<section class="faqs">
    <div class="container">
        <div class="faqs-in">
            {% for block in section.blocks %}
            {% if block.type == 'faq_item' %}
            <div class="faqs-block" {{ block.shopify_attributes }}>
                <div class="top">
                    {% if forloop.first and section.settings.heading != blank %}
                    <h2>{{ section.settings.heading }}</h2>
                    {% endif %}
                </div>
                <div class="bottom">
                    {% if block.settings.image != blank %}
                    <div class="faqs-img">
                        <img src="{{ block.settings.image | image_url: width: 800 }}"
                            alt="{{ block.settings.image.alt | escape }}" class="img" loading="lazy">
                    </div>
                    {% endif %}
                    <div>
                        {% if block.settings.question != blank %}
                        <h4>{{ block.settings.question }}</h4>
                        {% endif %}
                        {% if block.settings.answer != blank %}
                        <p>{{ block.settings.answer }}</p>
                        {% endif %}
                        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                        <a href="{{ block.settings.button_link }}">{{ block.settings.button_text }}</a>
                        {% endif %}
                    </div>

                </div>
            </div>
            {% endif %}
            {% endfor %}
        </div>
    </div>
</section>

{% schema %}
{
"name": "FAQs",
"tag": "section",
"class": "faqs-section",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Section Heading"
}
],
"blocks": [
{
"type": "faq_item",
"name": "FAQ Item",
"settings": [
{
"type": "image_picker",
"id": "image",
"label": "Image"
},
{
"type": "text",
"id": "question",
"label": "Question"
},
{
"type": "textarea",
"id": "answer",
"label": "Answer"
},
{
"type": "text",
"id": "button_text",
"label": "Button Text"
},
{
"type": "url",
"id": "button_link",
"label": "Button Link"
}
]
}
],
"presets": [
{
"name": "FAQs"
}
],
"max_blocks": 4
}
{% endschema %}