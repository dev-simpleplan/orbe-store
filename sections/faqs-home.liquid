<section class="faqs">
  <div class="container">
    {% if section.settings.heading != blank %}
      <div class="top">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="faqs-in">
      {% for block in section.blocks %}
        <div class="faqs-block" {{ block.shopify_attributes }}>
          <div class="bottom">
            {% if block.settings.image != blank %}
              <div class="faqs-img">
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: '', class: 'img' }}
              </div>
            {% endif %}

            <div>
              {% if block.settings.question != blank %}
                <h4>{{ block.settings.question }}</h4>
              {% endif %}
              {% if block.settings.answer != blank %}
                <p>{{ block.settings.answer }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
      <div class="view-all-cta">
        <a href="{{ section.settings.cta_link }}" class="primary-btn">{{ section.settings.cta_text }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "FAQs",
  "tag": "section",
  "class": "faqs-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQs"
    }
  ]
}
{% endschema %}
