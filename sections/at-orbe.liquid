<section class="at-orbe" id="at-orbe-{{ section.id }}">
    <div class="container">
        <div class="at-orbe-in">
            <div class="at-orbe-block-wrap">
                <div class="at-orbe-block">
                    {% if section.settings.image_1 != blank %}
                        <img src="{{ section.settings.image_1 | image_url }}" alt="" class="img">
                    {% endif %}
                </div>
                <div class="at-orbe-block text-animation">
                    {% if section.settings.text_1 != blank %}
                        <h3>{{ section.settings.text_1 }}</h3>
                    {% endif %}
                </div>
                <div class="at-orbe-block text-animation">
                    {% if section.settings.text_2 != blank %}
                        <h3>{{ section.settings.text_2 }}</h3>
                    {% endif %}
                    {% if section.settings.small_image != blank %}
                        <div class="small-img-parallex">
                            <img src="{{ section.settings.small_image | image_url }}" alt="" class="img">
                        </div>
                    {% endif %}
                </div>
                <div class="at-orbe-block">
                    {% if section.settings.image_2 != blank %}
                        <img src="{{ section.settings.image_2 | image_url }}" alt="" class="img">
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

<script>
(function () {
  const root = document.getElementById('at-orbe-{{ section.id }}');
  if (!root) return;

  const el = root.querySelector('.small-img-parallex');
  if (!el) return;

  const section = el.closest('.at-orbe-block');
  if (!section) return;

  function onScroll() {
    const rect      = section.getBoundingClientRect();
    const viewH     = window.innerHeight;

    // progress: 0 when block bottom enters viewport, 1 when block top exits
    const total    = viewH + rect.height;
    const traveled = viewH - rect.top;
    const progress = Math.min(Math.max(traveled / total, 0), 1);

    // starts at +30% (below), moves to -30% (above) as you scroll
    const y = 30 - progress * 80;
    el.style.transform = `translateY(${y}%)`;
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>

{% schema %}
{
  "name": "At Orbe",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Text 1"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Text 2"
    },
    {
      "type": "image_picker",
      "id": "small_image",
      "label": "Small Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    }
  ],
  "presets": [
    {
      "name": "At Orbe"
    }
  ]
}
{% endschema %}
