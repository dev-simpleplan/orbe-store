<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Georgia', serif;
        color: #1a1a1a;
        overflow-x: hidden;
    }

    .intro-section {
        height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .intro-section h1 {
        font-size: clamp(1.8rem, 4vw, 3.5rem);
        font-weight: 300;
        letter-spacing: 0.08em;
        color: #1a1a1a;
    }

    .sticky-wrapper {
        height: 420vh;
        position: relative;
    }

    .sticky-inner {
        position: sticky;
        top: 0;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .scene {
        position: relative;
        width: min(490px, 82vw);
        height: min(490px, 82vw);
    }

    /* Orbit ring */
    .orbit-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 1px solid #CDCDCD;
    }

    .accent-ring {
        position: absolute;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        border: 1px solid #CDCDCD;
        top: 50%;
        transform: translateY(-50%);
    }

    .accent-ring.left {
        left: -40px;
    }

    .accent-ring.right {
        right: -40px;
    }

    /* Gold dots — positioned absolutely by JS each frame */
    .orbit-dot {
        position: absolute;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(180deg, #B98846 -10.88%, #FFFAB6 100%);
        transform: translate(-50%, -50%);
        pointer-events: none;
    }

    /* Labels — positioned absolutely by JS each frame, NEVER rotated */
    .orbit-label {
        position: absolute;
        width: 240px;
        text-align: center;
        transform: translate(-50%, -50%);
        pointer-events: none;
        background-color: #F2F3F5;
        border-radius: 16px;
        padding: 20px 25px;
        z-index: 99;
    }

    .orbit-label .label-title {
        font-size: 18px;
        font-weight: 350;
        letter-spacing: -0.05em;
        line-height: 99%;
        color: #1a1a1a;
        display: block;
        margin-bottom: 3px;
    }

    .orbit-label .label-sub {
        font-size: 10.5px;
        font-family: var(--aspekta);
        line-height: 112%;
        font-weight: 300;
        color: #1A1A1A;
        display: block;
    }

    .center-blob {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 62%;
        height: 62%;
        transform: translate(-50%, -50%);
        z-index: -1;
        pointer-events: none;
        width: min(490px, 82vw);
        height: min(490px, 82vw);
        border-radius: 50%;
        overflow: hidden;
    }

    .slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        transition: opacity 0.55s ease;
        pointer-events: none;
    }

    .slide img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }

    .center-blob .blob-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        pointer-events: none;
    }

    .slide.active {
        opacity: 1;
    }

    @media (max-width: 767px) {
        #stickyWrapper-{{ section.id }} {
            height: 260vh;
        }

        #stickyWrapper-{{ section.id }} .sticky-inner {
            align-items: center;
            /* padding-top: 70px; */
        }

        #stickyWrapper-{{ section.id }} .scene {
            width: min(430px, 100vw);
            height: 430px;
            overflow: visible;
        }

        #stickyWrapper-{{ section.id }} .orbit-ring {
            width: min(270px, 64vw);
            height: min(270px, 64vw);
            top: 88px;
            left: 0;
            right: 0;
            bottom: auto;
            margin: 0 auto;
        }

        #stickyWrapper-{{ section.id }} .accent-ring {
            width: 48px;
            height: 48px;
        }

        #stickyWrapper-{{ section.id }} .accent-ring.left {
            left: -24px;
        }

        #stickyWrapper-{{ section.id }} .accent-ring.right {
            right: -24px;
        }

        #stickyWrapper-{{ section.id }} .orbit-dot {
            width: 12px;
            height: 12px;
        }

        #stickyWrapper-{{ section.id }} .orbit-label {
            width: 118px;
            padding: 0;
            border-radius: 0;
            background: transparent;
            text-align: left;
            z-index: 4;
        }

        #stickyWrapper-{{ section.id }} .orbit-label .label-title {
            font-size: 13px;
            line-height: 94%;
            margin-bottom: 2px;
        }

        #stickyWrapper-{{ section.id }} .orbit-label .label-sub {
            font-size: 10px;
            line-height: 106%;
        }

        #stickyWrapper-{{ section.id }} .center-blob {
            width: min(180px, 42vw);
            height: min(180px, 42vw);
            left: 50%;
            top: 52%;
            transform: translate(-50%, -50%);
        }
        #stickyWrapper-{{ section.id }} .center-blob .slide:nth-child(2) {
        width: min(220px, 42vw);
        height: min(220px, 42vw);
         left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
        }
    }

    @media (min-width: 768px) and (max-width: 991px) {
        #stickyWrapper-{{ section.id }} {
            height: 280vh;
        }

        #stickyWrapper-{{ section.id }} .sticky-inner {
            padding-top: 80px;
            align-items: flex-start;
        }

        #stickyWrapper-{{ section.id }} .scene {
            width: min(620px, 92vw);
            height: 590px;
        }

        #stickyWrapper-{{ section.id }} .orbit-ring {
            width: min(420px, 66vw);
            height: min(420px, 66vw);
            top: 92px;
            left: 0;
            right: 0;
            bottom: auto;
            margin: 0 auto;
        }

        #stickyWrapper-{{ section.id }} .orbit-dot {
            width: 18px;
            height: 18px;
        }

        #stickyWrapper-{{ section.id }} .orbit-label {
            width: 150px;
            padding: 0;
            border-radius: 0;
            background: transparent;
            text-align: left;
        }

        #stickyWrapper-{{ section.id }} .orbit-label .label-title {
            font-size: 16px;
        }

        #stickyWrapper-{{ section.id }} .orbit-label .label-sub {
            font-size: 11px;
        }

        #stickyWrapper-{{ section.id }} .center-blob {
            width: min(270px, 42vw);
            height: min(270px, 42vw);
            left: 50%;
            top: 51%;
            transform: translate(-50%, -50%);
        }
    }
</style>

<section class="sticky-wrapper" id="stickyWrapper-{{ section.id }}">
    <div class="sticky-inner">
        <div class="scene">

            <div class="orbit-ring">
                <div class="accent-ring left"></div>
                <div class="accent-ring right"></div>
            </div>

            <!-- gold dots -->
            {% for block in section.blocks limit: 4 %}
                <div class="orbit-dot" {{ block.shopify_attributes }}></div>
            {% endfor %}

            <!-- text labels -->
            {% for block in section.blocks limit: 4 %}
                <div class="orbit-label">
                    {% if block.settings.title != blank %}
                        <span class="label-title">{{ block.settings.title }}</span>
                    {% endif %}
                    {% if block.settings.text != blank %}
                        <span class="label-sub">{{ block.settings.text }}</span>
                    {% endif %}
                </div>
            {% endfor %}

            <!-- Central blobs -->
            <div class="center-blob">
                {% if section.settings.video != blank %}
                    <video class="blob-video" muted playsinline webkit-playsinline preload="auto" tabindex="-1" aria-hidden="true">
                        {% for source in section.settings.video.sources %}
                            <source src="{{ source.url }}" type="{{ source.mime_type }}">
                        {% endfor %}
                    </video>
                {% else %}
                    {% if section.settings.image_1 != blank %}
                        <div class="slide active">
                            {{ section.settings.image_1 | image_url: width: 760 | image_tag: loading: 'lazy', alt: '', class: 'icon' }}
                        </div>
                    {% endif %}
                    {% if section.settings.image_2 != blank %}
                        <div class="slide{% if section.settings.image_1 == blank %} active{% endif %}">
                            {{ section.settings.image_2 | image_url: width: 760 | image_tag: loading: 'lazy', alt: '', class: 'icon' }}
                        </div>
                    {% endif %}
                {% endif %}
            </div>

        </div>
    </div>
</section>
<script>
    (function () {
        function init() {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
                setTimeout(init, 100);
                return;
            }

            gsap.registerPlugin(ScrollTrigger);

            const wrapper = document.getElementById('stickyWrapper-{{ section.id }}');
            if (!wrapper) return;

            const scene = wrapper.querySelector('.scene');
            const orbitRing = wrapper.querySelector('.orbit-ring');
            const dots = Array.from(wrapper.querySelectorAll('.orbit-dot'));
            const lbls = Array.from(wrapper.querySelectorAll('.orbit-label'));
            const slides = Array.from(wrapper.querySelectorAll('.slide'));
            const blobVideo = wrapper.querySelector('.blob-video');
            const imageSwapProgress = 0.82;
            let currentDeg = 0;
            let activeSlideIndex = -1;
            let videoDuration = 0;
            let targetTime = 0;
            let videoRafId = null;
            let videoPrimed = false;

            function videoTick() {
                videoRafId = null;
                if (!blobVideo || !videoDuration) return;
                if (!blobVideo.paused) blobVideo.pause();
                var cur = blobVideo.currentTime;
                var diff = targetTime - cur;
                if (Math.abs(diff) > 0.008) {
                    // Ease toward the scroll target; re-setting each frame self-heals
                    // if any single seek gets dropped (fixes reverse-scroll freezing).
                    blobVideo.currentTime = cur + diff * 0.25;
                    videoRafId = requestAnimationFrame(videoTick);
                }
            }

            function seekVideo(t) {
                targetTime = t;
                if (videoRafId === null) {
                    videoRafId = requestAnimationFrame(videoTick);
                }
            }

            function primeVideo() {
                if (videoPrimed || !blobVideo) return;
                videoDuration = blobVideo.duration || 0;
                // Warm the decoder with a play->pause cycle so backward seeks repaint.
                var playAttempt = blobVideo.play();
                var finish = function () {
                    blobVideo.pause();
                    blobVideo.currentTime = 0;
                    videoPrimed = true;
                    updateOrbitFromScroll();
                };
                if (playAttempt && typeof playAttempt.then === 'function') {
                    playAttempt.then(finish).catch(finish);
                } else {
                    finish();
                }
            }

            if (blobVideo) {
                blobVideo.autoplay = false;
                blobVideo.removeAttribute('autoplay');
                // Never let it free-play once primed; only scroll drives the frame.
                blobVideo.addEventListener('play', function () {
                    if (videoPrimed) blobVideo.pause();
                });
                if (blobVideo.readyState >= 2) {
                    primeVideo();
                } else {
                    blobVideo.addEventListener('loadeddata', primeVideo, { once: true });
                }
            }

            if (!scene || !orbitRing || dots.length < 1 || lbls.length < 1) return;

            const existingTrigger = ScrollTrigger.getById('rotating-circle-{{ section.id }}');
            if (existingTrigger) existingTrigger.kill();

            function positionOrbit(deg) {
                currentDeg = deg;
                const size = orbitRing.offsetWidth;
                const cx = orbitRing.offsetLeft + size / 2;
                const cy = orbitRing.offsetTop + size / 2;
                const dotR = (size / 2) - 1;
                const isCompact = window.matchMedia('(max-width: 991px)').matches;
                const isMobile = window.matchMedia('(max-width: 767px)').matches;
                const labelR = (size / 2) + 70;
                const compactLabelInset = (lbls[0].offsetWidth / 2) + (isMobile ? 24 : 30);
                const compactLabels = [
                    { x: compactLabelInset, y: isMobile ? 52 : 60 },
                    { x: scene.offsetWidth - compactLabelInset, y: isMobile ? 52 : 60 },
                    { x: scene.offsetWidth - compactLabelInset, y: scene.offsetHeight - (isMobile ? 58 : 70) },
                    { x: compactLabelInset, y: scene.offsetHeight - (isMobile ? 58 : 70) },
                ];
                const itemCount = Math.min(dots.length, lbls.length);
                const angleStep = 360 / itemCount;

                for (let i = 0; i < itemCount; i++) {
                    const a = ((deg - 90) + i * angleStep) * (Math.PI / 180);

                    dots[i].style.left = (cx + Math.cos(a) * dotR) + 'px';
                    dots[i].style.top = (cy + Math.sin(a) * dotR) + 'px';

                    if (isCompact) {
                        lbls[i].style.left = compactLabels[i % compactLabels.length].x + 'px';
                        lbls[i].style.top = compactLabels[i % compactLabels.length].y + 'px';
                    } else {
                        lbls[i].style.left = (cx + Math.cos(a) * labelR) + 'px';
                        lbls[i].style.top = (cy + Math.sin(a) * labelR) + 'px';
                    }
                }
            }

            function setActiveSlide(index) {
                if (!slides.length || activeSlideIndex === index) return;
                activeSlideIndex = index;
                slides.forEach((slide, slideIndex) => {
                    slide.classList.toggle('active', slideIndex === index);
                });
            }

            positionOrbit(0);

            function updateOrbitFromScroll() {
                const rect = wrapper.getBoundingClientRect();
                const distance = Math.max(1, wrapper.offsetHeight - window.innerHeight);
                const progress = gsap.utils.clamp(0, 1, -rect.top / distance);
                const rotateProgress = gsap.utils.clamp(0, 1, progress / imageSwapProgress);
                const deg = rotateProgress * 180;

                gsap.set(orbitRing, { rotation: deg * 0.2 });
                positionOrbit(deg);

                if (blobVideo && videoDuration) {
                    // Scrub the video: map scroll progress to playback time (both directions).
                    if (!blobVideo.paused) blobVideo.pause();
                    var t = gsap.utils.clamp(0, videoDuration - 0.05, progress * videoDuration);
                    seekVideo(t);
                } else {
                    setActiveSlide(progress >= imageSwapProgress && slides.length > 1 ? 1 : 0);
                }
            }

            const trigger = ScrollTrigger.create({
                id: 'rotating-circle-{{ section.id }}',
                trigger: wrapper,
                start: 'top top',
                end: 'bottom bottom',
                scrub: 2.4,
                invalidateOnRefresh: true,
                onRefresh: updateOrbitFromScroll,
                onUpdate: updateOrbitFromScroll,
            });

            if (window.lenis && typeof window.lenis.on === 'function') {
                window.lenis.on('scroll', updateOrbitFromScroll);
            } else {
                window.addEventListener('scroll', updateOrbitFromScroll, { passive: true });
            }

            let resizeTimer;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(updateOrbitFromScroll, 120);
            });

            requestAnimationFrame(() => {
                updateOrbitFromScroll();
                ScrollTrigger.refresh();
            });
            window.addEventListener('load', () => {
                updateOrbitFromScroll();
                ScrollTrigger.refresh();
            }, { once: true });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
</script>

{% schema %}
{
  "name": "Rotating Circle",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Center video",
      "info": "Plays/scrubs with scroll. If set, it replaces the two images below."
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    }
  ],
  "blocks": [
    {
      "type": "text_item",
      "name": "Text Item",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rotating Circle"
    }
  ]
}
{% endschema %}
