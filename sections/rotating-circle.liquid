<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Georgia', serif;
        color: #1a1a1a;
        overflow-x: hidden;
    }

    .intro-section {
        height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .intro-section h1 {
        font-size: clamp(1.8rem, 4vw, 3.5rem);
        font-weight: 300;
        letter-spacing: 0.08em;
        color: #1a1a1a;
    }

    .sticky-wrapper {
        height: 420vh;
        position: relative;
    }

    .sticky-inner {
        position: sticky;
        top: 0;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .scene {
        position: relative;
        width: min(560px, 82vw);
        height: min(560px, 82vw);
    }

    /* Orbit ring */
    .orbit-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 1px solid #CDCDCD;
    }

    .accent-ring {
        position: absolute;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        border: 1px solid #CDCDCD;
        top: 50%;
        transform: translateY(-50%);
    }

    .accent-ring.left {
        left: -40px;
    }

    .accent-ring.right {
        right: -40px;
    }

    /* Gold dots — positioned absolutely by JS each frame */
    .orbit-dot {
        position: absolute;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(180deg, #B98846 -10.88%, #FFFAB6 100%);
        transform: translate(-50%, -50%);
        pointer-events: none;
    }

    /* Labels — positioned absolutely by JS each frame, NEVER rotated */
    .orbit-label {
        position: absolute;
        width: 240px;
        text-align: center;
        transform: translate(-50%, -50%);
        pointer-events: none;
        background-color: #F2F3F5;
        border-radius: 16px;
        padding: 20px 25px;
        z-index: 99;
    }

    .orbit-label .label-title {
        font-size: 18px;
        font-weight: 350;
        letter-spacing: -0.05em;
        line-height: 99%;
        color: #1a1a1a;
        display: block;
        margin-bottom: 3px;
    }

    .orbit-label .label-sub {
        font-size: 10.5px;
        font-family: var(--aspekta);
        line-height: 112%;
        font-weight: 300;
        color: #1A1A1A;
        display: block;
    }

    .slide {
        position: absolute;
        opacity: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 70%;
        left: 88px;
        top: 50px;
    }

    .slide.active {
        opacity: 1;
    }

    @media (max-width: 767px) {
        #stickyWrapper {
            height: 260vh;
        }

        #stickyWrapper .sticky-inner {
            align-items: center;
            /* padding-top: 70px; */
        }

        #stickyWrapper .scene {
            width: min(430px, 100vw);
            height: 430px;
            overflow: visible;
        }

        #stickyWrapper .orbit-ring {
            width: min(270px, 64vw);
            height: min(270px, 64vw);
            inset: 88px auto auto 50%;
            transform: translateX(-50%);
        }

        #stickyWrapper .accent-ring {
            width: 48px;
            height: 48px;
        }

        #stickyWrapper .accent-ring.left {
            left: -24px;
        }

        #stickyWrapper .accent-ring.right {
            right: -24px;
        }

        #stickyWrapper .orbit-dot {
            width: 12px;
            height: 12px;
        }

        #stickyWrapper .orbit-label {
            width: 118px;
            padding: 0;
            border-radius: 0;
            background: transparent;
            text-align: left;
            z-index: 4;
        }

        #stickyWrapper .orbit-label .label-title {
            font-size: 13px;
            line-height: 94%;
            margin-bottom: 2px;
        }

        #stickyWrapper .orbit-label .label-sub {
            font-size: 10px;
            line-height: 106%;
        }

        #stickyWrapper .slide {
            width: min(210px, 50vw);
            left: 50%;
            top: 78px;
            transform: translateX(-50%);
        }
    }

    @media (min-width: 768px) and (max-width: 991px) {
        #stickyWrapper {
            height: 280vh;
        }

        #stickyWrapper .sticky-inner {
            padding-top: 80px;
            align-items: flex-start;
        }

        #stickyWrapper .scene {
            width: min(620px, 92vw);
            height: 590px;
        }

        #stickyWrapper .orbit-ring {
            width: min(420px, 66vw);
            height: min(420px, 66vw);
            inset: 92px auto auto 50%;
            transform: translateX(-50%);
        }

        #stickyWrapper .orbit-dot {
            width: 18px;
            height: 18px;
        }

        #stickyWrapper .orbit-label {
            width: 150px;
            padding: 0;
            border-radius: 0;
            background: transparent;
            text-align: left;
        }

        #stickyWrapper .orbit-label .label-title {
            font-size: 16px;
        }

        #stickyWrapper .orbit-label .label-sub {
            font-size: 11px;
        }

        #stickyWrapper .slide {
            width: min(310px, 48vw);
            left: 50%;
            top: 86px;
            transform: translateX(-50%);
        }
    }
</style>

<section class="sticky-wrapper" id="stickyWrapper">
    <div class="sticky-inner">
        <div class="scene" id="scene">

            <div class="orbit-ring" id="orbitRing">
                <div class="accent-ring left"></div>
                <div class="accent-ring right"></div>
            </div>

            <!-- 4 gold dots -->
            <div class="orbit-dot" id="dot0"></div>
            <div class="orbit-dot" id="dot1"></div>
            <div class="orbit-dot" id="dot2"></div>
            <div class="orbit-dot" id="dot3"></div>

            <!-- 4 text labels -->
            <div class="orbit-label" id="lbl0"><span class="label-title" id="lt0"></span><span class="label-sub"
                    id="ls0"></span></div>
            <div class="orbit-label" id="lbl1"><span class="label-title" id="lt1"></span><span class="label-sub"
                    id="ls1"></span></div>
            <div class="orbit-label" id="lbl2"><span class="label-title" id="lt2"></span><span class="label-sub"
                    id="ls2"></span></div>
            <div class="orbit-label" id="lbl3"><span class="label-title" id="lt3"></span><span class="label-sub"
                    id="ls3"></span></div>

            <!-- Central blobs -->
            <div class="center-blob">
                <div class="slide active" id="slide1">
                    <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/image_480.png?v=1777636144"
                        alt="Image" class="icon">
                </div>
            </div>

        </div>
    </div>
</section>
<script>
    gsap.registerPlugin(ScrollTrigger);

    const slideData = [
        [
            { title: "System-Level Formulation", sub: "Designed for synergy, not isolation." },
            { title: "Steady Energy Pathways", sub: "Helps reduce peaks and dips in the system." },
            { title: "Dose Aware Design", sub: "Respects the body's natural balance." },
            { title: "Optimised Bioavailability", sub: "Ensures efficient absorption and use." },
        ]
    ];

    const scene = document.getElementById('scene');
    const orbitRing = document.getElementById('orbitRing');
    const dots = [0, 1, 2, 3].map(i => document.getElementById('dot' + i));
    const lbls = [0, 1, 2, 3].map(i => document.getElementById('lbl' + i));
    const ltEls = [0, 1, 2, 3].map(i => document.getElementById('lt' + i));
    const lsEls = [0, 1, 2, 3].map(i => document.getElementById('ls' + i));

    function setLabelText(idx) {
        slideData[idx].forEach((d, i) => {
            ltEls[i].textContent = d.title;
            lsEls[i].textContent = d.sub;
        });
    }
    setLabelText(0);

    /*
     * Key fix: instead of rotating a container and counter-rotating children,
     * we calculate each dot/label x,y position directly using cos/sin
     * and set left/top every frame. Labels get NO rotation — they stay upright always.
     */
    function positionOrbit(deg) {
        const sceneRect = scene.getBoundingClientRect();
        const ringRect = orbitRing.getBoundingClientRect();
        const size = ringRect.width;
        const cx = ringRect.left - sceneRect.left + (size / 2);
        const cy = ringRect.top - sceneRect.top + (size / 2);
        const dotR = (size / 2) - 1;      /* sit on the ring */
        const isCompact = window.matchMedia('(max-width: 991px)').matches;
        const isMobile = window.matchMedia('(max-width: 767px)').matches;
        const labelR = (size / 2) + 70;     /* outside the ring */
        const compactLabelInset = (lbls[0].offsetWidth / 2) + (isMobile ? 24 : 30);
        const compactLabels = [
            { x: compactLabelInset, y: isMobile ? 52 : 60 },
            { x: scene.offsetWidth - compactLabelInset, y: isMobile ? 52 : 60 },
            { x: scene.offsetWidth - compactLabelInset, y: scene.offsetHeight - (isMobile ? 58 : 70) },
            { x: compactLabelInset, y: scene.offsetHeight - (isMobile ? 58 : 70) },
        ];

        for (let i = 0; i < 4; i++) {
            /* start at top (-90°), step 90° per item, add current rotation */
            const a = ((deg - 90) + i * 90) * (Math.PI / 180);

            /* dot */
            dots[i].style.left = (cx + Math.cos(a) * dotR) + 'px';
            dots[i].style.top = (cy + Math.sin(a) * dotR) + 'px';

            /* label — same angle, bigger radius, NO rotation property touched */
            if (isCompact) {
                lbls[i].style.left = compactLabels[i].x + 'px';
                lbls[i].style.top = compactLabels[i].y + 'px';
            } else {
                lbls[i].style.left = (cx + Math.cos(a) * labelR) + 'px';
                lbls[i].style.top = (cy + Math.sin(a) * labelR) + 'px';
            }
        }
    }

    positionOrbit(0);

    ScrollTrigger.create({
        trigger: '#stickyWrapper',
        start: 'top top',
        end: 'bottom bottom',
        scrub: 2.4,
        onUpdate(self) {
            const p = self.progress;
            const deg = p * 240; /* reduced orbit for calmer label movement */

            /* Ring itself drifts slowly */
            gsap.set(orbitRing, { rotation: deg * 0.2 });

            /* Dots & labels orbit — labels stay upright (no rotation set on them) */
            positionOrbit(deg);
        }
    });

    let resizeTimer;
    window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => positionOrbit(0), 120);
    });
</script>
