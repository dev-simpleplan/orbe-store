<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Georgia', serif;
        color: #1a1a1a;
        overflow-x: hidden;
    }

    .intro-section {
        height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .intro-section h1 {
        font-size: clamp(1.8rem, 4vw, 3.5rem);
        font-weight: 300;
        letter-spacing: 0.08em;
        color: #1a1a1a;
    }

    .sticky-wrapper {
        height: 420vh;
        position: relative;
    }

    .sticky-inner {
        position: sticky;
        top: 0;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .scene {
        position: relative;
        width: min(560px, 82vw);
        height: min(560px, 82vw);
    }

    /* Orbit ring */
    .orbit-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 1px solid #CDCDCD;
    }

    .accent-ring {
        position: absolute;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        border: 1px solid #CDCDCD;
        top: 50%;
        transform: translateY(-50%);
    }

    .accent-ring.left {
        left: -40px;
    }

    .accent-ring.right {
        right: -40px;
    }

    /* Gold dots — positioned absolutely by JS each frame */
    .orbit-dot {
        position: absolute;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(180deg, #B98846 -10.88%, #FFFAB6 100%);
        transform: translate(-50%, -50%);
        pointer-events: none;
    }

    /* Labels — positioned absolutely by JS each frame, NEVER rotated */
    .orbit-label {
        position: absolute;
        width: 240px;
        text-align: center;
        transform: translate(-50%, -50%);
        pointer-events: none;
        background-color: #F2F3F5;
        border-radius: 16px;
        padding: 20px 25px;
        z-index: 99;
    }

    .orbit-label .label-title {
        font-size: 18px;
        font-weight: 350;
        letter-spacing: -0.05em;
        line-height: 99%;
        color: #1a1a1a;
        display: block;
        margin-bottom: 3px;
    }

    .orbit-label .label-sub {
        font-size: 10.5px;
        font-family: var(--aspekta);
        line-height: 112%;
        font-weight: 300;
        color: #1A1A1A;
        display: block;
    }

    .slide {
        position: absolute;
        opacity: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 70%;
        left: 88px;
        top: 50px;
    }

    .slide.active {
        opacity: 1;
    }

    @media (max-width: 767px) {
        #stickyWrapper-{{ section.id }} {
            height: 260vh;
        }

        #stickyWrapper-{{ section.id }} .sticky-inner {
            align-items: center;
            /* padding-top: 70px; */
        }

        #stickyWrapper-{{ section.id }} .scene {
            width: min(430px, 100vw);
            height: 430px;
            overflow: visible;
        }

        #stickyWrapper-{{ section.id }} .orbit-ring {
            width: min(270px, 64vw);
            height: min(270px, 64vw);
            inset: 88px auto auto 50%;
            transform: translateX(-50%);
        }

        #stickyWrapper-{{ section.id }} .accent-ring {
            width: 48px;
            height: 48px;
        }

        #stickyWrapper-{{ section.id }} .accent-ring.left {
            left: -24px;
        }

        #stickyWrapper-{{ section.id }} .accent-ring.right {
            right: -24px;
        }

        #stickyWrapper-{{ section.id }} .orbit-dot {
            width: 12px;
            height: 12px;
        }

        #stickyWrapper-{{ section.id }} .orbit-label {
            width: 118px;
            padding: 0;
            border-radius: 0;
            background: transparent;
            text-align: left;
            z-index: 4;
        }

        #stickyWrapper-{{ section.id }} .orbit-label .label-title {
            font-size: 13px;
            line-height: 94%;
            margin-bottom: 2px;
        }

        #stickyWrapper-{{ section.id }} .orbit-label .label-sub {
            font-size: 10px;
            line-height: 106%;
        }

        #stickyWrapper-{{ section.id }} .slide {
            width: min(210px, 50vw);
            left: 50%;
            top: 78px;
            transform: translateX(-50%);
        }
    }

    @media (min-width: 768px) and (max-width: 991px) {
        #stickyWrapper-{{ section.id }} {
            height: 280vh;
        }

        #stickyWrapper-{{ section.id }} .sticky-inner {
            padding-top: 80px;
            align-items: flex-start;
        }

        #stickyWrapper-{{ section.id }} .scene {
            width: min(620px, 92vw);
            height: 590px;
        }

        #stickyWrapper-{{ section.id }} .orbit-ring {
            width: min(420px, 66vw);
            height: min(420px, 66vw);
            inset: 92px auto auto 50%;
            transform: translateX(-50%);
        }

        #stickyWrapper-{{ section.id }} .orbit-dot {
            width: 18px;
            height: 18px;
        }

        #stickyWrapper-{{ section.id }} .orbit-label {
            width: 150px;
            padding: 0;
            border-radius: 0;
            background: transparent;
            text-align: left;
        }

        #stickyWrapper-{{ section.id }} .orbit-label .label-title {
            font-size: 16px;
        }

        #stickyWrapper-{{ section.id }} .orbit-label .label-sub {
            font-size: 11px;
        }

        #stickyWrapper-{{ section.id }} .slide {
            width: min(310px, 48vw);
            left: 50%;
            top: 86px;
            transform: translateX(-50%);
        }
    }
</style>

<section class="sticky-wrapper" id="stickyWrapper-{{ section.id }}">
    <div class="sticky-inner">
        <div class="scene">

            <div class="orbit-ring">
                <div class="accent-ring left"></div>
                <div class="accent-ring right"></div>
            </div>

            <!-- 4 gold dots -->
            <div class="orbit-dot"></div>
            <div class="orbit-dot"></div>
            <div class="orbit-dot"></div>
            <div class="orbit-dot"></div>

            <!-- 4 text labels -->
            <div class="orbit-label"><span class="label-title"></span><span class="label-sub"></span></div>
            <div class="orbit-label"><span class="label-title"></span><span class="label-sub"></span></div>
            <div class="orbit-label"><span class="label-title"></span><span class="label-sub"></span></div>
            <div class="orbit-label"><span class="label-title"></span><span class="label-sub"></span></div>

            <!-- Central blobs -->
            <div class="center-blob">
                <div class="slide active">
                    <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/image_480.png?v=1777636144"
                        alt="Image" class="icon">
                </div>
            </div>

        </div>
    </div>
</section>
<script>
    (function () {
        function init() {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
                setTimeout(init, 100);
                return;
            }

            gsap.registerPlugin(ScrollTrigger);

            const wrapper = document.getElementById('stickyWrapper-{{ section.id }}');
            if (!wrapper) return;

            const scene = wrapper.querySelector('.scene');
            const orbitRing = wrapper.querySelector('.orbit-ring');
            const dots = Array.from(wrapper.querySelectorAll('.orbit-dot'));
            const lbls = Array.from(wrapper.querySelectorAll('.orbit-label'));
            const ltEls = Array.from(wrapper.querySelectorAll('.label-title'));
            const lsEls = Array.from(wrapper.querySelectorAll('.label-sub'));
            let currentDeg = 0;

            if (!scene || !orbitRing || dots.length < 4 || lbls.length < 4) return;

            const existingTrigger = ScrollTrigger.getById('rotating-circle-{{ section.id }}');
            if (existingTrigger) existingTrigger.kill();

            const slideData = [
                { title: "System-Level Formulation", sub: "Designed for synergy, not isolation." },
                { title: "Steady Energy Pathways", sub: "Helps reduce peaks and dips in the system." },
                { title: "Dose Aware Design", sub: "Respects the body's natural balance." },
                { title: "Optimised Bioavailability", sub: "Ensures efficient absorption and use." },
            ];

            slideData.forEach((d, i) => {
                ltEls[i].textContent = d.title;
                lsEls[i].textContent = d.sub;
            });

            function positionOrbit(deg) {
                currentDeg = deg;
                const sceneRect = scene.getBoundingClientRect();
                const ringRect = orbitRing.getBoundingClientRect();
                const size = ringRect.width;
                const cx = ringRect.left - sceneRect.left + (size / 2);
                const cy = ringRect.top - sceneRect.top + (size / 2);
                const dotR = (size / 2) - 1;
                const isCompact = window.matchMedia('(max-width: 991px)').matches;
                const isMobile = window.matchMedia('(max-width: 767px)').matches;
                const labelR = (size / 2) + 70;
                const compactLabelInset = (lbls[0].offsetWidth / 2) + (isMobile ? 24 : 30);
                const compactLabels = [
                    { x: compactLabelInset, y: isMobile ? 52 : 60 },
                    { x: scene.offsetWidth - compactLabelInset, y: isMobile ? 52 : 60 },
                    { x: scene.offsetWidth - compactLabelInset, y: scene.offsetHeight - (isMobile ? 58 : 70) },
                    { x: compactLabelInset, y: scene.offsetHeight - (isMobile ? 58 : 70) },
                ];

                for (let i = 0; i < 4; i++) {
                    const a = ((deg - 90) + i * 90) * (Math.PI / 180);

                    dots[i].style.left = (cx + Math.cos(a) * dotR) + 'px';
                    dots[i].style.top = (cy + Math.sin(a) * dotR) + 'px';

                    if (isCompact) {
                        lbls[i].style.left = compactLabels[i].x + 'px';
                        lbls[i].style.top = compactLabels[i].y + 'px';
                    } else {
                        lbls[i].style.left = (cx + Math.cos(a) * labelR) + 'px';
                        lbls[i].style.top = (cy + Math.sin(a) * labelR) + 'px';
                    }
                }
            }

            positionOrbit(0);

            function updateOrbitFromScroll() {
                const rect = wrapper.getBoundingClientRect();
                const distance = Math.max(1, wrapper.offsetHeight - window.innerHeight);
                const progress = gsap.utils.clamp(0, 1, -rect.top / distance);
                const deg = progress * 240;

                gsap.set(orbitRing, { rotation: deg * 0.2 });
                positionOrbit(deg);
            }

            const trigger = ScrollTrigger.create({
                id: 'rotating-circle-{{ section.id }}',
                trigger: wrapper,
                start: 'top top',
                end: 'bottom bottom',
                scrub: 2.4,
                invalidateOnRefresh: true,
                onRefresh: updateOrbitFromScroll,
                onUpdate: updateOrbitFromScroll,
            });

            if (window.lenis && typeof window.lenis.on === 'function') {
                window.lenis.on('scroll', updateOrbitFromScroll);
            } else {
                window.addEventListener('scroll', updateOrbitFromScroll, { passive: true });
            }

            let resizeTimer;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(updateOrbitFromScroll, 120);
            });

            requestAnimationFrame(() => {
                updateOrbitFromScroll();
                ScrollTrigger.refresh();
            });
            window.addEventListener('load', () => {
                updateOrbitFromScroll();
                ScrollTrigger.refresh();
            }, { once: true });
        }

        init();
    })();
</script>
