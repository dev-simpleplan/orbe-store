<section class="essential-ingredient" id="essential-ingredient-{{ section.id }}">
    <div class="container">
        <div class="top">
            <div class="top-left">
                <div class="heading">
                    {% if section.settings.heading != blank %}
                    <h2>{{ section.settings.heading }}</h2>
                    {% endif %}
                    {% if section.settings.description != blank %}
                    <p>{{ section.settings.description }}</p>
                    {% endif %}
                </div>
            </div>
            <div class="top-right">
                {% if section.settings.link_text != blank %}
                <a href="#essential-ingredient-drawer-{{ section.id }}" class="open-ingredients">{{
                    section.settings.link_text }}</a>
                {% endif %}
            </div>
        </div>
        <div class="essential-ingredient-in">
            <div class="left">
                <div class="box-img">
                    {% if section.settings.box_image != blank %}
                    {{ section.settings.box_image | image_url: width: 900 | image_tag: alt: '', class: 'icon' }}
                    {% endif %}
                </div>
            </div>
            <div class="right">
                <div class="capsule-img">
                    {% if section.settings.capsule_image != blank %}
                    {{ section.settings.capsule_image | image_url: width: 300 | image_tag: alt: '', class: 'icon' }}
                    {% endif %}
                </div>
                <div class="accordion-wrap essential-ingredient">
                    <div class="accordion">
                        {% for block in section.blocks %}
                        <div class="accordion-item" {{ block.shopify_attributes }}>
                            <div class="accordion-title">
                                {{ block.settings.title }}
                                <span class="accordion-icon">
                                    {% render 'plus-accord-icon' %}
                                </span>
                            </div>
                            <div class="accordion-content">
                                {% assign content_lines = block.settings.content | newline_to_br | split: '<br />' %}
                                {% for line in content_lines %}
                                {% assign clean_line = line | strip %}
                                {% if clean_line != blank %}
                                <p>{{ clean_line }}</p>
                                {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="ingredient-drawer-backdrop" data-ingredient-drawer-close></div>
    <aside class="ingredient-drawer" id="essential-ingredient-drawer-{{ section.id }}" aria-hidden="true">
        <div class="ingredient-drawer-scroll" data-lenis-prevent>
            <div class="ingredient-drawer-head">
                {% if section.settings.drawer_eyebrow != blank %}
                <p>{{ section.settings.drawer_eyebrow }}</p>
                {% endif %}
                <button type="button" class="ingredient-drawer-close" aria-label="Close ingredients"
                    data-ingredient-drawer-close>
                    <span></span>
                    <span></span>
                </button>
            </div>
            <div class="ingredient-top-title">
                {% if section.settings.drawer_heading != blank %}
                <h2>{{ section.settings.drawer_heading }}</h2>
                {% endif %}
            </div>
            <div class="ingredient-drawer-accordion">
                {% for block in section.blocks %}
                <div class="ingredient-drawer-item">
                    <button type="button" class="ingredient-drawer-title">
                        <span>{{ block.settings.title }}</span>
                        <span class="ingredient-drawer-icon">{% render 'plus-accord-icon' %}</span>
                    </button>
                    <div class="ingredient-drawer-content">
                        {% assign drawer_lines = block.settings.content | newline_to_br | split: '<br />' %}
                        {% for line in drawer_lines %}
                        {% assign clean_line = line | strip %}
                        {% if clean_line != blank %}
                        <p>{{ clean_line }}</p>
                        {% endif %}
                        {% endfor %}
                    </div>
                </div>
                {% endfor %}
            </div>

            {% if section.settings.inactive_heading != blank or section.settings.inactive_text != blank %}
            <div class="ingredient-drawer-section">
                {% if section.settings.inactive_heading != blank %}
                <h2>{{ section.settings.inactive_heading }}</h2>
                {% endif %}
                {% assign inactive_lines = section.settings.inactive_text | newline_to_br | split: '<br />' %}
                {% for line in inactive_lines %}
                {% assign clean_line = line | strip %}
                {% if clean_line != blank %}
                <p>{{ clean_line }}</p>
                {% endif %}
                {% endfor %}
            </div>
            {% endif %}

            {% if section.settings.fill_weight_heading != blank or section.settings.fill_weight_text != blank %}
            <div class="ingredient-drawer-section">
                {% if section.settings.fill_weight_heading != blank %}
                <h2>{{ section.settings.fill_weight_heading }}</h2>
                {% endif %}
                {% assign fill_lines = section.settings.fill_weight_text | newline_to_br | split: '<br />' %}
                {% for line in fill_lines %}
                {% assign clean_line = line | strip %}
                {% if clean_line != blank %}
                <p>{{ clean_line }}</p>
                {% endif %}
                {% endfor %}
            </div>
            {% endif %}

            {% if section.settings.appearance_heading != blank or section.settings.appearance_text != blank %}
            <div class="ingredient-drawer-section">
                {% if section.settings.appearance_heading != blank %}
                <h2>{{ section.settings.appearance_heading }}</h2>
                {% endif %}
                {% if section.settings.appearance_text != blank %}
                <p>{{ section.settings.appearance_text }}</p>
                {% endif %}
            </div>
            {% endif %}

            {% if section.settings.nutrition_heading != blank or section.settings.nutrition_table_image != blank %}
            <div class="ingredient-drawer-section ingredient-drawer-nutrition">
                {% if section.settings.nutrition_heading != blank %}
                <h2>{{ section.settings.nutrition_heading }}</h2>
                {% endif %}
                {% if section.settings.nutrition_text != blank %}
                <p>{{ section.settings.nutrition_text }}</p>
                {% endif %}
                {% if section.settings.nutrition_table_image != blank %}
                <div class="ingredient-drawer-table-img">
                    {{ section.settings.nutrition_table_image | image_url: width: 900 | image_tag: alt: '', class: 'img'
                    }}
                </div>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </aside>
</section>
<script>
    (function () {
        function initEssentialIngredientAccordion() {
            var section = document.getElementById('essential-ingredient-{{ section.id }}');
            if (!section || section.dataset.accordionReady === 'true') return;

            var titles = Array.prototype.slice.call(section.querySelectorAll('.accordion-title'));
            if (!titles.length) return;

            section.dataset.accordionReady = 'true';

            function closeItem(title) {
                var panel = title.nextElementSibling;
                title.classList.remove('active');
                if (panel) panel.style.maxHeight = '0px';
            }

            function openItem(title) {
                var panel = title.nextElementSibling;
                title.classList.add('active');
                if (panel) panel.style.maxHeight = panel.scrollHeight + 'px';
            }

            titles.forEach(function (title) {
                title.addEventListener('click', function () {
                    var isActive = title.classList.contains('active');

                    titles.forEach(function (item) {
                        if (item !== title) closeItem(item);
                    });

                    if (isActive) {
                        closeItem(title);
                    } else {
                        openItem(title);
                    }
                });
            });

            openItem(titles[0]);

            var openButton = section.querySelector('.open-ingredients');
            var drawer = section.querySelector('.ingredient-drawer');
            var drawerCloseButtons = section.querySelectorAll('[data-ingredient-drawer-close]');
            var drawerTitles = Array.prototype.slice.call(section.querySelectorAll('.ingredient-drawer-title'));

            function closeDrawerItem(title) {
                var panel = title.nextElementSibling;
                title.classList.remove('active');
                if (panel) panel.style.maxHeight = '0px';
            }

            function openDrawerItem(title) {
                var panel = title.nextElementSibling;
                title.classList.add('active');
                if (panel) panel.style.maxHeight = panel.scrollHeight + 'px';
            }

            function openDrawer() {
                if (!drawer) return;
                drawer.setAttribute('aria-hidden', 'false');
                section.classList.add('ingredient-drawer-active');
                document.documentElement.classList.add('ingredient-drawer-open');
                document.body.classList.add('ingredient-drawer-open');
                if (drawerTitles.length) openDrawerItem(drawerTitles[0]);
                if (window.lenis) window.lenis.stop();
            }

            function closeDrawer() {
                if (!drawer) return;
                drawer.setAttribute('aria-hidden', 'true');
                section.classList.remove('ingredient-drawer-active');
                document.documentElement.classList.remove('ingredient-drawer-open');
                document.body.classList.remove('ingredient-drawer-open');
                if (window.lenis) window.lenis.start();
            }

            if (openButton) {
                openButton.addEventListener('click', function (event) {
                    event.preventDefault();
                    openDrawer();
                });
            }

            drawerCloseButtons.forEach(function (button) {
                button.addEventListener('click', closeDrawer);
            });

            drawerTitles.forEach(function (title) {
                title.addEventListener('click', function () {
                    var isActive = title.classList.contains('active');

                    drawerTitles.forEach(function (item) {
                        if (item !== title) closeDrawerItem(item);
                    });

                    if (isActive) {
                        closeDrawerItem(title);
                    } else {
                        openDrawerItem(title);
                    }
                });
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') closeDrawer();
            });

            window.addEventListener('resize', function () {
                var activeTitle = section.querySelector('.accordion-title.active');
                if (activeTitle) openItem(activeTitle);
                var activeDrawerTitle = section.querySelector('.ingredient-drawer-title.active');
                if (activeDrawerTitle) openDrawerItem(activeDrawerTitle);
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initEssentialIngredientAccordion);
        } else {
            initEssentialIngredientAccordion();
        }
    })();
</script>

