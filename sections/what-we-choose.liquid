<section class="what-we-choose" id="what-we-choose-{{ section.id }}"
    {% if section.settings.background_image != blank %}
      style="background-image: url('{{ section.settings.background_image | image_url }}');"
    {% endif %}>
    <div class="container">
        <div class="heading">
            {% if section.settings.heading != blank %}
              <h2>{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.description != blank %}
              <p>{{ section.settings.description }}</p>
            {% endif %}
        </div>
        <div class="what-we-choose-in">
            {% for block in section.blocks %}
              <div class="what-we-block"
                {% if block.settings.image != blank %}
                  style="background-image: url('{{ block.settings.image | image_url }}');"
                {% endif %}
                {{ block.shopify_attributes }}>
                  {% if block.settings.title != blank %}
                    <h3>{{ block.settings.title }}</h3>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <div class="text-white-block">
                        <p>{{ block.settings.text }}</p>
                    </div>
                  {% endif %}
              </div>
            {% endfor %}
        </div>
    </div>
</section>

<script>
  (function () {
    function init() {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        setTimeout(init, 100);
        return;
      }

      gsap.registerPlugin(ScrollTrigger);

      const section = document.getElementById('what-we-choose-{{ section.id }}');
      if (!section) return;

      const cards = gsap.utils.toArray(section.querySelectorAll('.what-we-block'));
      if (!cards.length) return;

      const getCardPath = (card, index) => {
        const sectionRect = section.getBoundingClientRect();
        const cardRect = card.getBoundingClientRect();

        return {
          startX: sectionRect.width / 2 + cardRect.width * 0.75,
          startY: sectionRect.height / 2 + cardRect.height * 0.85,
          endX: -sectionRect.width / 2 - cardRect.width * 0.85,
          endY: -sectionRect.height / 2 - cardRect.height * 0.85,
        };
      };

      gsap.set(cards, {
        autoAlpha: 0,
        xPercent: -50,
        yPercent: -40,
        x: 0,
        y: 0,
        rotate: 0,
      });

      const cardOverlap = 0.9;
      const cardEnterDuration = 0.75;
      const cardCenterHold = 0.25;
      const cardExitDuration = 0.65;
      const cardTotalDuration = cardEnterDuration + cardCenterHold + cardExitDuration;
      const timelineLength = (cards.length - 1) * cardOverlap + cardTotalDuration;
      const getPinDistance = () => window.innerHeight * timelineLength * 1.12;
      const getEarlyDistance = () => window.innerHeight * 0.8;

      ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: () => `+=${getPinDistance()}`,
        pin: true,
        anticipatePin: 1.5,
        invalidateOnRefresh: true,
      });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          end: () => `+=${getPinDistance() + getEarlyDistance()}`,
          scrub: 1,
          invalidateOnRefresh: true,
        },
      });

      cards.forEach((card, index) => {
        const path = () => getCardPath(card, index);
        const position = index * cardOverlap;

        tl.set(card, {
          autoAlpha: 1,
          x: () => path().startX,
          y: () => path().startY,
          rotate: 4,
        }, position);

        tl.to(card, {
          x: 0,
          y: 0,
          rotate: 0,
          ease: 'sine.inOut',
          duration: cardEnterDuration,
        }, position);

        tl.to(card, {
          x: 0,
          y: 0,
          rotate: 0,
          ease: 'none',
          duration: cardCenterHold,
        }, position + cardEnterDuration);

        tl.to(card, {
          x: () => path().endX,
          y: () => path().endY,
          rotate: -5,
          ease: 'sine.inOut',
          duration: cardExitDuration,
        }, position + cardEnterDuration + cardCenterHold);

        tl.set(card, { autoAlpha: 0 }, position + cardTotalDuration);
      });

      window.addEventListener('load', () => ScrollTrigger.refresh());
    }

    init();
  })();
</script>

{% schema %}
{
  "name": "What We Choose",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What We Choose"
    }
  ]
}
{% endschema %}
