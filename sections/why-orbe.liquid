<section class="why-orbe" id="why-orbe-{{ section.id }}">
  <div class="why-orbe-sticky"
    {% if section.settings.background_image != blank %}
      style="background-image: url('{{ section.settings.background_image | image_url }}');"
    {% endif %}>
    <div class="blur-overlay"></div>
    <div class="container">
      <div class="why-orbe-in">
        <div class="top">
          {% if section.settings.heading != blank %}
            <h2>{{ section.settings.heading }}</h2>
          {% endif %}
        </div>
        <div class="bottom">
          <div class="counter-grid">
            <div class="left">
              {% if section.settings.stat_1 != blank %}
                <h3>{{ section.settings.stat_1 }}</h3>
              {% endif %}
              {% if section.settings.text_1 != blank %}
                <p>{{ section.settings.text_1 }}</p>
              {% endif %}
            </div>
            <div class="center">
              {% if section.settings.stat_2 != blank %}
                <h3>{{ section.settings.stat_2 }}</h3>
              {% endif %}
              {% if section.settings.text_2 != blank %}
                <p>{{ section.settings.text_2 }}</p>
              {% endif %}
            </div>
            <div class="right">
              {% if section.settings.stat_3 != blank %}
                <h3>{{ section.settings.stat_3 }}</h3>
              {% endif %}
              {% if section.settings.text_3 != blank %}
                <p>{{ section.settings.text_3 }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  (function () {
    function init() {
      const section = document.getElementById('why-orbe-{{ section.id }}');
      if (!section) return;

      const sticky = section.querySelector('.why-orbe-sticky');
      const overlay = section.querySelector('.blur-overlay');
      if (!sticky || !overlay) return;

      let ticking = false;

      function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max);
      }

      function updateWhyOrbe() {
        ticking = false;

        const rect = section.getBoundingClientRect();
        const distance = Math.max(1, section.offsetHeight - window.innerHeight);
        const progress = clamp(-rect.top / distance, 0, 1);

        overlay.style.transform = 'translate3d(0, ' + (-progress * 100) + '%, 0)';
      }

      function requestUpdate() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(updateWhyOrbe);
      }

      updateWhyOrbe();

      if (window.lenis && typeof window.lenis.on === 'function') {
        window.lenis.on('scroll', requestUpdate);
      }

      window.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', requestUpdate);
      window.addEventListener('load', requestUpdate, { once: true });
    }

    init();
  })();
</script>

{% schema %}
{
  "name": "Why Orbe",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "header",
      "content": "Stat 1"
    },
    {
      "type": "text",
      "id": "stat_1",
      "label": "Stat"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Stat 2"
    },
    {
      "type": "text",
      "id": "stat_2",
      "label": "Stat"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Stat 3"
    },
    {
      "type": "text",
      "id": "stat_3",
      "label": "Stat"
    },
    {
      "type": "textarea",
      "id": "text_3",
      "label": "Text"
    }
  ],
  "presets": [
    {
      "name": "Why Orbe"
    }
  ]
}
{% endschema %}
