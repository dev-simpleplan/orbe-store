<!-- MAIN SECTION -->
<div id="orbe-scroll-driver">
  <div id="orbe-stage">

    <!-- Phase 3: fullscreen video behind everything -->
    <video id="orbe-fullvideo" autoplay muted loop playsinline>
      <source src="{{ 'https://cdn.shopify.com/videos/c/o/v/51deb0e0d9964c4ba1505d2174f44e82.mp4'}}" type="video/mp4">
    </video>

    <!-- O shape wrapper — GSAP animates scale + y on this -->
    <div id="orbe-o-wrap">

      <!-- Real video clipped to O shape via CSS clip-path -->
      <video id="orbe-masked-video" autoplay muted loop playsinline>
        <source src="{{ 'https://cdn.shopify.com/videos/c/o/v/51deb0e0d9964c4ba1505d2174f44e82.mp4'}}" type="video/mp4">
      </video>

      <!-- SVG outline on top of video for crispness -->
      <svg id="orbe-o-outline" viewBox="0 0 520 527" xmlns="http://www.w3.org/2000/svg">
        <path fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"
