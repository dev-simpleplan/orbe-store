      </svg>

    </div>

    <!-- Hero copy -->
    <div id="orbe-copy">
      <h1>The Beauty That<br>Simplicity Creates</h1>
      <p>Guiding you toward choices that honour your strength,<br>your rhythm, your becoming.</p>
      <a href="#" class="orbe-btn">Start Your Journey</a>
    </div>

    <!-- Scroll hint -->
    <div id="orbe-hint">
      <span>Scroll</span>
      <div class="hint-line"></div>
    </div>

  </div>
</div>

<script>
(function () {
  function init() {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined' || typeof Lenis === 'undefined') {
      setTimeout(init, 100);
      return;
    }

    /* ── 1. Register plugin FIRST ── */
    gsap.registerPlugin(ScrollTrigger);

    /* ── 2. Lenis ── */
    const lenis = new Lenis({
      duration: 1.6,
      easing: t => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(time => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);

    /* ── 3. Refs ── */
    const oWrap     = document.getElementById('orbe-o-wrap');
    const fullVideo = document.getElementById('orbe-fullvideo');
    const copy      = document.getElementById('orbe-copy');
    const hint      = document.getElementById('orbe-hint');

    /* ── 4. Set initial state — half O visible at bottom, slightly scaled up ── */
    gsap.set(oWrap, {
      y: '55%',       /* pushed down — bottom half peeks up */
      scale: 1.5,
      transformOrigin: 'center center',
    });

    /* ── 5. Main scroll timeline ── */
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '#orbe-scroll-driver',
        start: 'top top',
        end: 'bottom bottom',
        scrub: 2,
      }
    });

    /* Phase 1 (0%→40%): O rises to center + zooms out to normal size */
    tl.to(oWrap, {
      y: '0%',
      scale: 1,
      ease: 'power2.inOut',
      duration: 0.40,
    }, 0);

    /* Phase 2 (30%→50%): hero copy fades in */
    tl.fromTo(copy,
      { opacity: 0, y: 16 },
      { opacity: 1, y: 0, ease: 'power2.out', duration: 0.18 },
      0.30
    );

    /* Phase 2b (52%→60%): hero copy fades out before expansion */
    tl.to(copy, {
      opacity: 0,
      y: -10,
      ease: 'power2.in',
      duration: 0.08,
    }, 0.52);

    /* Phase 3 (55%→100%): O expands with scroll — ease:none = 1:1 with scroll */
    tl.to(oWrap, {
      scale: 12,
      ease: 'none',
      duration: 0.45,
    }, 0.55);

    /* Phase 3b (72%→94%): fullscreen video fades in as O fills screen */
    tl.to(fullVideo, {
      opacity: 1,
      ease: 'power1.inOut',
      duration: 0.22,
    }, 0.72);

    /* Scroll hint disappears on first scroll */
    ScrollTrigger.create({
      trigger: '#orbe-scroll-driver',
      start: 'top+=50 top',
      onEnter:     () => gsap.to(hint, { opacity: 0, duration: 0.4 }),
      onLeaveBack: () => gsap.to(hint, { opacity: 1, duration: 0.4 }),
    });
  }

  init();
})();
</script>
