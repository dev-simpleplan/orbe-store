<script>
  (function () {
    function init() {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        setTimeout(init, 100);
        return;
      }

      gsap.registerPlugin(ScrollTrigger);

      const oWrap = document.getElementById('orbe-o-wrap');
      const copy = document.getElementById('orbe-copy');
      const hint = document.getElementById('orbe-hint');
      const fullSec = document.getElementById('orbe-fullvideo-section');
      const fullContent = document.getElementById('orbe-fullscreen-content');
      const header = document.querySelector('.header');

      gsap.set(oWrap, {
        y: '60%',
        scale: 1.5,
        transformOrigin: 'center center',
      });

      gsap.set(copy, {
        bottom: '6%',
        scale: 1,
        top: 'auto',
        opacity: 1,
      });

      gsap.set(fullSec, {
        clipPath: 'circle(0% at 50% 50%)',
      });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#orbe-scroll-driver',
          start: 'top top',
          end: 'bottom bottom',
          scrub: 2,
          onUpdate: (self) => {
            if (self.progress >= 0.55 && self.progress < 0.95) {
              header.classList.add('header--transparent');
            } else {
              header.classList.remove('header--transparent');
            }
          },
          onLeave: () => header.classList.remove('header--transparent'),
          onLeaveBack: () => header.classList.remove('header--transparent'),
        },
      });

      tl.to(oWrap, { y: '0%', scale: 0.6, ease: 'power2.inOut', duration: 0.4 }, 0);
      tl.to(copy, { scale: 0.8, bottom: '32%', ease: 'power2.inOut', duration: 0.4 }, 0);
      tl.to(copy, { opacity: 1, bottom: '32%', ease: 'power2.in', duration: 0.12 }, 0.4);
      tl.to(copy, { scale: 0.15, opacity: 0, ease: 'power2.in', duration: 0.3 }, 0.45);
      tl.to(oWrap, { scale: 12, ease: 'none', duration: 0.55 }, 0.45);

      gsap.set(fullSec, { clipPath: 'inset(65% 0%)' });

      tl.to(
        fullSec,
        {
          clipPath: 'inset(0% 0%)',
          ease: 'power1.inOut',
          duration: 0.28,
          onStart: () => { fullSec.style.pointerEvents = 'all'; },
        },
        0.35
      );

      tl.to(fullContent, { opacity: 1, ease: 'power2.out', duration: 0.16 }, 0.45);

    }
    init();
  })();
</script>