{% assign sp_count = section.blocks.size %}

<section class="sp-section" id="sp-{{ section.id }}">

  <!-- Background -->
  <div class="sp-bg">
    {% if section.settings.video != blank %}
      <video autoplay muted loop playsinline preload="auto" class="sp-bg-media">
        {% for source in section.settings.video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    {% elsif section.settings.background_image != blank %}
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="" class="sp-bg-media">
    {% endif %}
  </div>

  <!-- Stacked cards (GSAP drives visibility + movement) -->
  <div class="sp-cards-wrap">
    {% for block in section.blocks %}
      <div class="sp-card" {{ block.shopify_attributes }}>

        <div class="sp-card-top">
          <span class="sp-step">0{{ forloop.index }}</span>

          <!-- Hardcoded Orbé O icon -->
          <svg class="sp-orbe-icon" width="46" height="46" viewBox="0 0 46 46" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M23 5C13.06 5 5 13.06 5 23C5 32.94 13.06 41 23 41C32.94 41 41 32.94 41 23C41 17.84 38.7 13.22 35.1 10.1" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </div>

        <div class="sp-card-bot">
          {% if block.settings.title != blank %}
            <h3>{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.description != blank %}
            <p>{{ block.settings.description }}</p>
          {% endif %}
        </div>

      </div>
    {% endfor %}
  </div>

  <!-- Dots indicator -->
  {% if sp_count > 1 %}
    <div class="sp-dots" aria-hidden="true">
      {% for block in section.blocks %}
        <span class="sp-dot"></span>
      {% endfor %}
    </div>
  {% endif %}

</section>

<style>
  /* Section: full viewport, GSAP pins it */
  .sp-section {
    position: relative;
    overflow: hidden;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Background fills section */
  .sp-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .sp-bg-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(1);
  }

  /* Cards stack — centered, square-ish */
  .sp-cards-wrap {
    position: relative;
    z-index: 2;
    width: min(620px, 88vw);
    aspect-ratio: 1 / 1.08;
  }

  /* All cards stacked — GSAP controls visibility */
  .sp-card {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.08);
    -webkit-backdrop-filter: blur(32px);
    backdrop-filter: blur(32px);
    border-radius: 4px;
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    visibility: hidden;
    opacity: 0;
  }

  /* Top row: step number + icon */
  .sp-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .sp-step {
    font-size: clamp(28px, 3.5vw, 46px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.90);
    font-family: var(--aspekta);
    line-height: 1;
  }

  .sp-orbe-icon {
    display: block;
    flex-shrink: 0;
    opacity: 0.85;
  }

  /* Bottom text */
  .sp-card-bot {
    text-align: center;
    color: #fff;
  }

  .sp-card-bot h3 {
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 400;
    line-height: 1;
    margin: 0 0 14px;
    letter-spacing: -0.02em;
  }

  .sp-card-bot p {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.70);
    max-width: 38ch;
    margin: 0 auto;
  }

  /* Dots */
  .sp-dots {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .sp-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fff;
    opacity: 0.3;
    display: block;
  }

  @media (max-width: 767px) {
    .sp-section { height: auto; min-height: 100vh; }
    .sp-cards-wrap { width: 88vw; }
    .sp-card { padding: 24px 22px; }
  }
</style>

<script>
(function () {
  function init() {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
      setTimeout(init, 100);
      return;
    }

    gsap.registerPlugin(ScrollTrigger);

    const section = document.getElementById('sp-{{ section.id }}');
    if (!section) return;

    const cards = gsap.utils.toArray(section.querySelectorAll('.sp-card'));
    const dots  = gsap.utils.toArray(section.querySelectorAll('.sp-dot'));
    if (!cards.length) return;

    /* ── Same timing constants as what-we-choose ── */
    const cardOverlap    = 0.85;
    const cardEnterDur   = 0.70;
    const cardHoldDur    = 0.30;
    const cardExitDur    = 0.55;
    const cardTotalDur   = cardEnterDur + cardHoldDur + cardExitDur;
    const timelineLength = (cards.length - 1) * cardOverlap + cardTotalDur;

    const getPinDistance   = () => window.innerHeight * timelineLength * 1.12;
    const getEarlyDistance = () => window.innerHeight * 0.8;

    /* ── Pin section ── */
    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: () => `+=${getPinDistance()}`,
      pin: true,
      anticipatePin: 1.5,
      invalidateOnRefresh: true,
    });

    /* ── Initial state ── */
    gsap.set(cards, { autoAlpha: 0, y: 70 });
    gsap.set(dots,  { opacity: 0.3, scale: 1 });

    /* ── Scrubbed timeline ── */
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 80%',
        end: () => `+=${getPinDistance() + getEarlyDistance()}`,
        scrub: 1,
        invalidateOnRefresh: true,
      },
    });

    cards.forEach((card, index) => {
      const pos = index * cardOverlap;

      tl.set(card, { autoAlpha: 0, y: 70 }, pos);

      /* Enter: slide up from below */
      tl.to(card, {
        autoAlpha: 1,
        y: 0,
        ease: 'power2.out',
        duration: cardEnterDur,
      }, pos);

      /* Hold */
      tl.to(card, { y: 0, ease: 'none', duration: cardHoldDur }, pos + cardEnterDur);

      /* Exit: slide up and out */
      tl.to(card, {
        autoAlpha: 0,
        y: -60,
        ease: 'power2.in',
        duration: cardExitDur,
      }, pos + cardEnterDur + cardHoldDur);

      tl.set(card, { autoAlpha: 0 }, pos + cardTotalDur);

      /* Dot */
      if (dots[index]) {
        tl.to(dots[index], { opacity: 1, scale: 1.5, ease: 'none', duration: cardEnterDur }, pos);
        tl.to(dots[index], { opacity: 0.3, scale: 1, ease: 'none', duration: cardExitDur }, pos + cardEnterDur + cardHoldDur);
      }
    });

    window.addEventListener('load', () => ScrollTrigger.refresh());
  }

  init();
})();
</script>

{% schema %}
{
  "name": "Scientific Process",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background Video (overrides image)"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Research"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Our formulas are built on real research, proven nutrient forms, and careful testing. Everything we create is grounded in evidence and not assumptions or trends."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scientific Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Research",
            "description": "Our formulas are built on real research, proven nutrient forms, and careful testing. Everything we create is grounded in evidence and not assumptions or trends."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Formulation",
            "description": "Each ingredient is selected at a therapeutic dose and combined in a formula that works synergistically — never for show, always for function."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Testing",
            "description": "We test every batch for purity, potency, and stability before it reaches you. No compromises at this stage."
          }
        }
      ]
    }
  ]
}
{% endschema %}
