{% assign sp_count = section.blocks.size %}

<section class="sp-section" id="sp-{{ section.id }}">

  <!-- Background -->
  <div class="sp-bg">
    {% if section.settings.video != blank %}
      <video autoplay muted loop playsinline preload="auto" class="sp-bg-media">
        {% for source in section.settings.video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    {% elsif section.settings.background_image != blank %}
      <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="" class="sp-bg-media" loading="lazy">
    {% endif %}
  </div>
  <div class="sp-overlay"></div>

  <!-- Content -->
  <div class="sp-inner">

    <!-- Static heading -->
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <div class="sp-head">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p>{{ section.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <!-- Cards (stacked, GSAP drives visibility) -->
    <div class="sp-cards-wrap">
      {% for block in section.blocks %}
        <div class="sp-card" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="sp-card-top">
            <span class="sp-step">0{{ forloop.index }}</span>
            {% if section.settings.logo != blank %}
              {{ section.settings.logo | image_url: width: 120 | image_tag: loading: 'lazy', class: 'sp-logo' }}
            {% endif %}
          </div>
          <div class="sp-card-bot">
            {% if block.settings.title != blank %}
              <h3>{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p>{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>

  <!-- Dots -->
  {% if sp_count > 1 %}
    <div class="sp-dots" aria-hidden="true">
      {% for block in section.blocks %}
        <span class="sp-dot"></span>
      {% endfor %}
    </div>
  {% endif %}

</section>

<style>
  /* ── Section: full viewport, sticky handled by GSAP ── */
  .sp-section {
    position: relative;
    overflow: hidden;
    height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Background */
  .sp-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .sp-bg-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(1);
  }

  .sp-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.52);
    z-index: 1;
  }

  /* Inner flex column */
  .sp-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    padding: 70px 60px 100px;
    gap: 48px;
    box-sizing: border-box;
  }

  /* Static heading */
  .sp-head {
    text-align: center;
    color: #fff;
    flex-shrink: 0;
  }

  .sp-head h2 {
    font-size: clamp(34px, 4.5vw, 64px);
    font-weight: 400;
    line-height: 1;
    margin: 0 0 18px;
    letter-spacing: -0.03em;
  }

  .sp-head p {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.72);
    max-width: 52ch;
    margin: 0 auto;
  }

  /* Cards stack */
  .sp-cards-wrap {
    position: relative;
    width: 100%;
    max-width: 860px;
    flex: 1;
  }

  /* All cards absolutely stacked — GSAP controls opacity/transform */
  .sp-card {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.06);
    -webkit-backdrop-filter: blur(48px);
    backdrop-filter: blur(48px);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 6px;
    padding: 40px 44px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    visibility: hidden;
    opacity: 0;
  }

  .sp-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .sp-step {
    font-size: clamp(30px, 3.5vw, 50px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.88);
    font-family: var(--aspekta);
    line-height: 1;
  }

  .sp-logo {
    width: 58px;
    height: 58px;
    object-fit: contain;
    border-radius: 50%;
    display: block;
  }

  .sp-card-bot {
    text-align: center;
    color: #fff;
  }

  .sp-card-bot h3 {
    font-size: clamp(34px, 5vw, 62px);
    font-weight: 400;
    line-height: 1;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .sp-card-bot p {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.70);
    max-width: 42ch;
    margin: 0 auto;
  }

  /* Dots */
  .sp-dots {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .sp-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fff;
    opacity: 0.3;
    display: block;
  }

  /* Mobile: no pin, stacked cards scroll naturally */
  @media (max-width: 767px) {
    .sp-section { height: auto; min-height: 100vh; }
    .sp-inner { padding: 60px 20px 90px; gap: 36px; }
    .sp-cards-wrap { flex: none; height: 380px; }
    .sp-card { padding: 28px 22px; }
  }
</style>

<script>
(function () {
  function init() {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
      setTimeout(init, 100);
      return;
    }

    gsap.registerPlugin(ScrollTrigger);

    const section = document.getElementById('sp-{{ section.id }}');
    if (!section) return;

    const cards = gsap.utils.toArray(section.querySelectorAll('.sp-card'));
    const dots  = gsap.utils.toArray(section.querySelectorAll('.sp-dot'));
    if (!cards.length) return;

    /* ── Timing constants (mirrors what-we-choose pattern) ── */
    const cardOverlap    = 0.85;
    const cardEnterDur   = 0.70;
    const cardHoldDur    = 0.30;
    const cardExitDur    = 0.55;
    const cardTotalDur   = cardEnterDur + cardHoldDur + cardExitDur;
    const timelineLength = (cards.length - 1) * cardOverlap + cardTotalDur;

    const getPinDistance   = () => window.innerHeight * timelineLength * 1.12;
    const getEarlyDistance = () => window.innerHeight * 0.8;

    /* ── Pin the section ── */
    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: () => `+=${getPinDistance()}`,
      pin: true,
      anticipatePin: 1.5,
      invalidateOnRefresh: true,
    });

    /* ── Initial state: all cards hidden below ── */
    gsap.set(cards, { autoAlpha: 0, y: 72 });
    gsap.set(dots,  { opacity: 0.3, scale: 1 });

    /* ── Scrubbed timeline drives card + dot animations ── */
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 80%',
        end: () => `+=${getPinDistance() + getEarlyDistance()}`,
        scrub: 1,
        invalidateOnRefresh: true,
      },
    });

    cards.forEach((card, index) => {
      const pos = index * cardOverlap;

      /* Ensure card is hidden before its turn */
      tl.set(card, { autoAlpha: 0, y: 72 }, pos);

      /* Enter — slide up from below */
      tl.to(card, {
        autoAlpha: 1,
        y: 0,
        ease: 'power2.out',
        duration: cardEnterDur,
      }, pos);

      /* Hold at center */
      tl.to(card, {
        y: 0,
        ease: 'none',
        duration: cardHoldDur,
      }, pos + cardEnterDur);

      /* Exit — slide up and out */
      tl.to(card, {
        autoAlpha: 0,
        y: -60,
        ease: 'power2.in',
        duration: cardExitDur,
      }, pos + cardEnterDur + cardHoldDur);

      tl.set(card, { autoAlpha: 0 }, pos + cardTotalDur);

      /* Dot: brighten on enter, dim on exit */
      if (dots[index]) {
        tl.to(dots[index], {
          opacity: 1,
          scale: 1.5,
          ease: 'none',
          duration: cardEnterDur,
        }, pos);

        tl.to(dots[index], {
          opacity: 0.3,
          scale: 1,
          ease: 'none',
          duration: cardExitDur,
        }, pos + cardEnterDur + cardHoldDur);
      }
    });

    window.addEventListener('load', () => ScrollTrigger.refresh());
  }

  init();
})();
</script>

{% schema %}
{
  "name": "Scientific Process",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Scientific Process"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "At Orbé, simplicity is an act of respect. Respect for your time, your mind, and your body. We refine everything: our formulas, our design, even the way we communicate."
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Card Icon / Logo (top-right of card)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background Video (overrides image)"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Research"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Our formulas are built on real research, proven nutrient forms, and careful testing. Everything we create is grounded in evidence and not assumptions or trends."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scientific Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Research",
            "description": "Our formulas are built on real research, proven nutrient forms, and careful testing. Everything we create is grounded in evidence and not assumptions or trends."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Formulation",
            "description": "Each ingredient is selected at a therapeutic dose and combined in a formula that works synergistically — never for show, always for function."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Testing",
            "description": "We test every batch for purity, potency, and stability before it reaches you. No compromises at this stage."
          }
        }
      ]
    }
  ]
}
{% endschema %}
