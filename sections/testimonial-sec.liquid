<section class="testimonial-sec">
    <div class="container-spcl">
 <div class="heading">
            <h2>{{ section.settings.heading }}</h2>
        </div>
        <div class="testimonial-sec-in">
            <div class="owl-carousel testimonial-owl">
                {% for block in section.blocks %}
                    {% if block.type == 'text_block' %}
                        <div class="ts-card ts-card--text" {{ block.shopify_attributes }}>
                            {% if block.settings.author_image != blank %}
                                <div class="ts-img">
                                    <img
                                        src="{{ block.settings.author_image | image_url: width: 500 }}"
                                        alt="{{ block.settings.author_name | escape }}"
                                        width="244" height="244" loading="lazy">
                                </div>
                            {% endif %}
                            <div class="ts-meta">
                                <span class="ts-author">{{ block.settings.author_name }}</span>
                                <span class="ts-stars">
                                    {% for i in (1..5) %}
                                        {% if i <= block.settings.rating %}
                                            <svg width="12" height="12" viewBox="0 0 12 12" fill="#151515"><path d="M6 0l1.5 4h4l-3.3 2.4 1.3 4L6 8 2.5 10.4l1.3-4L.5 4h4z"/></svg>
                                        {% else %}
                                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="#151515" stroke-width="0.8"><path d="M6 0l1.5 4h4l-3.3 2.4 1.3 4L6 8 2.5 10.4l1.3-4L.5 4h4z"/></svg>
                                    {% endif %}
                                {% endfor %}
                            </span>
                            </div>
                            {% if block.settings.review != blank %}
                                <p class="ts-review">{{ block.settings.review }}</p>
                            {% endif %}
                        </div>

                    {% elsif block.type == 'video' %}
                        <div class="ts-card ts-card--video" {{ block.shopify_attributes }}>
                            {% if block.settings.video != blank %}
                                {{
                                    block.settings.video
                                    | video_tag:
                                        autoplay: true,
                                        loop: true,
                                        muted: true,
                                        playsinline: true,
                                        image_size: '800x'
                                }}
                            {% elsif block.settings.poster != blank %}
                                <img
                                    src="{{ block.settings.poster | image_url: width: 800 }}"
                                    alt="" width="288" height="512" loading="lazy">
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>

            <div class="ts-nav">
                <button class="ts-prev" aria-label="Previous">
                    <svg width="43" height="43" viewBox="0 0 43 43" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="21.3472" cy="21.3472" r="21.3472" transform="matrix(-1 0 0 1 42.6943 0)" fill="currentColor" />
                        <path d="M30.0313 20.8421L17.665 20.8421L22.9648 15.5423L22.2985 14.7852L15.7368 21.3469L22.2985 27.9086L22.9648 27.1515L17.665 21.8516L30.0313 21.8516L30.0313 20.8421Z" fill="white" />
                    </svg>
                </button>
                <button class="ts-next" aria-label="Next">
                    <svg width="43" height="43" viewBox="0 0 43 43" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="21.3472" cy="21.3472" r="21.3472" fill="currentColor" />
                        <path d="M12.663 20.8421L25.0294 20.8421L19.7295 15.5423L20.3958 14.7852L26.9575 21.3469L20.3958 27.9086L19.7295 27.1515L25.0294 21.8516L12.663 21.8516L12.663 20.8421Z" fill="white" />
                    </svg>
                </button>
            </div>
        </div>
    </div> 
</section>

<style>
    .testimonial-sec {
        overflow: hidden;
        background: #fff;
    }

    .testimonial-sec .heading {
        margin-bottom: 110px;
        text-align: center;
    }
    .testimonial-sec .heading h2{
      text-transform: capitalize;
    }
    .testimonial-sec-in {
        position: relative;
    }

    .testimonial-owl .owl-stage {
        display: flex;
        align-items: flex-end;
    }

    .testimonial-owl .owl-item {
        width: auto !important;
    }

    .ts-card {
        box-sizing: border-box;
    }

    .ts-card--text {
        width: 380px;
        max-width: 380px;
        min-height: 512px;
        padding: 0;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        align-items: stretch;
        background: transparent;
        border: 0;
    }

    .ts-card--video {
        width: 320px;
        max-width: 320px;
        height: 512px;
        min-height: 512px;
        overflow: hidden;
        background: #f2f2f2;
    }

    .ts-card--video img,
    .ts-card--video video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .ts-img {
        width: 244px;
        height: 244px;
        border-radius: 50%;
        overflow: hidden;
        flex: 0 0 244px;
        margin: 0 auto 8px;
        background: #111;
    }

    .ts-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .ts-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        min-height: 80px;
        padding: 0 20px;
        background: #f6f6f6;
    }

    .ts-author {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        font-family: var(--aspekta);
        color: #1A1A1A;
        letter-spacing: 2.88px;
        line-height: 150%;
    }

    .ts-stars {
        display: flex;
        gap: 4px;
        align-items: center;
        flex: 0 0 auto;
    }

    .ts-stars svg {
        width: 14px;
        height: 14px;
    }

    .ts-review {
        min-height: 160px;
        margin: 0;
        padding: 0 20px 18px;
        background: #f6f6f6;
        color: #5D5D5D;
        font-family: var(--aspekta);
        font-size: 14px;
        font-weight: 400;
        line-height: 132%;
        letter-spacing: 0;
    }

    /* custom nav */
    .ts-nav {
        display: flex;
        justify-content: center;
        gap: 5px;
        margin-top: 32px;
    }

    .ts-prev,
    .ts-next {
        width: 43px;
        height: 43px;
        border-radius: 50%;
        border: 0;
        background: transparent;
        color: #151515;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .ts-prev:hover,
    .ts-next:hover {
        color: #151515;
    }

    .ts-prev.disabled,
    .ts-next.disabled {
        cursor: default;
        opacity: 0.45;
        pointer-events: none;
    }

    .ts-prev svg,
    .ts-next svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    /* hide owl default nav/dots */
    .testimonial-owl .owl-nav,
    .testimonial-owl .owl-dots {
        display: none;
    }

    @media (max-width: 1439px) {
        .testimonial-sec .container {
            padding-left: 20px;
            padding-right: 20px;
        }

        .testimonial-sec .heading {
            margin-bottom: 80px;
        }
    }

    @media (max-width: 991px) {
     

        .testimonial-sec .heading {
            margin-bottom: 48px;
        }

        .testimonial-owl .owl-stage {
            align-items: stretch;
        }

        .ts-card--text {
            width: 320px;
            max-width: 320px;
            min-height: 460px;
        }

        .ts-card--video {
            width: 260px;
            max-width: 260px;
            height: 460px;
            min-height: 460px;
        }

        .ts-img {
            width: 200px;
            height: 200px;
            flex-basis: 200px;
        }
    }

    @media (max-width: 767px) {
        .testimonial-sec .container {
            padding-left: 16px;
            padding-right: 16px;
        }

        .testimonial-sec-in {
            margin-left: calc(50% - 50vw);
            margin-right: calc(50% - 50vw);
        }

        .testimonial-owl,
        .testimonial-owl .owl-stage-outer {
            overflow: visible;
        }

        .testimonial-owl .owl-stage {
            align-items: flex-end;
        }

        .ts-card--text,
        .ts-card--video {
            width: 80vw;
            max-width: none;
            min-height: 430px;
        }

        .ts-card--video {
            height: 430px;
        }

        .ts-img {
            width: min(48vw, 200px);
            height: min(48vw, 200px);
            flex-basis: min(48vw, 200px);
        }

        .ts-review {
            font-size: 13px;
            min-height: 150px;
        }

        .ts-nav {
            display: flex;
            margin-top: 34px;
        }

        .ts-prev,
        .ts-next {
            width: 40px;
            height: 40px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof jQuery === 'undefined') return;

        var $owl = jQuery('.testimonial-owl');

        function mobileStagePadding() {
            return Math.round(window.innerWidth * 0.2);
        }

        function updateTestimonialNav(event) {
            var $prev = jQuery('.ts-prev');
            var $next = jQuery('.ts-next');

            if (window.innerWidth < 768) {
                $prev.add($next).removeClass('disabled');
                return;
            }

            var carousel = event.relatedTarget;
            var current = carousel.current();
            var minimum = carousel.minimum();
            var maximum = carousel.maximum();

            $prev.toggleClass('disabled', current <= minimum);
            $next.toggleClass('disabled', current >= maximum);
        }

        $owl.on('initialized.owl.carousel changed.owl.carousel resized.owl.carousel', updateTestimonialNav);

        $owl.owlCarousel({
            loop: false,
            margin: 12,
            nav: false,
            dots: false,
            autoWidth: true,
            center: true,
            responsive: {
                0: { items: 1, autoWidth: true, center: true, loop: true, margin: 12, stagePadding: mobileStagePadding() },
                768: { autoWidth: true, center: false, loop: false, margin: 12, stagePadding: 0 },
                1024: { autoWidth: true, center: false, loop: false, margin: 12, stagePadding: 0 }
            }
        });

        jQuery('.ts-prev').on('click', function () {
            if (!jQuery(this).hasClass('disabled')) {
                $owl.trigger('prev.owl.carousel');
            }
        });

        jQuery('.ts-next').on('click', function () {
            if (!jQuery(this).hasClass('disabled')) {
                $owl.trigger('next.owl.carousel');
            }
        });
    });
</script>

{% schema %}
{
    "name": "Testimonial Slider",
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Seeing through the noise"
        }
    ],
    "blocks": [
        {
            "type": "text_block",
            "name": "Text testimonial",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "author_image",
                    "label": "Author image"
                },
                {
                    "type": "text",
                    "id": "author_name",
                    "label": "Author name",
                    "default": "Ananya Mehra"
                },
                {
                    "type": "range",
                    "id": "rating",
                    "label": "Star rating",
                    "min": 1,
                    "max": 5,
                    "step": 1,
                    "default": 5
                },
                {
                    "type": "textarea",
                    "id": "review",
                    "label": "Review",
                    "default": "I've tried many wellness supplements before, but this one genuinely felt different."
                }
            ]
        },
        {
            "type": "video",
            "name": "Video",
            "settings": [
                {
                    "type": "video",
                    "id": "video",
                    "label": "Video"
                },
                {
                    "type": "image_picker",
                    "id": "poster",
                    "label": "Fallback image (if no video)"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Testimonial Slider",
            "blocks": [
                {
                    "type": "text_block",
                    "settings": {
                        "author_name": "Ananya Mehra",
                        "rating": 5,
                        "review": "I've tried many wellness supplements before, but this one genuinely felt different. Within a few weeks, I noticed better energy levels, improved focus, and a much calmer routine overall."
                    }
