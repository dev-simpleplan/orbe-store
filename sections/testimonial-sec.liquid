<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css">

<section class="testimonial-sec">
        <div class="container heading">
            <h2>{{ section.settings.heading }}</h2>
        </div>
        <div class="testimonial-sec-in">
            <div class="owl-carousel testimonial-owl">
                {% for block in section.blocks limit: 4 %}
                    {% if block.type == 'text_block' %}
                        <div class="ts-card ts-card--text" {{ block.shopify_attributes }}>
                            {% if block.settings.author_image != blank %}
                                <div class="ts-img">
                                    <img
                                        src="{{ block.settings.author_image | image_url: width: 500 }}"
                                        alt="{{ block.settings.author_name | escape }}"
                                        width="244" height="244" loading="lazy">
                                </div>
                            {% endif %}
                            <div class="ts-meta">
                                <span class="ts-author">{{ block.settings.author_name }}</span>
                                <span class="ts-stars">
                                    {% for i in (1..5) %}
                                        {% if i <= block.settings.rating %}
                                            <svg width="12" height="12" viewBox="0 0 12 12" fill="#151515"><path d="M6 0l1.5 4h4l-3.3 2.4 1.3 4L6 8 2.5 10.4l1.3-4L.5 4h4z"/></svg>
                                        {% else %}
                                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="#151515" stroke-width="0.8"><path d="M6 0l1.5 4h4l-3.3 2.4 1.3 4L6 8 2.5 10.4l1.3-4L.5 4h4z"/></svg>
                                    {% endif %}
                                {% endfor %}
                            </span>
                            </div>
                            {% if block.settings.review != blank %}
                                <p class="ts-review">{{ block.settings.review }}</p>
                            {% endif %}
                        </div>

                    {% elsif block.type == 'video' %}
                        <div class="ts-card ts-card--video" {{ block.shopify_attributes }}>
                            {% if block.settings.video != blank %}
                                {{
                                    block.settings.video
                                    | video_tag:
                                        autoplay: true,
                                        loop: true,
                                        muted: true,
                                        playsinline: true,
                                        image_size: '800x'
                                }}
                            {% elsif block.settings.poster != blank %}
                                <img
                                    src="{{ block.settings.poster | image_url: width: 800 }}"
                                    alt="" width="288" height="512" loading="lazy">
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>

            <div class="ts-nav">
                <button class="ts-prev" aria-label="Previous">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
                <button class="ts-next" aria-label="Next">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
        </div>
</section>

<style>
    .testimonial-sec {
        overflow: hidden;
        background: #fff;
    }

    .testimonial-sec .container {
        max-width: 1440px;
        padding-left: 4px;
        padding-right: 4px;
    }

    .testimonial-sec .heading {
        margin-bottom: 110px;
        text-align: center;
    }

    .testimonial-sec .heading h2 {
        margin: 0;
        color: #151515;
        font-family: var(--tobias);
        font-size: 58px;
        font-weight: 400;
        line-height: 0.95;
        letter-spacing: 0;
        text-transform: capitalize;
    }

    .testimonial-sec-in {
        position: relative;
    }

    .testimonial-owl .owl-stage {
        display: flex;
        align-items: flex-end;
    }

    .testimonial-owl .owl-item {
        width: auto !important;
    }

    .ts-card {
        box-sizing: border-box;
    }

    .ts-card--text {
        width: 364px;
        max-width: 364px;
        min-height: 512px;
        padding: 0;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        align-items: stretch;
        background: transparent;
        border: 0;
    }

    .ts-card--video {
        width: 288px;
        max-width: 288px;
        height: 512px;
        min-height: 512px;
        overflow: hidden;
        background: #f2f2f2;
    }

    .ts-card--video img,
    .ts-card--video video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .ts-img {
        width: 244px;
        height: 244px;
        border-radius: 50%;
        overflow: hidden;
        flex: 0 0 244px;
        margin: 0 auto 8px;
        background: #111;
    }

    .ts-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .ts-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        min-height: 60px;
        padding: 0 20px;
        background: #f6f6f6;
    }

    .ts-author {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #151515;
    }

    .ts-stars {
        display: flex;
        gap: 4px;
        align-items: center;
        flex: 0 0 auto;
    }

    .ts-stars svg {
        width: 13px;
        height: 13px;
    }

    .ts-review {
        min-height: 160px;
        margin: 0;
        padding: 0 20px 18px;
        background: #f6f6f6;
        color: #333;
        font-family: var(--aspekta);
        font-size: 14px;
        font-weight: 400;
        line-height: 1.28;
        letter-spacing: 0;
    }

    /* custom nav */
    .ts-nav {
        display: none;
        gap: 12px;
        margin-top: 32px;
    }

    .ts-prev,
    .ts-next {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px solid #151515;
        background: transparent;
        color: #151515;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .ts-prev:hover,
    .ts-next:hover {
        background: #151515;
        color: #fff;
    }

    /* hide owl default nav/dots */
    .testimonial-owl .owl-nav,
    .testimonial-owl .owl-dots {
        display: none;
    }

    @media (max-width: 1439px) {
        .testimonial-sec .container {
            padding-left: 20px;
            padding-right: 20px;
        }

        .testimonial-sec .heading {
            margin-bottom: 80px;
        }
    }

    @media (max-width: 991px) {
        .testimonial-sec .heading h2 {
            font-size: 46px;
        }

        .testimonial-sec .heading {
            margin-bottom: 48px;
        }

        .testimonial-owl .owl-stage {
            align-items: stretch;
        }

        .ts-card--text {
            width: 320px;
            max-width: 320px;
            min-height: 460px;
        }

        .ts-card--video {
            width: 260px;
            max-width: 260px;
            height: 460px;
            min-height: 460px;
        }

        .ts-img {
            width: 200px;
            height: 200px;
            flex-basis: 200px;
        }
    }

    @media (max-width: 767px) {
        .testimonial-sec .container {
            padding-left: 16px;
            padding-right: 16px;
        }

        .testimonial-sec .heading h2 {
            font-size: 38px;
        }

        .ts-card--text,
        .ts-card--video {
            width: calc(100vw - 64px);
            max-width: 320px;
            min-height: 430px;
        }

        .ts-card--video {
            height: 430px;
        }

        .ts-review {
            font-size: 13px;
            min-height: 150px;
        }
    }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js" defer></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof jQuery === 'undefined') return;

        var $owl = jQuery('.testimonial-owl');

        $owl.owlCarousel({
            loop: false,
            margin: 12,
            nav: false,
            dots: false,
            autoWidth: true,
            responsive: {
                0: { items: 1, autoWidth: true, margin: 12 },
                768: { autoWidth: true, margin: 12 },
                1024: { autoWidth: true, margin: 12 }
            }
        });

        jQuery('.ts-prev').on('click', function () {
            $owl.trigger('prev.owl.carousel');
        });

        jQuery('.ts-next').on('click', function () {
            $owl.trigger('next.owl.carousel');
        });
    });
</script>

{% schema %}
{
    "name": "Testimonial Slider",
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Seeing through the noise"
        }
    ],
    "blocks": [
        {
            "type": "text_block",
            "name": "Text testimonial",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "author_image",
                    "label": "Author image"
                },
                {
                    "type": "text",
                    "id": "author_name",
                    "label": "Author name",
                    "default": "Ananya Mehra"
                },
                {
                    "type": "range",
                    "id": "rating",
                    "label": "Star rating",
                    "min": 1,
                    "max": 5,
                    "step": 1,
                    "default": 5
                },
                {
                    "type": "textarea",
                    "id": "review",
                    "label": "Review",
                    "default": "I've tried many wellness supplements before, but this one genuinely felt different."
                }
            ]
        },
        {
            "type": "video",
            "name": "Video",
            "settings": [
                {
                    "type": "video",
                    "id": "video",
                    "label": "Video"
                },
                {
                    "type": "image_picker",
                    "id": "poster",
                    "label": "Fallback image (if no video)"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Testimonial Slider",
            "blocks": [
                {
                    "type": "text_block",
                    "settings": {
                        "author_name": "Ananya Mehra",
                        "rating": 5,
                        "review": "I've tried many wellness supplements before, but this one genuinely felt different. Within a few weeks, I noticed better energy levels, improved focus, and a much calmer routine overall."
                    }
                },
                { "type": "video", "settings": {} },
                {
                    "type": "text_block",
                    "settings": {
                        "author_name": "Priya Sharma",
                        "rating": 5,
                        "review": "What I love most is how clean and premium the experience feels — from the packaging to the results. It has honestly become a part of my daily self-care ritual."
                    }
                },
                { "type": "video", "settings": {} },
                {
                    "type": "text_block",
                    "settings": {
                        "author_name": "Sara Williams",
                        "rating": 4,
                        "review": "A genuinely thoughtful product. I appreciate the transparency in ingredients and the noticeable difference it makes to my day."
                    }
                }
            ]
        }
    ]
}
{% endschema %}
