<section class="progress-for-us">
    <div class="container">
        <div class="progress-for-us-in">
            <div class="left">
                <div class="progress-for-us-img">
                    {% if section.settings.main_image != blank %}
                        <img src="{{ section.settings.main_image | image_url: width: 1000 }}" alt="{{ section.settings.heading | escape }}" class="img" loading="lazy" width="1000" height="800">
                    {% endif %}
                </div>
            </div>
            <div class="right">
                <div class="progress-for-us-img-sm">
                    {% if section.settings.secondary_image != blank %}
                        <img src="{{ section.settings.secondary_image | image_url: width: 600 }}" alt="" class="img" loading="lazy" width="600" height="400">
                    {% endif %}
                </div>
                <div class="progress-for-us-content text-animation">
                    {% if section.settings.heading != blank %}
                        <h2>{{ section.settings.heading }}</h2>
                    {% endif %}
                    <div class="progress-for-us-pointers">
                        {% for block in section.blocks %}
                            <p {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Progress For Us",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main image (left)"
    },
    {
      "type": "image_picker",
      "id": "secondary_image",
      "label": "Secondary image (right top)"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Progress, for us, means refining what already works, with care, patience, and clarity."
    }
  ],
  "blocks": [
    {
      "type": "pointer",
      "name": "Pointer",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Add your point here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Progress For Us",
      "blocks": [
        {
          "type": "pointer",
          "settings": {
            "text": "We monitor new clinical research to understand how nutrients work, interact, and absorb over time."
          }
        },
        {
          "type": "pointer",
          "settings": {
            "text": "Feedback from experts and the Orbe community helps guide future improvements and innovations."
          }
        },
        {
          "type": "pointer",
          "settings": {
            "text": "We review formulations regularly to ensure they remain relevant, effective, and safe."
          }
        },
        {
          "type": "pointer",
          "settings": {
            "text": "New products are developed slowly and intentionally — only when there is clear evidence and a genuine need."
          }
        }
      ]
    }
  ]
}
{% endschema %}
