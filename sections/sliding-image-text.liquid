{% comment %} Sliding Image Text Section {% endcomment %}

<style>
  #sit-section-{{ section.id }} {
    height: 320vh;
    position: relative;
  }

  #sit-section-{{ section.id }} .sliding-image-text-in {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: #fff;
  }

  #sit-section-{{ section.id }} .sit-fold {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 19px;
    pointer-events: none;
  }

  #sit-section-{{ section.id }} .sit-side {
    position: relative;
    overflow: hidden;
    height: 100%;
  }

  #sit-section-{{ section.id }} .sit-media,
  #sit-section-{{ section.id }} .sit-copy {
    position: absolute;
    inset: 0;
  }

  #sit-section-{{ section.id }} .sit-media {
    will-change: transform;
  }

  #sit-section-{{ section.id }} .sit-media img,
  #sit-section-{{ section.id }} .sit-mobile-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #sit-section-{{ section.id }} .sit-copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 60px;
    opacity: 0;
    will-change: opacity, transform;
  }

  #sit-section-{{ section.id }} .sit-fold.is-active .sit-copy {
    opacity: 1;
  }

  #sit-section-{{ section.id }} .sit-copy p {
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    line-height: 1.75;
    color: #1a1a1a;
    max-width: 280px;
  }

  #sit-section-{{ section.id }} .sit-copy h2 {
    font-size: clamp(1.2rem, 2vw, 1.8rem);
    font-weight: 400;
    color: #1a1a1a;
    margin: 0 0 8px;
  }

  #sit-section-{{ section.id }} .sit-copy .block-2 {
    align-self: flex-end;
  }

  #sit-section-{{ section.id }} .sit-mobile-fold {
    display: none;
  }

  @media (max-width: 991px) {
    #sit-section-{{ section.id }} {
      height: auto;
    }

    #sit-section-{{ section.id }} .sliding-image-text-in {
      display: none;
    }

    #sit-section-{{ section.id }} .sit-mobile-fold {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 19px;
      min-height: 100vw;
    }

    #sit-section-{{ section.id }} .sit-mobile-image {
      position: relative;
      overflow: hidden;
    }

    #sit-section-{{ section.id }} .sit-mobile-copy {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 40px 30px;
    }

    #sit-section-{{ section.id }} .sit-mobile-copy p {
      font-size: clamp(0.85rem, 1.1vw, 1rem);
      line-height: 1.75;
      color: #1a1a1a;
    }

    #sit-section-{{ section.id }} .sit-mobile-copy h2 {
      font-size: clamp(1.2rem, 2vw, 1.8rem);
      font-weight: 400;
      color: #1a1a1a;
      margin: 0 0 8px;
    }
  }

  @media (max-width: 767px) {
    #sit-section-{{ section.id }} .sit-mobile-fold {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    #sit-section-{{ section.id }} .sit-mobile-image {
      height: 80vw;
    }

    #sit-section-{{ section.id }} .sit-mobile-copy {
      min-height: 70vw;
      padding: 30px 20px;
    }
  }
</style>

<section class="sliding-image-text" id="sit-section-{{ section.id }}">
  <div class="sliding-image-text-in">
    {% for block in section.blocks limit: 3 %}
      {% assign fold_index = forloop.index0 %}
      {% assign is_even = fold_index | modulo: 2 %}

      <div class="sit-fold{% if forloop.first %} is-active{% endif %}" data-sit-fold="{{ forloop.index }}" {{ block.shopify_attributes }}>
        <div class="sit-side">
          {% if is_even == 0 %}
            <div class="sit-media sit-image" data-sit-image>
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.image.alt }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
          {% else %}
            <div class="sit-copy" data-sit-copy>
              {% if block.settings.heading != blank %}
                <h2>{{ block.settings.heading }}</h2>
              {% endif %}
              <p>{{ block.settings.text_top }}</p>
              {% if block.settings.text_bottom != blank %}
                <p class="block-2">{{ block.settings.text_bottom }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>

        <div class="sit-side">
          {% if is_even == 0 %}
            <div class="sit-copy" data-sit-copy>
              {% if block.settings.heading != blank %}
                <h2>{{ block.settings.heading }}</h2>
              {% endif %}
              <p>{{ block.settings.text_top }}</p>
              {% if block.settings.text_bottom != blank %}
                <p class="block-2">{{ block.settings.text_bottom }}</p>
              {% endif %}
            </div>
          {% else %}
            <div class="sit-media sit-image" data-sit-image>
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.image.alt }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {% for block in section.blocks limit: 3 %}
    {% assign fold_index = forloop.index0 %}
    {% assign is_even = fold_index | modulo: 2 %}

    <div class="sit-mobile-fold">
      {% if is_even == 0 %}
        <div class="sit-mobile-image">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: block.settings.image.alt }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      {% endif %}

      <div class="sit-mobile-copy">
        {% if block.settings.heading != blank %}
          <h2>{{ block.settings.heading }}</h2>
        {% endif %}
        <p>{{ block.settings.text_top }}</p>
        {% if block.settings.text_bottom != blank %}
          <p class="block-2">{{ block.settings.text_bottom }}</p>
        {% endif %}
      </div>

      {% if is_even != 0 %}
        <div class="sit-mobile-image">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: block.settings.image.alt }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      {% endif %}
    </div>
  {% endfor %}
</section>

<script>
  (function () {
    function init() {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        setTimeout(init, 100);
        return;
      }

      gsap.registerPlugin(ScrollTrigger);

      const section = document.getElementById('sit-section-{{ section.id }}');
      const folds = gsap.utils.toArray('#sit-section-{{ section.id }} .sit-fold');

      if (!section || folds.length < 2) return;

      const mm = gsap.matchMedia();

      mm.add('(min-width: 992px)', () => {
        folds.forEach((fold, index) => {
          const image = fold.querySelector('[data-sit-image]');
          const copy = fold.querySelector('[data-sit-copy]');

          gsap.set(fold, { zIndex: folds.length - index });
          gsap.set(copy, {
            autoAlpha: index === 0 ? 1 : 0,
            yPercent: index === 0 ? 0 : 10,
          });

          if (index === 0) {
            gsap.set(image, { yPercent: 0 });
          } else {
            gsap.set(image, { yPercent: 100 });
          }
        });

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: section,
            start: 'top top',
            end: 'bottom bottom',
            scrub: 1.2,
            invalidateOnRefresh: true,
          },
        });

        function transitionFold(fromIndex, toIndex, at) {
          const fromFold = folds[fromIndex];
          const toFold = folds[toIndex];
          const fromImage = fromFold.querySelector('[data-sit-image]');
          const fromCopy = fromFold.querySelector('[data-sit-copy]');
          const toImage = toFold.querySelector('[data-sit-image]');
          const toCopy = toFold.querySelector('[data-sit-copy]');

          tl.set(toFold, { zIndex: folds.length + toIndex }, at);
          tl.fromTo(toImage, { yPercent: 100 }, { yPercent: 0, ease: 'none', duration: 1 }, at);
          tl.to(fromImage, { yPercent: 100, ease: 'none', duration: 1 }, at);
          tl.to(fromCopy, { autoAlpha: 0, yPercent: -8, ease: 'power1.out', duration: 0.28 }, at);
          tl.fromTo(toCopy, { autoAlpha: 0, yPercent: 10 }, { autoAlpha: 1, yPercent: 0, ease: 'power1.out', duration: 0.35 }, at + 0.42);
          tl.to(toCopy, { autoAlpha: 1, duration: 0.22 }, at + 1);
        }

        transitionFold(0, 1, 0);
        transitionFold(1, 2, 1.3);

        return () => {
          ScrollTrigger.getAll().forEach((trigger) => {
            if (trigger.trigger === section) trigger.kill();
          });
        };
      });
    }

    init();
  })();
</script>

{% schema %}
{
  "name": "Sliding Image Text",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "fold",
      "name": "Fold",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text_top",
          "label": "Text (top)",
          "default": "Guiding you toward choices that honour your strength, respect your natural rhythm, and support the person you are continually becoming."
        },
        {
          "type": "textarea",
          "id": "text_bottom",
          "label": "Text (bottom)",
          "info": "Optional - appears bottom-right aligned"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sliding Image Text",
      "blocks": [
        { "type": "fold" },
        { "type": "fold" },
        { "type": "fold" }
      ]
    }
  ]
}
{% endschema %}
