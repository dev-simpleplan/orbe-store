<section class="method-banner">
    <div class="container">
        <div class="method-banner-in" {% if section.settings.bg_image != blank %} style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');"{% endif %}>
            {% if section.settings.heading != blank %}
                <h2>{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.text != blank %}
                <p>{{ section.settings.text }}</p>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Method Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built on Principles, Not Trends"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "ORBÉ products are guided by clear scientific and human-centered principles. These foundations shape every formulation today — and every product we create tomorrow."
    }
  ],
  "presets": [
    {
      "name": "Method Banner"
    }
  ]
}
{% endschema %}
