<section class="science-contact-sec">
    <div class="container">
        <div class="science-contact-sec-in">

            <div class="scs-left">
                <div class="scs-heading text-animation">
                    {% if section.settings.heading != blank %}
                    <h2>{{ section.settings.heading }}</h2>
                    {% endif %}
                    {% if section.settings.subtext != blank %}
                    <p>{{ section.settings.subtext }}</p>
                    {% endif %}
                </div>

                <div class="scs-qod text-animation">
                    {% if section.settings.qod_label != blank %}
                    <p class="scs-qod-label">{{ section.settings.qod_label }}</p>
                    {% endif %}
                    <div class="scs-qod-body">
                        <div class="scs-qod-text">
                            {% if section.settings.qod_question != blank %}
                            <h3 class="scs-qod-question">{{ section.settings.qod_question }}</h3>
                            {% endif %}
                               {% if section.settings.qod_desc != blank %}
                            <p class="scs-qod-desc">{{ section.settings.qod_desc }}</p>
                            {% endif %}
                        </div>
                    </div>
                    <div class="bottom-scs-qod">
                        <div class="scs-qod-author">
                        {% if section.settings.author_name != blank %}
                        <p class="scs-author-name">{{ section.settings.author_name }}</p>
                        {% endif %}
                        {% if section.settings.author_role != blank %}
                        <p class="scs-author-role">{{ section.settings.author_role }}</p>
                        {% endif %}
                    </div>
                    <div class="dark-o-logo">

                <svg version="1.2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 93 97" width="92" height="97"><style>.a{opacity:.01}.b{opacity:.1;fill:#fff}</style><path fill-rule="evenodd" class="a" d="m68.4 6.2c22.6 11.8 31.3 39.6 19.6 62.1l-1.1 2.2c-11.8 22.5-39.6 31.3-62.1 19.5-22.5-11.7-31.3-39.5-19.6-62l1.2-2.2c11.7-22.5 39.5-31.3 62-19.6z"/><path class="b" d="m87.8 68.6c0 0-11.6-6-14.4-7.4 3.7-6.1 6.6-12.1 7.7-18.2 0.1-0.1 0.1-0.2 0.1-0.4 2-11.3-0.6-21.8-7.8-28q-0.2-0.2-0.5-0.4-0.3-0.3-0.7-0.6c-0.3-0.2-0.6-0.4-0.9-0.5q-0.4-0.3-0.7-0.5c-9.1-5.6-21.5-4.1-32.8 2.9-0.2 0.2-0.5 0.3-0.7 0.5-5.3 3.4-10.4 8.1-14.7 13.9-0.9 1.2-1.9 2.1-2.6 3.3l-13.5-6.9c2.7-5.8 5.7-10.3 10.2-14.5 4.5-4.2 9.4-7.3 14.8-9.3q8-3 17.2-2.4 9.2 0.6 17.9 5.1c5.7 3 11 6.9 15 11.9 4 4.9 6.5 10.1 8.4 15.8 1.8 5.7 2.7 11.6 2.3 18-0.3 6.4-1.6 11.9-4.3 17.7z"/><path class="b" d="m85.3 73.4c-2.3 3.9-5 7.3-8.2 10.4-4.6 4.3-9.6 7.5-15 9.6-5.4 2.1-11.2 3-17.3 2.7q-9.3-0.5-17.9-5c-5.8-3-10.6-6.9-14.6-11.9-4-5-6.9-10.4-8.7-16.2q-2.7-8.8-2.1-18.5c0.3-4.6 0.8-9.2 2.2-13.6l13.6 7.1q-1.1 2.2-2.1 4.4l-0.1 0.2c-6.4 15.8-4.5 31.8 6 39.7 8.8 6.5 21.3 5.6 32.9-1 0-0.1 0.1-0.1 0.2-0.1 0-0.1 0-0.1 0.1-0.1 6-3.5 11.8-8.7 16.6-15.1v-0.1z"/></svg>
                    </div>
                    </div>
                </div>
            </div>

            <div class="scs-right" {% if section.settings.form_bg !=blank
                %}style="background-image: url('{{ section.settings.form_bg | image_url: width: 1400 }}');" {% endif %}>
                <div class="scs-form-wrap">
                    {% form 'contact' %}
                    {% if form.posted_successfully? %}
                    <p class="scs-form-success">Thank you for reaching out! We'll get back to you soon.</p>
                    {% endif %}

                    <div class="scs-input-wrap">
                        <label for="ScsFirstName">First Name</label>
                        <input type="text" id="ScsFirstName" name="contact[first_name]"
                            placeholder="Enter Your Full Name">
                    </div>
                    <div class="scs-input-wrap">
                        <label for="ScsLastName">Last Name*</label>
                        <input type="text" id="ScsLastName" name="contact[last_name]" placeholder="Enter Your Last Name"
                            required>
                    </div>
                    <div class="scs-input-wrap">
                        <label for="ScsEmail">Email Address</label>
                        <input type="email" id="ScsEmail" name="contact[email]" placeholder="Enter Your Email Address"
                            required>
                    </div>
                    <div class="scs-input-wrap">
                        <label for="ScsBody">Your Question</label>
                        <textarea id="ScsBody" name="contact[body]" rows="1" placeholder="Write Your Message Here"
                            data-lenis-prevent></textarea>
                    </div>
                    <div class="scs-input-wrap scs-submit-wrap">
                        <input type="submit" value="{{ section.settings.submit_label | default: 'Submit' }}"
                            class="scs-submit-btn primary-btn">
                    </div>
                    {% endform %}

                    <div class="scs-logo-o">
                        <svg width="88" height="90" viewBox="0 0 88 90" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M76.5257 55.2624C76.5257 55.2624 67.3475 52.0523 65.1196 51.2731C67.1943 46.4292 68.7157 41.6906 68.8642 37.0696C68.8981 36.9727 68.8751 36.8832 68.8847 36.7779C69.1312 28.2245 66.1165 20.7583 60.1355 16.9548C60.0072 16.8556 59.8703 16.7806 59.7093 16.6971C59.5325 16.5809 59.3315 16.4563 59.122 16.3558C58.8883 16.2469 58.6873 16.1223 58.4451 16.0376C58.2441 15.9129 58.0346 15.8125 57.8409 15.7447C50.5926 12.6119 41.6003 15.0092 34.0187 21.3774C33.8541 21.5372 33.6737 21.6643 33.5091 21.8241C29.9508 24.9265 26.7038 28.9257 24.1521 33.6571C23.627 34.6145 23.0146 35.4327 22.5948 36.3998L11.914 32.7456C13.2551 28.1342 15.0203 24.4861 17.8715 20.919C20.7553 17.3362 24.0657 14.5545 27.7951 12.5172C31.5488 10.4884 35.6962 9.27643 40.2532 8.91411C44.8186 8.52759 49.3855 9.14684 53.9383 10.7392C58.491 12.3315 62.7971 14.707 66.2959 17.914C69.8031 21.0968 72.2088 24.7094 74.1788 28.713C76.1487 32.7166 77.3766 36.9768 77.8189 41.6958C78.2528 46.439 77.8825 50.6836 76.5257 55.2624Z"
                                fill="#1A1A1A" />
                            <path
                                d="M59.7019 16.6947C59.2914 16.4696 58.8809 16.2445 58.4377 16.0352C58.6799 16.1199 58.8809 16.2445 59.1146 16.3534C59.3241 16.4538 59.5251 16.5785 59.7019 16.6947Z"
                                fill="#1A1A1A" />
                            <path
                                d="M75.2075 59.0341C73.9131 62.1133 72.2894 64.9686 70.2478 67.5419C67.3458 71.2543 63.9932 74.1569 60.2383 76.2669C56.4834 78.3768 52.3106 79.6614 47.7367 80.0721C43.1544 80.5071 38.579 79.912 34.002 78.3112C29.425 76.7104 25.4519 74.3155 21.9701 71.0601C18.4797 67.8288 15.775 64.1388 13.8389 60.0384C11.9028 55.938 10.7511 51.4599 10.3511 46.6199C10.0679 43.2334 9.89964 39.7514 10.5002 36.4023L21.2767 40.1715C20.8703 41.3334 20.5208 42.4881 20.2282 43.6355L20.1605 43.8292C17.0931 56.0961 20.217 67.7573 28.8146 72.3944C35.9384 76.2716 45.087 74.2822 52.9326 68.1693C52.9738 68.1294 53.0391 68.0979 53.0803 68.0579C53.0888 68.0337 53.1057 67.9853 53.1626 67.978C57.2258 64.7534 60.9085 60.3632 63.7603 55.0847L63.7772 55.0363L75.2075 59.0341Z"
                                fill="#1A1A1A" />
                        </svg>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    .scs-submit-btn {
        border: none;
    }

    .science-contact-sec {
        overflow: hidden;
    }

    .science-contact-sec-in {
        display: flex;
        align-items: stretch;
        gap: 60px;
    }

    /* ── LEFT ── */
    .scs-left {
        flex: 0 0 42%;
        max-width: 42%;
        display: flex;
        flex-direction: column;
        gap: 100px;
        padding: 80px 0;
    }

    .scs-heading h2 {
        font-size: 40px;
        line-height: 1.1;
        margin-bottom: 16px;
    }

    .scs-heading p {
        font-size: 14px;
        line-height: 1.6;
        color: #5D5D5D;
        margin: 0;
    }

    /* QOD black card */
    .scs-qod {
        background: #000;
        color: #fff;
        padding: 32px 28px 28px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        max-width: 400px;
    }

    .scs-qod-label {
        font-size: 40px;
        font-family: var(--tobias);
        font-weight: 400;
        line-height: 120%;
        letter-spacing: -0.05em;
        color: #fff;
        margin: 0;
    }

    .scs-qod-body {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
    }

    .scs-qod-text {
        flex: 1;
    }

    .scs-qod-question {
        font-size: 26px;
        font-family: var(--tobias);
        font-weight: 400;
        line-height: 120%;
        color: #fff;
        letter-spacing: -0.05em;
        margin: 0 0 15px;
        max-width: 15ch;
    }

    .scs-qod-desc {
        font-size: 14px;
        line-height: 136%;
        color: #fff;
        letter-spacing: 0em;
        font-weight: 500;
        max-width: 32ch;
        margin: 0;
    }

    .scs-qod-img {
        flex: 0 0 auto;
        width: 90px;
        height: 90px;
    }

    .scs-qod-img img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }

    .scs-qod-author {
        padding-top: 16px;
    }

    .scs-author-name {
        font-size: 14px;
        font-weight: 400;
        color: #fff;
        line-height: 150%;
        letter-spacing: 0em;
        margin: 0 0 2px;
        font-family: var(--tobias);
    }

    .scs-author-role {
        font-size: 12px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #fff;
        letter-spacing: 2.88px;
        margin: 0;
        font-family: var(--aspekta);
    }

    /* ── RIGHT ── */
    .scs-right {
        flex: 1;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 37px 0px 37px 20px;
    }

    .scs-form-wrap {
        background: #fff;
        width: 100%;
        padding: 80px 40px 100px;
        position: relative;
    }

    /* form fields */
    .scs-input-wrap {
        margin-bottom: 28px;
    }

    .scs-input-wrap label {
        display: block;
        font-size: 11px;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        font-family: var(--aspekta);
        font-weight: 600;
        color: #1A1A1A;
        margin-bottom: 8px;
    }

    .scs-input-wrap input[type="text"],
    .scs-input-wrap input[type="email"],
    .scs-input-wrap textarea {
        width: 100%;
        border: 0;
        border-bottom: 1px solid #D0D0D0;
        background: transparent;
        padding: 8px 0;
        font-size: 13px;
        font-family: var(--aspekta);
        color: #1A1A1A;
        outline: none;
        resize: none;
        box-sizing: border-box;
        transition: border-color 0.2s ease;
    }

    .scs-input-wrap input[type="text"]::placeholder,
    .scs-input-wrap input[type="email"]::placeholder,
    .scs-input-wrap textarea::placeholder {
        color: #AAAAAA;
    }

    .scs-input-wrap input:focus,
    .scs-input-wrap textarea:focus {
        border-bottom-color: #1A1A1A;
    }

    .scs-submit-wrap {
        margin-top: 36px;
        margin-bottom: 0;
    }

    .scs-logo-o {
        position: absolute;
        bottom: 20px;
        right: 20px;
    }

    .scs-logo-o svg {
        width: 60px;
        height: 60px;
        display: block;
    }

    .scs-form-success {
        font-size: 14px;
        color: #1A1A1A;
        margin-bottom: 24px;
    }
    .bottom-scs-qod{
        display: flex;
        align-items: end;
        justify-content: space-between;
    }

    @media (max-width: 991px) {
        .science-contact-sec-in {
            flex-direction: column;
            gap: 0;
        }

        .scs-left {
            flex: none;
            max-width: 100%;
            padding: 0px 20px;
            padding-bottom: 20px;
            gap: 36px;
        }

        .scs-right {
            padding: 40px 20px;
        }

        .science-contact-sec .container {
            padding: 0px;
        }

        .scs-form-wrap {
            padding: 40px 32px 32px;
        }
        .scs-qod{
            max-width: 100%;
        }
    }

    @media (max-width: 767px) {

        .scs-heading h2 {
            font-size: 32px;
        }

        .scs-qod-label {
            font-size: 28px;
        }

        .scs-qod-question {
            font-size: 20px;
        }

        .scs-form-wrap {
            padding: 32px 20px 24px;
        }
        .dark-o-logo svg{
            width: 60px;
            height: 60px;
        }
    }
</style>

{% schema %}
{
"name": "Science Contact",
"settings": [
{
"type": "header",
"content": "Left — Heading"
},
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "A Space For Your Question"
},
{
"type": "textarea",
"id": "subtext",
"label": "Subtitle",
"default": "Subtitle that supports the title. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc vulputate libero et velit."
},
{
"type": "header",
"content": "Left — Question Of The Day card"
},
{
"type": "text",
"id": "qod_label",
"label": "Card label",
"default": "Question Of The Day"
},
{
"type": "textarea",
"id": "qod_question",
"label": "Question",
"default": "Why Isn't Food Alone Always Enough?"
},
{
"type": "textarea",
"id": "qod_desc",
"label": "Description",
"default": "Whether you're curious about ingredients, absorption, or how Orbe fits into your routine, we're here to help."
},
{
"type": "image_picker",
"id": "qod_image",
"label": "Card image (bottom right)"
},
{
"type": "text",
"id": "author_name",
"label": "Author name",
"default": "Lali Sinclair"
},
{
"type": "text",
"id": "author_role",
"label": "Author role",
"default": "Marketing"
},
{
"type": "header",
"content": "Right — Form"
},
{
"type": "image_picker",
"id": "form_bg",
"label": "Form background image"
},
{
"type": "text",
"id": "submit_label",
"label": "Submit button text",
"default": "Submit"
}
],
"presets": [
{
"name": "Science Contact"
}
]
}
{% endschema %}