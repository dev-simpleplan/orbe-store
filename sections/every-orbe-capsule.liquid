{% assign heading = section.settings.heading %}
{% assign capsule_image = section.settings.capsule_image %}
{% assign bg_image = section.settings.background_image %}

<section class="every-orbe-capsule"
  {% if bg_image != blank %}
    style="background-image: url('{{ bg_image | image_url: width: 2000 }}');"
  {% else %}
    style="background-image: url('https://cdn.shopify.com/s/files/1/0739/8014/9916/files/image_16.png?v=1781179509');"
  {% endif %}
>

  <!-- DESKTOP (>991px) -->
  <div class="eoc-desktop">
    <div class="eoc-left text-animation">
      <h2 class="eoc-heading">{{ heading }}</h2>
    </div>

    <div class="eoc-center">
      <div class="eoc-pill">
        {% if capsule_image != blank %}
          <img src="{{ capsule_image | image_url: width: 600 }}" alt="Orbe Capsule" class="eoc-pill-img">
        {% else %}
          <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/Untitled_13_1_d5b6f6f5-fca2-4310-9b7f-c83ae57eefe3.png?v=1781179578" alt="Orbe Capsule" class="eoc-pill-img">
        {% endif %}

        {% for block in section.blocks %}
          {% assign idx = forloop.index %}
          <button class="eoc-dot eoc-dot-{{ idx }}" data-index="{{ idx }}" aria-label="Point {{ idx }}" {{ block.shopify_attributes }}>
            <span class="eoc-dot-num">{{ idx }}</span>
          </button>
          <div class="eoc-card eoc-card-{{ idx }}{% if idx == 1 or idx == 3 %} eoc-card--left{% else %} eoc-card--right{% endif %}">
            {% if block.settings.title != blank %}<p class="eoc-card-title">{{ block.settings.title }}</p>{% endif %}
            {% if block.settings.description != blank %}<p class="eoc-card-desc">{{ block.settings.description }}</p>{% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="eoc-right"></div>
  </div>

  <!-- MOBILE (≤991px) -->
  <div class="eoc-mobile">
    <div class="eoc-mobile-inner">
      <div class="eoc-pill eoc-pill--mobile text-animation">
        {% if capsule_image != blank %}
          <img src="{{ capsule_image | image_url: width: 600 }}" alt="Orbe Capsule" class="eoc-pill-img">
        {% else %}
          <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/Untitled_13_1_d5b6f6f5-fca2-4310-9b7f-c83ae57eefe3.png?v=1781179578" alt="Orbe Capsule" class="eoc-pill-img">
        {% endif %}
        {% for block in section.blocks %}
          <button
            class="eoc-dot eoc-dot-{{ forloop.index }} eoc-dot--mobile"
            data-title="{{ block.settings.title | escape }}"
            data-desc="{{ block.settings.description | escape }}"
            aria-label="Point {{ forloop.index }}"
          >
            <span class="eoc-dot-num">{{ forloop.index }}</span>
          </button>
        {% endfor %}
      </div>
      <h2 class="eoc-heading eoc-heading--mobile">{{ heading }}</h2>
    </div>
  </div>

  <!-- Modal dialog (mobile only) -->
  <div class="eoc-modal-overlay" id="eocModalOverlay" aria-hidden="true">
    <div class="eoc-modal" role="dialog">
      <button class="eoc-modal-close" id="eocModalClose" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="1" y1="1" x2="17" y2="17" stroke="#111" stroke-width="2" stroke-linecap="round"/>
          <line x1="17" y1="1" x2="1" y2="17" stroke="#111" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <p class="eoc-modal-title" id="eocModalTitle"></p>
      <p class="eoc-modal-desc" id="eocModalDesc"></p>
    </div>
  </div>

</section>

<script>
(function () {
  // ── Desktop: open first dot by default ───────────────────────
  if (window.innerWidth > 991) {
    var firstDot  = document.querySelector('.eoc-dot-1:not(.eoc-dot--mobile)');
    var firstCard = document.querySelector('.eoc-card-1');
    if (firstDot && firstCard) {
      firstDot.classList.add('is-active');
      firstCard.classList.add('is-open');
    }
  }

  // ── Desktop: click dot → side card ──────────────────────────
  document.querySelectorAll('.eoc-dot:not(.eoc-dot--mobile)').forEach(function (dot) {
    dot.addEventListener('click', function () {
      var idx = this.dataset.index;
      var card = document.querySelector('.eoc-card-' + idx);
      var isOpen = card.classList.contains('is-open');

      document.querySelectorAll('.eoc-card').forEach(function (c) { c.classList.remove('is-open'); });
      document.querySelectorAll('.eoc-dot:not(.eoc-dot--mobile)').forEach(function (d) { d.classList.remove('is-active'); });

      if (!isOpen) {
        card.classList.add('is-open');
        this.classList.add('is-active');
      }
    });
  });

  // ── Mobile: click dot → centered modal ───────────────────────
  var overlay = document.getElementById('eocModalOverlay');
  var closeBtn = document.getElementById('eocModalClose');
  var modalTitle = document.getElementById('eocModalTitle');
  var modalDesc = document.getElementById('eocModalDesc');

  var scrollY = 0;

  function openModal(title, desc) {
    modalTitle.textContent = title || '';
    modalDesc.textContent = desc || '';
    scrollY = window.scrollY;
    document.body.style.top = '-' + scrollY + 'px';
    document.body.style.position = 'fixed';
    document.body.style.width = '100%';
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
  }

  function closeModal() {
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.width = '';
    window.scrollTo(0, scrollY);
  }

  document.querySelectorAll('.eoc-dot--mobile').forEach(function (dot) {
    dot.addEventListener('click', function () {
      openModal(this.dataset.title, this.dataset.desc);
    });
  });

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closeModal();
  });
})();
</script>

{% schema %}
{
  "name": "Every Orbe Capsule",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Every Orbe Capsule Is Tested To Ensure It Does What It's Designed To Do: Safely, Consistently, And Over Time."
    },
    {
      "type": "image_picker",
      "id": "capsule_image",
      "label": "Capsule Image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Feature Point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "INGREDIENTS ARE VERIFIED AT SOURCE."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Each nutrient is checked for identity, purity, and quality before it ever enters a formula."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Every Orbe Capsule",
      "blocks": [
        { "type": "point" },
        { "type": "point" },
        { "type": "point" },
        { "type": "point" }
      ]
    }
  ]
}
{% endschema %}
