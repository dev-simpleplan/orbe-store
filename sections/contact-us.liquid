},
{
"type": "social_link",
"settings": {
"label": "FACEBOOK"
}
},
{
"type": "social_link",
"settings": {
"label": "INSTAGRAM"
}
},
{
"type": "social_link",
"settings": {
"label": "TWITTER"
}
}
]
}
]
}
{% endschema %}