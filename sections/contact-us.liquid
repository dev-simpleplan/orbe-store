"settings": [
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Get in Touch With Our Team"
},
{
"type": "textarea",
"id": "subtitle",
"label": "Subtitle",
"default": "Subtitle that supports the title."
},
{
"type": "image_picker",
"id": "form_bg",
"label": "Form Background Image"
}
],
"blocks": [
{
"type": "contact_info",
"name": "Contact Info",
"settings": [
{
"type": "image_picker",
"id": "icon",
"label": "Icon"
},
{
"type": "text",
"id": "title",
"label": "Title",
"default": "Office"
},
{
"type": "text",
"id": "text",
"label": "Text",
"default": "Your address here"
},
{
"type": "url",
"id": "link",
"label": "Link"
}
]
},
{
"type": "social_link",
"name": "Social Link",
"settings": [
{
"type": "text",
"id": "label",
"label": "Label",
"default": "FACEBOOK"
},
{
"type": "url",
"id": "url",
"label": "URL"
}
]
}
],
"presets": [
{
