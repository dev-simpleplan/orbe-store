<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@24.7.0/build/css/intlTelInput.css">

<style>
  .field-error {
    display: none;
    color: #d0021b;
    font-size: 12px;
    margin-top: 5px;
    letter-spacing: 0;
    text-transform: none;
    font-family: var(--aspekta, sans-serif);
  }
  .contact-us-form input.input--error,
  .contact-us-form textarea.input--error {
    border-color: #d0021b !important;
    outline: none;
  }
  .iti { width: 100%; }
  .iti__tel-input { width: 100%; }
</style>

<section class="contact-us">
  <div class="container">
    <div class="contact-us-in">
      <div class="left">
        <div class="top">
          <h2>{{ section.settings.heading }}</h2>
          <p>{{ section.settings.subtitle }}</p>
        </div>
        <div class="bottom">
          <div class="contact-information">
            {% for block in section.blocks %}
            {% if block.type == 'contact_info' %}
            <div class="contact-info-block" {{ block.shopify_attributes }}>
              <div class="cib-icon">
                {% if block.settings.icon != blank %}
                {{ block.settings.icon | image_url: width: 40 | image_tag: class: 'icon', alt: block.settings.title }}
              {% endif %}
              </div>
              <p class="cib-title">{{ block.settings.title }}</p>
              {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
              {% else %}
              <span>{{ block.settings.text }}</span>
              {% endif %}
            </div>
            {% endif %}
            {% endfor %}
          </div>
          <div class="social-platform-links">
            {% for block in section.blocks %}
            {% if block.type == 'social_link' %}
            <a href="{{ block.settings.url }}" target="_blank" {{ block.shopify_attributes }}>{{ block.settings.label }} <span>
                <svg width="9" height="9" viewBox="0 0 9 9" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M0.930729 8.66667L7.33073 2.26667V8H8.66406V0H0.664062V1.33333H6.3974L-0.00260448 7.73333L0.930729 8.66667Z"
                    fill="#1C1B1F" />
                </svg>
              </span>
            </a>
            {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="right" {% if section.settings.form_bg !=blank
        %}style="background-image: url('{{ section.settings.form_bg | image_url: width: 1200 }}');" {% endif %}>
        <div class="contact-us-form">
          {% form 'contact' %}
          {% if form.posted_successfully? %}
          <p class="form-success">Thank you for reaching out! We'll get back to you soon.</p>
          {% endif %}
          <div class="input-wrap">
            <label for="ContactFormFirstName">First Name</label>
            <input type="text" id="ContactFormFirstName" name="contact[first_name]" placeholder="Enter Your First Name">
            <span class="field-error" id="error-first-name"></span>
          </div>
          <div class="input-wrap">
            <label for="ContactFormLastName">Last Name</label>
            <input type="text" id="ContactFormLastName" name="contact[last_name]" placeholder="Enter Your Last Name">
            <span class="field-error" id="error-last-name"></span>
          </div>
          <div class="input-wrap">
            <label for="ContactFormEmail">Business Email</label>
            <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="Enter Your Email Address">
            <span class="field-error" id="error-email"></span>
          </div>
          <div class="input-wrap">
            <label for="ContactFormPhone">Phone number (optional)</label>
            <div class="phone-warp">
              <input type="tel" id="ContactFormPhone" name="contact[phone]" placeholder="Enter Your Phone Number">
            </div>
            <span class="field-error" id="error-phone"></span>
          </div>
          <div class="input-wrap">
            <label for="ContactFormBody">Additional Information*</label>
            <textarea rows="1" name="contact[body]" id="ContactFormBody" data-lenis-prevent
              placeholder="Please provide any additional details about your request"></textarea>
            <span class="field-error" id="error-body"></span>
          </div>
          <div class="input-wrap submit-wrap">
            <input type="submit" value="Submit" class="primary-btn">
          </div>
          {% endform %}
          <div class="logo-o">
            <svg class="icon" width="88" height="90" viewBox="0 0 88 90" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M76.5296 55.2629C76.5296 55.2629 67.3514 52.0528 65.1235 51.2736C67.1982 46.4296 68.7196 41.6911 68.8682 37.0701C68.902 36.9732 68.879 36.8837 68.8886 36.7784C69.1351 28.225 66.1204 20.7588 60.1394 16.9553C60.0111 16.8561 59.8742 16.7811 59.7132 16.6976C59.5364 16.5814 59.3354 16.4567 59.1259 16.3563C58.8922 16.2474 58.6912 16.1228 58.449 16.0381C58.248 15.9134 58.0385 15.813 57.8448 15.7452C50.5965 12.6124 41.6042 15.0097 34.0226 21.3779C33.858 21.5377 33.6776 21.6648 33.513 21.8245C29.9547 24.9269 26.7077 28.9262 24.156 33.6575C23.6309 34.615 23.0185 35.4332 22.5987 36.4003L11.9179 32.7461C13.259 28.1347 15.0242 24.4866 17.8754 20.9195C20.7593 17.3367 24.0696 14.555 27.799 12.5177C31.5527 10.4888 35.7001 9.27692 40.2571 8.9146C44.8225 8.52808 49.3894 9.14733 53.9422 10.7397C58.495 12.332 62.801 14.7075 66.2998 17.9145C69.8071 21.0973 72.2127 24.7099 74.1827 28.7135C76.1526 32.717 77.3805 36.9773 77.8228 41.6963C78.2567 46.4395 77.8864 50.6841 76.5296 55.2629Z"
                fill="#1A1A1A" />
              <path
                d="M59.7058 16.6951C59.2953 16.4701 58.8848 16.245 58.4416 16.0356C58.6838 16.1203 58.8848 16.245 59.1185 16.3539C59.328 16.4543 59.529 16.579 59.7058 16.6951Z"
                fill="#1A1A1A" />
              <path
                d="M75.2114 59.0346C73.917 62.1138 72.2933 64.9691 70.2517 67.5424C67.3497 71.2548 63.9971 74.1574 60.2422 76.2674C56.4874 78.3773 52.3145 79.6619 47.7406 80.0726C43.1583 80.5075 38.5829 79.9125 34.0059 78.3117C29.4289 76.7108 25.4558 74.316 21.974 71.0606C18.4836 67.8293 15.7789 64.1393 13.8428 60.0389C11.9067 55.9385 10.755 51.4604 10.355 46.6204C10.0718 43.2339 9.90354 39.7519 10.5041 36.4028L21.2806 40.172C20.8742 41.3339 20.5247 42.4886 20.2321 43.636L20.1644 43.8297C17.097 56.0966 20.221 67.7577 28.8185 72.3949C35.9423 76.2721 45.0909 74.2827 52.9365 68.1698C52.9777 68.1298 53.0431 68.0984 53.0842 68.0584C53.0927 68.0342 53.1096 67.9858 53.1665 67.9785C57.2297 64.7539 60.9124 60.3637 63.7642 55.0852L63.7811 55.0368L75.2114 59.0346Z"
                fill="#1A1A1A" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@24.7.0/build/js/intlTelInput.min.js"></script>
<script>
(function () {
  var phoneInput = document.getElementById('ContactFormPhone');
  if (!phoneInput) return;

  var iti = window.intlTelInput(phoneInput, {
    initialCountry: 'in',
    separateDialCode: true,
    loadUtilsOnInit: 'https://cdn.jsdelivr.net/npm/intl-tel-input@24.7.0/build/js/utils.js'
  });

  var form = phoneInput.closest('form');
  if (!form) return;

  var requiredFields = [
    { id: 'ContactFormFirstName', errorId: 'error-first-name', msg: 'First name is required' },
    { id: 'ContactFormLastName',  errorId: 'error-last-name',  msg: 'Last name is required' },
    { id: 'ContactFormEmail',     errorId: 'error-email',      msg: 'Email is required' },
    { id: 'ContactFormBody',      errorId: 'error-body',       msg: 'This field is required' }
  ];

  function showError(errorId, inputEl, msg) {
    var el = document.getElementById(errorId);
    if (el) { el.textContent = msg; el.style.display = 'block'; }
    if (inputEl) inputEl.classList.add('input--error');
  }

  function clearError(errorId, inputEl) {
    var el = document.getElementById(errorId);
    if (el) { el.textContent = ''; el.style.display = 'none'; }
    if (inputEl) inputEl.classList.remove('input--error');
  }

  requiredFields.forEach(function (f) {
    var el = document.getElementById(f.id);
    if (el) el.addEventListener('input', function () { clearError(f.errorId, el); });
  });
  phoneInput.addEventListener('input', function () {
    var digits = phoneInput.value.replace(/\D/g, '').slice(0, 10);
    phoneInput.value = digits;
    clearError('error-phone', phoneInput);
  });

  phoneInput.addEventListener('keydown', function (e) {
    var allowed = ['Backspace','Delete','ArrowLeft','ArrowRight','ArrowUp','ArrowDown','Tab','Home','End'];
    if (allowed.indexOf(e.key) === -1 && !/^\d$/.test(e.key)) e.preventDefault();
  });

  form.addEventListener('submit', function (e) {
    var hasError = false;

    requiredFields.forEach(function (f) {
      var el = document.getElementById(f.id);
      if (!el) return;
      if (!el.value.trim()) {
        showError(f.errorId, el, f.msg);
        hasError = true;
      } else {
        clearError(f.errorId, el);
      }
    });

    // Email format
    var emailEl = document.getElementById('ContactFormEmail');
    if (emailEl && emailEl.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim())) {
      showError('error-email', emailEl, 'Please enter a valid email address');
      hasError = true;
    }

    // Phone optional — if filled must be 10 digits
    if (phoneInput.value.trim()) {
      var digits = phoneInput.value.replace(/\D/g, '');
      if (digits.length !== 10) {
        showError('error-phone', phoneInput, 'Phone number must be exactly 10 digits');
        hasError = true;
      } else {
        clearError('error-phone', phoneInput);
      }
    }

    // Block submission first, then safely update phone value
    if (hasError) {
      e.preventDefault();
      return;
    }

    if (phoneInput.value.trim()) {
      try { phoneInput.value = iti.getNumber(); } catch (err) {}
    }
  });
})();
</script>

{% schema %}
{
