{%- comment -%} Desktop image sources with CDN fallbacks {%- endcomment -%}
{%- if section.settings.d1_left   -%}{%- assign d1_left_src   = section.settings.d1_left   | image_url: width: 1400 -%}{%- else -%}{%- assign d1_left_src   = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/ab750cd8881aee1ab3e0f9cc2ad63b66bdbdebe8.png?v=1780909624' -%}{%- endif -%}
{%- if section.settings.d1_center -%}{%- assign d1_center_src = section.settings.d1_center | image_url: width: 1400 -%}{%- else -%}{%- assign d1_center_src = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/f961151e57385d613cb3940344e99748fd2888c1.png?v=1780909624' -%}{%- endif -%}
{%- if section.settings.d1_right  -%}{%- assign d1_right_src  = section.settings.d1_right  | image_url: width: 1400 -%}{%- else -%}{%- assign d1_right_src  = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/d2e5c456e5c464d9b80b348076849657b55e6b05.png?v=1780909624' -%}{%- endif -%}
{%- if section.settings.d2_left   -%}{%- assign d2_left_src   = section.settings.d2_left   | image_url: width: 1400 -%}{%- else -%}{%- assign d2_left_src   = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/bc4de2dd4e1a18333b2498c4accd46f0339f02a1.png?v=1780909624' -%}{%- endif -%}
{%- if section.settings.d2_center -%}{%- assign d2_center_src = section.settings.d2_center | image_url: width: 1400 -%}{%- else -%}{%- assign d2_center_src = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/f961151e57385d613cb3940344e99748fd2888c1_59767dfd-f84b-4f3c-a526-c96502158480.png?v=1780912404' -%}{%- endif -%}
{%- if section.settings.d2_right  -%}{%- assign d2_right_src  = section.settings.d2_right  | image_url: width: 1400 -%}{%- else -%}{%- assign d2_right_src  = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/8cb88735909b0bd81c5fbf92ea63539fc3a7dff2.png?v=1780909624' -%}{%- endif -%}

{%- comment -%} Mobile image sources with CDN fallbacks {%- endcomment -%}
{%- if section.settings.m1_img -%}{%- assign m1_src = section.settings.m1_img | image_url: width: 800 -%}{%- else -%}{%- assign m1_src = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/f961151e57385d613cb3940344e99748fd2888c1.png?v=1780909624' -%}{%- endif -%}
{%- if section.settings.m2_img -%}{%- assign m2_src = section.settings.m2_img | image_url: width: 800 -%}{%- else -%}{%- assign m2_src = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/f961151e57385d613cb3940344e99748fd2888c1_59767dfd-f84b-4f3c-a526-c96502158480.png?v=1780912404' -%}{%- endif -%}
{%- if section.settings.m3_img -%}{%- assign m3_src = section.settings.m3_img | image_url: width: 800 -%}{%- else -%}{%- assign m3_src = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/85519b51555456cb4d541782f2a6172fb3f7b481.png?v=1780909625' -%}{%- endif -%}

<section class="science-banner">
  <div class="science-banner-sticky">

    <!-- DESKTOP: 2 slides × 3 columns -->
    <div class="sci-desktop-track">
      <div class="sci-banner-wrap">
        <div class="sci-col left">
          <img src="{{ d1_left_src }}" alt="" class="img">
        </div>
        <div class="sci-col center">
          <img src="{{ d1_center_src }}" alt="" class="img">
          <div class="sci-slide-text">
            <h1>{{ section.settings.d1_heading }}</h1>
            <p>{{ section.settings.d1_text }}</p>
          </div>
        </div>
        <div class="sci-col right">
          <img src="{{ d1_right_src }}" alt="" class="img">
        </div>
      </div>

      <div class="sci-banner-wrap">
        <div class="sci-col left">
          <img src="{{ d2_left_src }}" alt="" class="img">
        </div>
        <div class="sci-col center">
          <img src="{{ d2_center_src }}" alt="" class="img">
          <div class="sci-slide-text">
            <h1>{{ section.settings.d2_heading }}</h1>
            <p>{{ section.settings.d2_text }}</p>
          </div>
        </div>
        <div class="sci-col right">
          <img src="{{ d2_right_src }}" alt="" class="img">
        </div>
      </div>
    </div>

    <!-- MOBILE: 3 full-width slides -->
    <div class="sci-mobile-track">
      <div class="sci-mobile-slide">
        <img src="{{ m1_src }}" alt="" class="img">
        <div class="sci-slide-text">
          <h1>{{ section.settings.m1_heading }}</h1>
          <p>{{ section.settings.m1_text }}</p>
        </div>
      </div>
      <div class="sci-mobile-slide">
        <img src="{{ m2_src }}" alt="" class="img">
        <div class="sci-slide-text">
          <h1>{{ section.settings.m2_heading }}</h1>
          <p>{{ section.settings.m2_text }}</p>
        </div>
      </div>
      <div class="sci-mobile-slide">
        <img src="{{ m3_src }}" alt="" class="img">
        <div class="sci-slide-text">
          <h1>{{ section.settings.m3_heading }}</h1>
          <p>{{ section.settings.m3_text }}</p>
        </div>
      </div>
    </div>

    <!-- Progress dots (mobile: 3 dots, desktop: hidden) -->
    <div class="sci-progress">
      <span class="sci-dot active"></span>
      <span class="sci-dot"></span>
      <span class="sci-dot sci-dot-mobile"></span>
    </div>

  </div>
</section>

<script>
(function () {
  var section = document.querySelector('.science-banner');
  if (!section) return;

  var isMobile     = window.innerWidth <= 991;
  var desktopTrack = section.querySelector('.sci-desktop-track');
  var mobileTrack  = section.querySelector('.sci-mobile-track');
  var track        = isMobile ? mobileTrack : desktopTrack;
  var items        = isMobile
    ? section.querySelectorAll('.sci-mobile-slide')
    : section.querySelectorAll('.sci-banner-wrap');
  var n    = items.length;
  var dots = section.querySelectorAll('.sci-dot');

  var currentX = 0;
  var targetX  = 0;

  function getRawProgress() {
    var pinRange = section.offsetHeight - window.innerHeight;
    var scrolled = window.scrollY - section.offsetTop;
    return Math.min(Math.max(scrolled / pinRange, 0), 1);
  }

  function loop() {
    var maxTranslate = track.scrollWidth - window.innerWidth;
    targetX  = -(getRawProgress() * maxTranslate);
    currentX += (targetX - currentX) * 0.09;
    if (Math.abs(targetX - currentX) < 0.1) currentX = targetX;

    track.style.transform = 'translateX(' + currentX + 'px)';

    var p      = maxTranslate > 0 ? (-currentX / maxTranslate) : 0;
    var factor = window.innerWidth * 0.025;

    if (isMobile) {
      items.forEach(function (slide, i) {
        var slidePos = p * (n - 1) - i;
        var img = slide.querySelector('.img');
        if (img) img.style.transform = 'translateX(' + (slidePos * factor * 0.8) + 'px)';
      });
    } else {
      items.forEach(function (wrap, i) {
        var slidePos = p * (n - 1) - i;
        var lImg = wrap.querySelector('.sci-col.left .img');
        var cImg = wrap.querySelector('.sci-col.center .img');
        var rImg = wrap.querySelector('.sci-col.right .img');
        if (lImg) lImg.style.transform = 'translateX(' + (slidePos * factor * 2.0) + 'px)';
        if (cImg) cImg.style.transform = 'translateX(' + (slidePos * factor * 0.8) + 'px)';
        if (rImg) rImg.style.transform = 'translateX(' + (slidePos * factor * 1.5) + 'px)';
      });
    }

    var activeIdx = Math.round(p * (n - 1));
    dots.forEach(function (dot, i) {
      dot.classList.toggle('active', i === activeIdx);
    });

    requestAnimationFrame(loop);
  }

  loop();
})();
</script>

{% schema %}
{
  "name": "Science Banner",
  "settings": [
    { "type": "header", "content": "Desktop — Slide 1" },
    { "type": "image_picker", "id": "d1_left",   "label": "Left Image" },
    { "type": "image_picker", "id": "d1_center", "label": "Center Image" },
    { "type": "image_picker", "id": "d1_right",  "label": "Right Image" },
    { "type": "text",         "id": "d1_heading","label": "Heading", "default": "Science With Intention" },
    { "type": "textarea",     "id": "d1_text",   "label": "Text",    "default": "At Orbe, science isn't about complexity or claims. It's about understanding what the body needs, choosing what's proven, and delivering it in the most thoughtful way possible." },

    { "type": "header", "content": "Desktop — Slide 2" },
    { "type": "image_picker", "id": "d2_left",   "label": "Left Image" },
    { "type": "image_picker", "id": "d2_center", "label": "Center Image" },
    { "type": "image_picker", "id": "d2_right",  "label": "Right Image" },
    { "type": "text",         "id": "d2_heading","label": "Heading", "default": "Formulated With Purpose" },
    { "type": "textarea",     "id": "d2_text",   "label": "Text",    "default": "Every ingredient is chosen for a reason. No fillers, no shortcuts — just clean, effective formulas that work in harmony with your body." },

    { "type": "header", "content": "Mobile — Slide 1" },
    { "type": "image_picker", "id": "m1_img",    "label": "Image" },
    { "type": "text",         "id": "m1_heading","label": "Heading", "default": "Science With Intention" },
    { "type": "textarea",     "id": "m1_text",   "label": "Text",    "default": "At Orbe, science isn't about complexity or claims. It's about understanding what the body needs, choosing what's proven, and delivering it in the most thoughtful way possible." },

    { "type": "header", "content": "Mobile — Slide 2" },
    { "type": "image_picker", "id": "m2_img",    "label": "Image" },
    { "type": "text",         "id": "m2_heading","label": "Heading", "default": "Formulated With Purpose" },
    { "type": "textarea",     "id": "m2_text",   "label": "Text",    "default": "Every ingredient is chosen for a reason. No fillers, no shortcuts — just clean, effective formulas that work in harmony with your body." },

    { "type": "header", "content": "Mobile — Slide 3" },
    { "type": "image_picker", "id": "m3_img",    "label": "Image" },
    { "type": "text",         "id": "m3_heading","label": "Heading", "default": "Built to Perform" },
    { "type": "textarea",     "id": "m3_text",   "label": "Text",    "default": "From bioavailability to absorption, every detail is optimised so your body gets exactly what it needs — nothing more, nothing less." }
  ],
  "presets": [{ "name": "Science Banner" }]
}
{% endschema %}
