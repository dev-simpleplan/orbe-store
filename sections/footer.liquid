<footer>
  <div class="footer">
      <div class="footer-in">
        <div class="left">
          <div class="footer-logo">
            {% if section.settings.footer_logo != blank %}
              <img src="{{ section.settings.footer_logo | img_url: 'master' }}" alt="{{ section.settings.footer_logo.alt | default: shop.name }}" class="icon">
            {% else %}
              <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/Group_1707486900.svg?v=1777620507" alt="Footer Logo" class="icon">
            {% endif %}
          </div>

          <div class="footer-nav">
            <div class="footer-nav-top">
              {% assign footer_menu = linklists['footer'] %}
              {% assign has_direct_links = false %}

              {% for link in footer_menu.links %}
                {% if link.links.size == 0 %}
                  {% assign has_direct_links = true %}
                {% endif %}
              {% endfor %}

              {% if has_direct_links %}
                <div class="footer-nav-links">
                  <ul>
                    {% assign direct_i = 0 %}
                    {% for link in footer_menu.links %}
                      {% if link.links.size == 0 %}
                        {% assign direct_i = direct_i | plus: 1 %}
                        {% if direct_i <= 3 %}
                          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </ul>
                  <ul>
                    {% assign direct_i = 0 %}
                    {% for link in footer_menu.links %}
                      {% if link.links.size == 0 %}
                        {% assign direct_i = direct_i | plus: 1 %}
                        {% if direct_i > 3 %}
                          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}

              {% for link in footer_menu.links %}
                {% if link.links.size > 0 %}
                  <div>
                    <p>
                      {% if link.url != blank and link.url != '#' %}
                        <a href="{{ link.url }}" class="footer-nav-heading-link">{{ link.title }}</a>
                      {% else %}
                        {{ link.title }}
                      {% endif %}
                    </p>
                    <ul>
                      {% for child_link in link.links %}
                        <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
              <div class="subscribe-news">
                <p>Subscribe to Newsletter</p>
                <p>You'll get an email once a month. We'll never share it.</p>
                <div class="subscribe-news-form">
                  <form method="post" action="/contact#footer-newsletter">
                    <input type="hidden" name="form_type" value="customer">
                    <input type="hidden" name="utf8" value="✓">
                    <input type="email" name="contact[email]" placeholder="Enter your email">
                    <input type="submit" value="Subscribe">
                  </form>
                </div>
              </div>
          </div>
        </div>

        <div class="right">
          <div class="footer-image">
            {% if section.settings.footer_image != blank %}
              <img src="{{ section.settings.footer_image | img_url: 'master' }}" alt="{{ section.settings.footer_image.alt | default: 'Footer Image' }}" class="icon">
            {% else %}
              <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/Frame_2072749374_2.svg?v=1778152931" alt="Image" class="icon">
            {% endif %}
          </div>
        </div>
      </div>
  </div>
</footer>

<style>
  .footer-nav-links {
    display: flex;
    justify-content: space-between;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "image_picker",
      "id": "footer_image",
      "label": "Footer Image"
    }
  ]
}
{% endschema %}
