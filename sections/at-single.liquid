<section class="at-single">
    <div class="container">
         <div class="heading text-animation">
                {% if section.settings.heading != blank %}
                    <h2>{{ section.settings.heading }}</h2>
                {% endif %}
            </div>
        <div class="at-single-in">
           
            <div class="at-single-image-block">
                <div class="at-single-bg">
                    {% if section.settings.image != blank %}
                        <img src="{{ section.settings.image | image_url }}" alt="" class="img">
                    {% endif %}
                </div>
                <span class="at-single-strike" aria-hidden="true"></span>
                <div class="orbe-motion-logo">
                    {% if section.settings.logo != blank %}
                        <img src="{{ section.settings.logo | image_url }}" alt="">
                    {% endif %}
                </div>
            </div>
            <div class="at-single-content-block text-animation">
                <div class="left">
                    {% if section.settings.left_text != blank %}
                        <p>{{ section.settings.left_text }}</p>
                    {% endif %}
                </div>
                <div class="right">
                    {% if section.settings.right_text != blank %}
                        <p>{{ section.settings.right_text }}</p>
                    {% endif %}
                    {% if section.settings.button_text != blank %}
                        <a href="{{ section.settings.button_link }}" class="primary-btn">{{ section.settings.button_text }}</a>
                    {% endif %}
                </div>
            </div>

        </div>
    </div>
</section>

<script>
  (function () {
    var block = document.querySelector('.at-single-image-block');
    if (!block) return;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-struck');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    observer.observe(block);
  })();
</script>

{% schema %}
{
  "name": "At Single",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "left_text",
      "label": "Left Text"
    },
    {
      "type": "textarea",
      "id": "right_text",
      "label": "Right Text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "At Single"
    }
  ]
}
{% endschema %}
