<section class="people-of-orbe">
    <div class="container">
        <div class="heading">
            <h2>{{ section.settings.heading }}</h2>
        </div>
        <div class="people-of-orbe-in">
            {% assign people_count = section.blocks.size %}
            {% if people_count == 0 %}
                {% assign people_count = 5 %}
            {% endif %}

            <div class="people-of-orbe-slider owl-carousel">
                {% if section.blocks.size > 0 %}
                    {% for block in section.blocks %}
                        {% case forloop.index %}
                            {% when 1 %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/ae00c29e45116a5117e73e113b446abbf9b7f72c.png?v=1777991165' %}
                            {% when 2 %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/734e97d18c35254fe654c967b1f6d274ef1ad4fa.png?v=1777991165' %}
                            {% when 3 %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/c1a59def97b3f3bff6c226dadac007d718ed7033_1.png?v=1777901552' %}
                            {% when 4 %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/cb528a057874ed1960709ef4ccbdb9d1d937fafd_1.png?v=1777901552' %}
                            {% else %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/1a8d976d2a04f4ca91c80f07eafed4b9fb071027_1.png?v=1777901552' %}
                        {% endcase %}
                        <div class="item" {{ block.shopify_attributes }}>
                            <div class="poo-card">
                                <div class="poo-img">
                                    {% if block.settings.image != blank %}
                                        <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.name | escape }}" class="img">
                                    {% else %}
                                        <img src="{{ default_image }}" alt="{{ block.settings.name | escape }}" class="img">
                                    {% endif %}
                                </div>
                                <div class="poo-content">
                                    <h3>{{ block.settings.name }}</h3>
                                    <p>{{ block.settings.designation }}</p>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="item">
                        <div class="poo-card">
                            <div class="poo-img">
                                <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/ae00c29e45116a5117e73e113b446abbf9b7f72c.png?v=1777991165" alt="Neil Paul" class="img">
                            </div>
                            <div class="poo-content">
                                <h3>Neil Paul</h3>
                                <p>Marketing</p>
                            </div>
                        </div>
                    </div>
                    <div class="item">
                        <div class="poo-card">
                            <div class="poo-img">
                                <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/734e97d18c35254fe654c967b1f6d274ef1ad4fa.png?v=1777991165" alt="Mira Shah" class="img">
                            </div>
                            <div class="poo-content">
                                <h3>Mira Shah</h3>
                                <p>Product</p>
                            </div>
                        </div>
                    </div>
                    <div class="item">
                        <div class="poo-card">
                            <div class="poo-img">
                                <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/c1a59def97b3f3bff6c226dadac007d718ed7033_1.png?v=1777901552" alt="Arjun Mehta" class="img">
                            </div>
                            <div class="poo-content">
                                <h3>Arjun Mehta</h3>
                                <p>Research</p>
                            </div>
                        </div>
                    </div>
                    <div class="item">
                        <div class="poo-card">
                            <div class="poo-img">
                                <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/cb528a057874ed1960709ef4ccbdb9d1d937fafd_1.png?v=1777901552" alt="Katherine" class="img">
                            </div>
                            <div class="poo-content">
                                <h3>Katherine</h3>
                                <p>Sales Manager</p>
                            </div>
                        </div>
                    </div>
                    <div class="item">
                        <div class="poo-card">
                            <div class="poo-img">
                                <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/1a8d976d2a04f4ca91c80f07eafed4b9fb071027_1.png?v=1777901552" alt="Daniel Brooks" class="img">
                            </div>
                            <div class="poo-content">
                                <h3>Daniel Brooks</h3>
                                <p>Operations</p>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>

            {% if people_count > 5 %}
                <div class="people-of-orbe-nav">
                    <div class="prev-btn-people">
                        <svg width="43" height="43" viewBox="0 0 43 43" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="21.3472" cy="21.3472" r="21.3472" transform="matrix(-1 0 0 1 42.6943 0)" fill="#1A1A1A" />
                            <path d="M30.0313 20.8421L17.665 20.8421L22.9648 15.5423L22.2985 14.7852L15.7368 21.3469L22.2985 27.9086L22.9648 27.1515L17.665 21.8516L30.0313 21.8516L30.0313 20.8421Z" fill="white" />
                        </svg>
                    </div>
                    <div class="next-btn-people">
                        <svg width="43" height="43" viewBox="0 0 43 43" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="21.3472" cy="21.3472" r="21.3472" fill="#1A1A1A" />
                            <path d="M12.663 20.8421L25.0294 20.8421L19.7295 15.5423L20.3958 14.7852L26.9575 21.3469L20.3958 27.9086L19.7295 27.1515L25.0294 21.8516L12.663 21.8516L12.663 20.8421Z" fill="white" />
                        </svg>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "People Of Orbe",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The People of Orbé"
    }
  ],
  "blocks": [
    {
      "type": "person",
      "name": "Person",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Neil Paul"
        },
        {
          "type": "text",
          "id": "designation",
          "label": "Designation",
          "default": "Marketing"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "People Of Orbe"
    }
  ]
}
{% endschema %}
