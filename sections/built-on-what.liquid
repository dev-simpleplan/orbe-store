<section class="built-on-what">
    <div class="container-left">
        <div class="built-on-what-in">
            <div class="left">
                <div class="bow-heading">
                    {% if section.settings.heading != blank %}
                        <h2>{{ section.settings.heading }}</h2>
                    {% endif %}
                    {% if section.settings.text != blank %}
                        <p>{{ section.settings.text }}</p>
                    {% endif %}
                </div>

                <div class="built-on-what-accordion">
                    {% for block in section.blocks %}
                        <div class="bow-item{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
                            <button class="bow-trigger" type="button" aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
                                <span class="bow-title">{{ block.settings.title }}</span>
                                <span class="bow-icon">
                                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <circle cx="10" cy="10" r="9.5" stroke="currentColor"/>
                                    </svg>
                                </span>
                            </button>
                            <div class="bow-content">
                                {% if block.settings.text != blank %}
                                    <p>{{ block.settings.text }}</p>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="right">
                <div class="built-on-what-img">
                    {% if section.settings.image != blank %}
                        <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" class="img" loading="lazy" width="1200" height="900">
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .built-on-what {
        overflow: hidden;
    }

    .built-on-what .container-left {
        padding-right: 0;
    }

    .built-on-what-in {
        display: flex;
        align-items: stretch;
        gap: 0;
    }

    .built-on-what-in .left {
        flex: 0 0 42%;
        max-width: 42%;
        padding: 80px 60px 80px 0;
        display: flex;
        flex-direction: column;
        gap: 48px;
    }

    .built-on-what-in .right {
        flex: 1;
        min-height: 600px;
    }

    .built-on-what-img {
        width: 100%;
        height: 100%;
    }

    .built-on-what-img .img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* Heading */
    .bow-heading h2 {
        margin-bottom: 16px;
    }

    .bow-heading p {
        color: #5D5D5D;
        font-size: 15px;
        line-height: 1.5;
        margin: 0;
    }

    /* Accordion */
    .built-on-what-accordion {
        display: flex;
        flex-direction: column;
    }

    .bow-item {
        border-top: 1px solid #E0E0E0;
    }

    .bow-item:last-child {
        border-bottom: 1px solid #E0E0E0;
    }

    .bow-trigger {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        background: none;
        border: 0;
        padding: 20px 0;
        cursor: pointer;
        text-align: left;
    }

    .bow-title {
        font-family: var(--canela);
        font-size: 18px;
        font-weight: 400;
        color: #1A1A1A;
        line-height: 1.3;
    }

    .bow-icon {
        flex: 0 0 20px;
        width: 20px;
        height: 20px;
        color: #1A1A1A;
        transition: color 0.2s ease;
    }

    .bow-icon svg {
        display: block;
        width: 100%;
        height: 100%;
        transition: transform 0.3s ease;
    }

    .bow-item.active .bow-icon svg circle {
        fill: #1A1A1A;
    }

    .bow-content {
        overflow: hidden;
        max-height: 0;
        transition: max-height 0.35s ease, padding 0.35s ease;
    }

    .bow-item.active .bow-content {
        max-height: 200px;
        padding-bottom: 20px;
    }

    .bow-content p {
        font-size: 14px;
        line-height: 1.6;
        color: #5D5D5D;
        margin: 0;
    }

    @media (max-width: 991px) {
        .built-on-what-in {
            flex-direction: column;
        }

        .built-on-what-in .left {
            flex: none;
            max-width: 100%;
            padding: 60px 0 48px;
            gap: 36px;
        }

        .built-on-what-in .right {
            min-height: 400px;
        }
    }

    @media (max-width: 767px) {
        .built-on-what-in .left {
            padding: 48px 0 36px;
            gap: 28px;
        }

        .built-on-what-in .right {
            min-height: 300px;
            margin-left: calc(50% - 50vw);
            margin-right: calc(50% - 50vw);
        }

        .bow-title {
            font-size: 16px;
        }
    }
</style>

<script>
    (function () {
        var section = document.currentScript.previousElementSibling;
        if (!section) return;

        section.querySelectorAll('.bow-trigger').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var item = btn.closest('.bow-item');
                var isActive = item.classList.contains('active');

                section.querySelectorAll('.bow-item').forEach(function (el) {
                    el.classList.remove('active');
                    el.querySelector('.bow-trigger').setAttribute('aria-expanded', 'false');
                });

                if (!isActive) {
                    item.classList.add('active');
                    btn.setAttribute('aria-expanded', 'true');
                }
            });
        });
    })();
</script>

{% schema %}
{
  "name": "Built On What",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built On What Science Already Understands"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtext",
      "default": "Clinical evidence is not a headline for us. It's the foundation."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right image"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Research-Led Ingredients"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Content",
          "default": "Nutrients supported by global research for absorption and efficacy."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Built On What",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "Research-Led Ingredients",
            "text": "Nutrients supported by global research for absorption and efficacy."
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Clinically Studied Forms",
            "text": "We use bioavailable forms of nutrients that have been studied in clinical settings."
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Evidence-Based Dosing",
            "text": "Every dose is calibrated against peer-reviewed research, not marketing targets."
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Absorption Matters",
            "text": "Formulated to support how the body actually absorbs and uses nutrients over time."
          }
        }
      ]
    }
  ]
}
{% endschema %}
