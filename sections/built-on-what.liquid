<section class="built-on-what">
    <div class="container-left">
        <div class="built-on-what-in">
            <div class="left">
                <div class="bow-heading">
                    {% if section.settings.heading != blank %}
                    <h2>{{ section.settings.heading }}</h2>
                    {% endif %}
                    {% if section.settings.text != blank %}
                    <p>{{ section.settings.text }}</p>
                    {% endif %}
                </div>

                <div class="built-on-what-accordion">
                    {% for block in section.blocks %}
                    <div class="bow-item{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
                        <button class="bow-trigger" type="button"
                            aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
                            <span class="bow-title">{{ block.settings.title }}</span>
                            <span class="bow-icon" aria-hidden="true">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path
                                        d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
                                        stroke="black" stroke-width="0.7" stroke-linecap="round"
                                        stroke-linejoin="round" />
                                    <path class="bow-icon-v" d="M12 8V16" stroke="black" stroke-width="0.7"
                                        stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M8 12H16" stroke="black" stroke-width="0.7" stroke-linecap="round"
                                        stroke-linejoin="round" />
                                </svg>
                            </span>
                        </button>
                        <div class="bow-panel">
                            <div class="bow-content">
                                {% if block.settings.text != blank %}
                                <p>{{ block.settings.text }}</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="right">
                <div class="built-on-what-img">
                    {% if section.settings.image != blank %}
                    <img src="{{ section.settings.image | image_url: width: 1200 }}"
                        alt="{{ section.settings.heading | escape }}" class="img" loading="lazy" width="1200"
                        height="900">
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .built-on-what {
        overflow: hidden;
    }

    .built-on-what .container-left {
        padding-right: 0;
    }

    .built-on-what-in {
        display: flex;
        align-items: stretch;
        gap: 0;
    }

    .built-on-what-in .left {
        flex: 0 0 42%;
        max-width: 42%;
        padding-right: 60px;
        display: flex;
        flex-direction: column;
        gap: 48px;
    }

    .built-on-what-in .right {
        flex: 1;
        position: relative;
        overflow: hidden;
    }

    .built-on-what-img {
        position: absolute;
        inset: 0;
    }

    .built-on-what-img .img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* Heading */
    .bow-heading h2 {
        margin-bottom: 16px;
    }

    .bow-heading p {
        color: #5D5D5D;
        font-size: 15px;
        line-height: 1.5;
        margin: 0;
    }

    /* Accordion */
    .built-on-what-accordion {
        display: flex;
        flex-direction: column;
    }

    .bow-item {
        border-top: 1px solid #E0E0E0;
    }

    .bow-item:last-child {
        border-bottom: 1px solid #E0E0E0;
    }

    .bow-trigger {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        background: none;
        border: 0;
        padding: 20px 0;
        cursor: pointer;
        text-align: left;
    }

    .bow-title {
        font-family: var(--tobias);
        font-size: 32px;
        font-weight: 400;
        color: #1A1A1A;
        line-height: 150%;
       letter-spacing: -0.03em;
    }

    .bow-icon {
        flex: 0 0 24px;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bow-icon svg {
        display: block;
        width: 24px;
        height: 24px;
    }

    .bow-icon-v {
        transition: opacity 0.25s ease, transform 0.25s ease;
        transform-origin: center;
    }

    .bow-item.active .bow-icon-v {
        opacity: 0;
    }

    .bow-panel {
        overflow: hidden;
        max-height: 0;
        transition: max-height 0.35s ease;
    }

    .bow-item.active .bow-panel {
        max-height: 300px;
    }

    .bow-content {
        padding-bottom: 20px;
    }

    .bow-content p {
        font-size: 18px;
        line-height: 150%;
        color: #1A1A1A;
        letter-spacing: 0em;
        margin: 0;
    }

    @media (max-width: 991px) {
        .built-on-what-in {
            flex-direction: column;
        }

        .built-on-what-in .left {
            flex: none;
            max-width: 100%;
            padding: 60px 0 48px;
            gap: 36px;
        }

        .built-on-what-in .right {
            min-height: 400px;
            display: none;
        }
        .built-on-what .container-left{
            padding: 0px 20px;
        }
    }

    @media (max-width: 767px) {
        .built-on-what-in .left {
            padding: 0px;
            gap: 28px;
        }

        .built-on-what-in .right {
            min-height: 300px;
            margin-left: calc(50% - 50vw);
            margin-right: calc(50% - 50vw);
            display: none;
        }

        .bow-title {
            font-size: 26px;
        }
        .bow-content p{
            font-size: 14px;
        }
    }
</style>

<script>
    (function () {
        var section = document.getElementById('shopify-section-{{ section.id }}');
        if (!section) return;

        section.querySelectorAll('.bow-trigger').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var item = btn.closest('.bow-item');
                var isActive = item.classList.contains('active');

                section.querySelectorAll('.bow-item').forEach(function (el) {
                    el.classList.remove('active');
                    el.querySelector('.bow-trigger').setAttribute('aria-expanded', 'false');
                });

                if (!isActive) {
                    item.classList.add('active');
                    btn.setAttribute('aria-expanded', 'true');
                }
            });
        });
    })();
</script>

{% schema %}
{
"name": "Built On What",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Built On What Science Already Understands"
},
{
"type": "textarea",
"id": "text",
"label": "Subtext",
"default": "Clinical evidence is not a headline for us. It's the foundation."
},
{
"type": "image_picker",
"id": "image",
"label": "Right image"
}
],
"blocks": [
{
"type": "item",
"name": "Accordion item",
"settings": [
{
"type": "text",
"id": "title",
"label": "Title",
"default": "Research-Led Ingredients"
},
{
"type": "textarea",
"id": "text",
"label": "Content",
"default": "Nutrients supported by global research for absorption and efficacy."
}
]
}
],
"presets": [
{
