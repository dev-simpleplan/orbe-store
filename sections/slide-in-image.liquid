<section class="slide-in-img">
  <div class="container">
    <div class="slide-in-img-in">

      <div class="sii-text">
        <h2 class="text-target">
          {{ section.settings.heading }}
        </h2>
      </div>

      <div class="sii-img">
        {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url }}" alt="{{ section.settings.heading | strip_html | escape }}"
          class="parallax-img">
        {% endif %}
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    gsap.registerPlugin(ScrollTrigger);

    function splitWords(selector) {
      document.querySelectorAll(selector).forEach(el => {
        const frag = document.createDocumentFragment();

        // Recursively walk the rich-text tree (Shopify wraps content in <p>, and
        // accent words come through as <strong>/<b>). Any text inside a bold tag
        // becomes an accent word.
        function walk(node, accent) {
          node.childNodes.forEach(child => {
            if (child.nodeType === 3) {
              const text = child.textContent.trim();
              if (!text) return;
              text.split(/\s+/).forEach(word => {
                const span = document.createElement("span");
                span.textContent = word;
                if (accent) span.classList.add("accent");
                frag.appendChild(span);
                frag.appendChild(document.createTextNode(" "));
              });
            } else if (child.nodeType === 1) {
              const tag = child.tagName;
              walk(child, accent || tag === "STRONG" || tag === "B");
            }
          });
        }

        walk(el, false);

        el.innerHTML = "";
        el.appendChild(frag);
      });
    }

    splitWords(".text-target");

    const words = document.querySelectorAll(".text-target span");
    const image = document.querySelector(".parallax-img");

    let tl1 = gsap.timeline({
      scrollTrigger: {
        trigger: ".slide-in-img",
        start: "top 40%",
        end: "top 20%",
        scrub: true
      }
    });

    tl1.to(words, {
      // Accent (bold) words fill to the gold color, the rest to near-black.
      color: (i, target) => target.classList.contains("accent") ? "#b98846" : "#1A1A1A",
      stagger: {
        each: 0.1,
        ease: "power1.inOut"
      },
      ease: "none"
    });

    gsap.to(".parallax-img", {
      y: -50,
      ease: "none",
      scrollTrigger: {
        trigger: ".slide-in-img",
        start: "top bottom",
        end: "bottom top",
        scrub: true
      }
    });
  });
</script>

{% schema %}
{
"name": "Slide In Image",
"settings": [
{
"type": "richtext",
"id": "heading",
"label": "Heading Text",
},
{
"type": "image_picker",
"id": "image",
"label": "Image"
}
],
"presets": [
{
"name": "Slide In Image"
}
]
}
{% endschema %}