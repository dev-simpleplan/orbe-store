<section class="best-bio-available" id="best-bio-available-{{ section.id }}">
    <div class="container">
        <div class="best-bio-top">
            <div class="heading text-animation">
                {% if section.settings.heading != blank %}
                <h2>{{ section.settings.heading }}</h2>
                {% endif %}
            </div>

        </div>
        <div class="best-bio-slider owl-carousel">
            {% for block in section.blocks %}
            <div class="item" {{ block.shopify_attributes }}>
                <div class="best-bio-available-in">
                    <div class="left">
                        <div class="text-animation">
                            {% if block.settings.text != blank %}
                            <p>{{ block.settings.text }}</p>
                            {% endif %}
                            <div class="author-wrap">
                                {% if block.settings.author_image != blank %}
                                <div class="author-img">
                                    {{ block.settings.author_image | image_url: width: 50 | image_tag: alt: 'author image', class: 'img' }}
                                </div>
                                {% endif %}
                                {% if block.settings.author_name != blank %}
                                <div class="author-name">
                                    <p>{{ block.settings.author_name }}</p>
                                </div>
                                {% endif %}
                            </div>
                        </div>
                        <div class="best-bio-nav">
                            <div class="prev-btn-bio" aria-label="Previous slide">
                                <svg width="43" height="43" viewBox="0 0 43 43" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="21.3472" cy="21.3472" r="21.3472" transform="matrix(-1 0 0 1 42.6943 0)"
                                        fill="#1A1A1A" />
                                    <path
                                        d="M30.0313 20.8421L17.665 20.8421L22.9648 15.5423L22.2985 14.7852L15.7368 21.3469L22.2985 27.9086L22.9648 27.1515L17.665 21.8516L30.0313 21.8516L30.0313 20.8421Z"
                                        fill="white" />
                                </svg>
                            </div>
                            <div class="next-btn-bio" aria-label="Next slide">
                                <svg width="43" height="43" viewBox="0 0 43 43" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="21.3472" cy="21.3472" r="21.3472" fill="#1A1A1A" />
                                    <path
                                        d="M12.663 20.8421L25.0294 20.8421L19.7295 15.5423L20.3958 14.7852L26.9575 21.3469L20.3958 27.9086L19.7295 27.1515L25.0294 21.8516L12.663 21.8516L12.663 20.8421Z"
                                        fill="white" />
                                </svg>
                            </div>
                        </div>
                    </div>
                    <div class="right">
                        <div class="best-bio-img">
                            {% if block.settings.image != blank %}
                                {{ block.settings.image | image_url: width: 635 | image_tag: alt: 'image', class: 'img' }}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% schema %}
{
"name": "Best Bio Available",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Heading"
}
],
"blocks": [
{
"type": "slide",
"name": "Slide",
"settings": [
{
"type": "textarea",
"id": "text",
"label": "Text"
},
{
"type": "image_picker",
"id": "author_image",
"label": "Author Image"
},
{
"type": "text",
"id": "author_name",
"label": "Author Name"
},
{
"type": "image_picker",
"id": "image",
"label": "Image"
}
]
}
],
"presets": [
{
"name": "Best Bio Available"
}
]
}
{% endschema %}
