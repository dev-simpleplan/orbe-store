<section class="see-through">
  <div class="container-left">
    <div class="see-through-in">
      <div class="st-struct-1">
        <div>
          <h2>{{ section.settings.heading }}</h2>
          <p>{{ section.settings.subheading }}</p>
        </div>
        <div>
          <img src="{{ section.settings.image_1 | img_url: 'master' }}" alt="{{ section.settings.image_1.alt | default: 'Image' }}" class="img">
        </div>
        <div></div>
      </div>
      <div class="st-struct-2">
        <div>
          <img src="{{ section.settings.image_2 | img_url: 'master' }}" alt="{{ section.settings.image_2.alt | default: 'Image' }}" class="img">
        </div>
        <div></div>
        <div>
          <img src="{{ section.settings.image_3 | img_url: 'master' }}" alt="{{ section.settings.image_3.alt | default: 'Image' }}" class="img">
        </div>
        <div>
          <img src="{{ section.settings.image_4 | img_url: 'master' }}" alt="{{ section.settings.image_4.alt | default: 'Image' }}" class="img">
        </div>
      </div>
      <div class="st-orbe-logo">
        <img src="{{ section.settings.orbe_logo | img_url: 'master' }}" alt="{{ section.settings.orbe_logo.alt | default: 'Logo' }}" class="img">
      </div>
    </div>
    <div class="st-struct-3">
      <div></div>
      <div>
        <img src="{{ section.settings.image_5 | img_url: 'master' }}" alt="{{ section.settings.image_5.alt | default: 'Image' }}" class="img">
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "See Through",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Seeing through the noise"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Because informed choices are powerful ones and you deserve both clarity and calm."
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Structure 1 — Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Structure 2 — Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Structure 2 — Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Structure 2 — Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Structure 3 — Image"
    },
    {
      "type": "image_picker",
      "id": "orbe_logo",
      "label": "Orbe Logo"
    }
  ],
  "presets": [
    {
      "name": "See Through"
    }
  ]
}
{% endschema %}