<section class="see-through">
  <div class="container-left">
    <div class="see-through-in">
      <div class="st-struct-1">
        <div>
          {% if section.settings.heading != blank %}
            <h2>{{ section.settings.heading }}</h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p>{{ section.settings.subheading }}</p>
          {% endif %}
        </div>
        <div class="st-media">
          {% if section.settings.image_1 != blank %}
            {{ section.settings.image_1 | image_url: width: 900 | image_tag: alt: '', class: 'img' }}
          {% endif %}
        </div>
        <div class="st-question">
          {% if section.settings.side_text != blank %}
            <p>{{ section.settings.side_text }}</p>
          {% endif %}
        </div>
      </div>
      <div class="st-struct-2">
        <div class="st-media">
          {% if section.settings.image_2 != blank %}
            {{ section.settings.image_2 | image_url: width: 500 | image_tag: alt: '', class: 'img' }}
          {% endif %}
        </div>
        <div></div>
        <div class="st-media">
          {% if section.settings.image_3 != blank %}
            {{ section.settings.image_3 | image_url: width: 500 | image_tag: alt: '', class: 'img' }}
          {% endif %}
        </div>
        <div class="st-media">
          {% if section.settings.image_4 != blank %}
            {{ section.settings.image_4 | image_url: width: 700 | image_tag: alt: '', class: 'img' }}
          {% endif %}
        </div>
      </div>
      <div class="st-orbe-logo">
        {% if section.settings.orbe_logo != blank %}
          {{ section.settings.orbe_logo | image_url: width: 500 | image_tag: alt: '', class: 'img' }}
        {% endif %}
      </div>
    </div>
    <div class="st-struct-3">
      <div></div>
      <div class="st-media">
        {% if section.settings.image_5 != blank %}
          {{ section.settings.image_5 | image_url: width: 800 | image_tag: alt: '', class: 'img' }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "See Through",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Seeing through the noise"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Because informed choices are powerful ones and you deserve both clarity and calm."
    },
    {
      "type": "textarea",
      "id": "side_text",
      "label": "Side Text"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Structure 1 — Image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Structure 2 — Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Structure 2 — Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Structure 2 — Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Structure 3 — Image"
    },
    {
      "type": "image_picker",
      "id": "orbe_logo",
      "label": "Orbe Logo"
    }
  ],
  "presets": [
    {
      "name": "See Through"
    }
  ]
}
{% endschema %}
