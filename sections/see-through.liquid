<section class="see-through">
  <div class="container-left">
    <div class="see-through-in">
      <div class="st-struct-1">
        <div>
          {% if section.settings.heading != blank %}
            <h2>{{ section.settings.heading }}</h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p>{{ section.settings.subheading }}</p>
          {% endif %}
        </div>
        <div class="st-media">
          {% render 'st-media', image: section.settings.image_1, video: section.settings.video_1, width: 900 %}
        </div>
        <div class="st-orbe-logo top">
          {% if section.settings.orbe_logo_top != blank %}
            {{ section.settings.orbe_logo_top | image_url: width: 500 | image_tag: alt: '', class: 'img' }}
          {% endif %}
        </div>
        <div class="st-question">
          {% if section.settings.side_text != blank %}
            <p>{{ section.settings.side_text }}</p>
          {% endif %}
        </div>
      </div>
      <div class="st-struct-2">
        <div class="st-media">
          {% render 'st-media', image: section.settings.image_2, video: section.settings.video_2, width: 500 %}
        </div>
        <div></div>
        <div class="st-media">
          {% render 'st-media', image: section.settings.image_3, video: section.settings.video_3, width: 500 %}
        </div>
        <div class="st-media">
          {% render 'st-media', image: section.settings.image_4, video: section.settings.video_4, width: 700 %}
        </div>
        <div class="st-orbe-logo bottom">
          {% if section.settings.orbe_logo_bottom != blank %}
            {{ section.settings.orbe_logo_bottom | image_url: width: 500 | image_tag: alt: '', class: 'img' }}
          {% endif %}
        </div>
      </div>
      {% comment %} <div class="st-orbe-logo">
        {% if section.settings.orbe_logo != blank %}
          {{ section.settings.orbe_logo | image_url: width: 500 | image_tag: alt: '', class: 'img' }}
        {% endif %}
      </div> {% endcomment %}
    </div>
    <div class="st-struct-3">
      <div></div>
      <div class="st-media">
        {% render 'st-media', image: section.settings.image_5, video: section.settings.video_5, width: 800 %}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('.see-through .st-video-wrap').forEach(function (wrap) {
      var video = wrap.querySelector('video');
      var btn = wrap.querySelector('.st-play');
      if (!video || !btn) return;

      function sync() {
        var playing = !video.paused && !video.ended;
        btn.classList.toggle('is-playing', playing);
        btn.setAttribute('aria-label', playing ? 'Pause' : 'Play');
      }

      btn.addEventListener('click', function () {
        if (video.paused || video.ended) {
          video.play();
        } else {
          video.pause();
        }
      });

      video.addEventListener('play', sync);
      video.addEventListener('pause', sync);
      sync();
    });
  })();
</script>

