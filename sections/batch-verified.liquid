<section class="batch-verified" data-batch-verified-section="{{ section.id }}">
  <div class="container">
    <div class="batch-verified-in">
      <div class="left">
        <div class="batch-v-img">
          <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/85519b51555456cb4d541782f2a6172fb3f7b481_1.png?v=1779867433" alt="Image" class="img">
        </div>
      </div>

      <div class="right">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}

        <div class="batch-varified-accordion">
          {% for block in section.blocks %}
            <div class="batch-varified-a-item{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
              <button
                type="button"
                class="batch-varified-a-title"
                aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
                <span>{{ block.settings.title }}</span>
                <span class="batch-varified-a-icon" aria-hidden="true"></span>
              </button>

              <div class="batch-varified-a-panel">
                <div class="batch-varified-a-content">
                  {% if block.settings.description != blank %}
                    <p>{{ block.settings.description }}</p>
                  {% endif %}

                  {% if block.settings.report_text != blank %}
                    <a href="{{ block.settings.report_link | default: '#!' }}" class="primary-btn">
                      {{ block.settings.report_text }}
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .batch-verified {
    padding: 0;
  }

  .batch-verified .batch-verified-in {
    display: grid;
    grid-template-columns: minmax(280px, 486px) minmax(320px, 1fr);
    align-items: start;
    gap: clamp(48px, 5vw, 60px);
  }

  .batch-verified .batch-v-img {
    width: 100%;
    aspect-ratio: 486 / 582;
    overflow: hidden;
  }

  .batch-verified .batch-v-img .img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .batch-verified .right {
    padding-top: 0;
  }

  .batch-verified h2 {
    max-width: 440px;
    margin: 0 0 34px;
    color: #151515;
    font-family: var(--tobias);
    font-size: clamp(42px, 4.4vw, 52px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .batch-verified .batch-varified-accordion {
    border-top: 0;
  }

  .batch-verified .batch-varified-a-item {
    border-bottom: 1px solid rgba(21, 21, 21, 0.18);
  }

  .batch-verified .batch-varified-a-title {
    width: 100%;
    min-height: 52px;
    padding: 0;
    border: 0;
    background: transparent;
    color: #151515;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    text-align: left;
    cursor: pointer;
    font-family: var(--tobias);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .batch-verified .batch-varified-a-icon {
    position: relative;
    width: 22px;
    height: 22px;
    flex: 0 0 22px;
  }

  .batch-verified .batch-varified-a-icon::before,
  .batch-verified .batch-varified-a-icon::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 22px;
    height: 1px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 0.32s ease, opacity 0.32s ease;
  }

  .batch-verified .batch-varified-a-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .batch-verified .batch-varified-a-item.active .batch-varified-a-icon::after {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(0deg);
  }

  .batch-verified .batch-varified-a-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: max-height;
  }

  .batch-verified .batch-varified-a-content {
    padding: 0 54px 30px 0;
  }

  .batch-verified .batch-varified-a-content p {
    max-width: 500px;
    margin: 0 0 24px;
    color: #151515;
    font-family: var(--aspekta);
    font-size: 12px;
    font-weight: 300;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .batch-verified .batch-varified-a-content .primary-btn {
    min-width: 158px;
    padding: 11px 26px;
    font-size: 12px;
  }

  @media (max-width: 989px) {
    .batch-verified .batch-verified-in {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .batch-verified .batch-v-img {
      max-width: 560px;
      margin: 0 auto;
    }
  }

  @media (max-width: 749px) {
    .batch-verified h2 {
      margin-bottom: 24px;
      font-size: 40px;
    }

    .batch-verified .batch-varified-a-title {
      min-height: 50px;
      font-size: 18px;
    }

    .batch-verified .batch-varified-a-content {
      padding-right: 34px;
    }
  }
</style>

<script>
  (function () {
    var section = document.querySelector('[data-batch-verified-section="{{ section.id }}"]');
    if (!section || section.dataset.batchVerifiedReady === 'true') return;

    var items = Array.prototype.slice.call(section.querySelectorAll('.batch-varified-a-item'));
    section.dataset.batchVerifiedReady = 'true';

    function setPanelHeight(item, isOpen) {
      var panel = item.querySelector('.batch-varified-a-panel');
      if (!panel) return;

      panel.style.maxHeight = isOpen ? panel.scrollHeight + 'px' : '0px';
    }

    function setItemState(item, isOpen) {
      item.classList.toggle('active', isOpen);
      setPanelHeight(item, isOpen);

      var button = item.querySelector('.batch-varified-a-title');
      if (button) button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    }

    items.forEach(function (item) {
      setPanelHeight(item, item.classList.contains('active'));
    });

    items.forEach(function (item) {
      var button = item.querySelector('.batch-varified-a-title');
      if (!button) return;

      button.addEventListener('click', function () {
        var wasOpen = item.classList.contains('active');

        items.forEach(function (accordionItem) {
          setItemState(accordionItem, false);
        });

        if (!wasOpen) setItemState(item, true);
      });
    });

    window.addEventListener('resize', function () {
      items.forEach(function (item) {
        if (item.classList.contains('active')) setPanelHeight(item, true);
      });
    });
  })();
</script>

