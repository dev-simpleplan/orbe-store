<section class="care-behind-c"
    {% if section.settings.background_image != blank %}
        style="background-image: url('{{ section.settings.background_image | image_url }}');"
    {% endif %}>
    <div class="container">
        <div class="heading text-animation">
            {% if section.settings.heading != blank %}
                <h2>{{ section.settings.heading }}</h2>
            {% endif %}
        </div>
        <div class="care-behind-c-in">
            <div class="left text-animation">
                <div class="text-block">
                    {% if section.settings.title_1 != blank %}
                        <h3>{{ section.settings.title_1 }}</h3>
                    {% endif %}
                    {% if section.settings.text_1 != blank %}
                        <p>{{ section.settings.text_1 }}</p>
                    {% endif %}
                </div>
                <div class="text-block">
                    {% if section.settings.title_2 != blank %}
                        <h3>{{ section.settings.title_2 }}</h3>
                    {% endif %}
                    {% if section.settings.text_2 != blank %}
                        <p>{{ section.settings.text_2 }}</p>
                    {% endif %}
                </div>
            </div>
            <div class="center">
                <div class="pill-img">
                    {% if section.settings.capsule_image != blank %}
                        {{ section.settings.capsule_image | image_url: width: 900 | image_tag: alt: '', class: 'icon' }}
                    {% endif %}
                </div>
            </div>
            <div class="right text-animation">
                <div class="text-block">
                    {% if section.settings.title_3 != blank %}
                        <h3>{{ section.settings.title_3 }}</h3>
                    {% endif %}
                    {% if section.settings.text_3 != blank %}
                        <p>{{ section.settings.text_3 }}</p>
                    {% endif %}
                </div>
                <div class="text-block">
                    {% if section.settings.title_4 != blank %}
                        <h3>{{ section.settings.title_4 }}</h3>
                    {% endif %}
                    {% if section.settings.text_4 != blank %}
                        <p>{{ section.settings.text_4 }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Care Behind Capsule",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "image_picker",
      "id": "capsule_image",
      "label": "Capsule Image"
    },
    {
      "type": "header",
      "content": "Point 1"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Point 2"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Point 3"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "text_3",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Point 4"
    },
    {
      "type": "text",
      "id": "title_4",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "text_4",
      "label": "Text"
    }
  ],
  "presets": [
    {
      "name": "Care Behind Capsule"
    }
  ]
}
{% endschema %}
