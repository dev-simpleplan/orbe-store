<section class="about-banner" id="about-banner-{{ section.id }}">
  <div class="container">
    <div class="about-banner-stage">
      <div class="about-banner-img">
        {% if section.settings.hero_logo != blank %}
          <img src="{{ section.settings.hero_logo | image_url }}" alt="" class="icon about-banner-logo">
        {% endif %}
        {% if section.settings.hero_image != blank %}
          <img src="{{ section.settings.hero_image | image_url }}" alt="" class="img about-banner-hero-image">
        {% endif %}
        <span class="about-banner-strip">
          <span class="about-banner-mobile-copy">
            {% if section.settings.heading != blank %}
              <span class="about-banner-mobile-heading">{{ section.settings.heading }}</span>
            {% endif %}
            {% if section.settings.description != blank %}
              <span class="about-banner-mobile-text">{{ section.settings.description }}</span>
            {% endif %}
          </span>
        </span>
      </div>
      <div class="about-banner-split" aria-hidden="true">
        <div class="about-banner-split-panel about-banner-split-top">
          {% if section.settings.hero_image != blank %}
            <img src="{{ section.settings.hero_image | image_url }}" alt="" class="img about-banner-split-from">
          {% endif %}
          {% if section.settings.left_img_1 != blank %}
            <img src="{{ section.settings.left_img_1 | image_url }}" alt="" class="img about-banner-split-to">
          {% elsif section.settings.hero_image != blank %}
            <img src="{{ section.settings.hero_image | image_url }}" alt="" class="img about-banner-split-to">
          {% endif %}
        </div>
        <div class="about-banner-split-panel about-banner-split-bottom">
          {% if section.settings.hero_image != blank %}
            <img src="{{ section.settings.hero_image | image_url }}" alt="" class="img about-banner-split-from">
          {% endif %}
          {% if section.settings.left_img_2 != blank %}
            <img src="{{ section.settings.left_img_2 | image_url }}" alt="" class="img about-banner-split-to">
          {% elsif section.settings.hero_image != blank %}
            <img src="{{ section.settings.hero_image | image_url }}" alt="" class="img about-banner-split-to">
          {% endif %}
        </div>
      </div>
      <div class="about-banner-in">
        <!-- LEFT IMAGES -->
        <div class="left">
          <div class="ab-img-1 ab-reveal-block">
            {% if section.settings.left_img_1 != blank %}
              <img src="{{ section.settings.left_img_1 | image_url }}" alt="" class="img">
            {% endif %}
          </div>

          <div class="ab-img-2 ab-reveal-block">
            {% if section.settings.left_img_2 != blank %}
              <img src="{{ section.settings.left_img_2 | image_url }}" alt="" class="img">
            {% endif %}
          </div>
        </div>
        <!-- RIGHT CONTENT -->
        <div class="right">

          <div class="right-top">
            <div class="abrt-left">

              <div class="abrt-img ab-reveal-block">
                {% if section.settings.top_right_img != blank %}
                  <img src="{{ section.settings.top_right_img | image_url }}" alt="" class="img">
                {% endif %}
              </div>

              {% if section.settings.heading != blank %}
                <div class="abrt-text ab-reveal-block">
                  <h1>{{ section.settings.heading }}</h1>
                </div>
              {% endif %}

            </div>
          </div>
          <div class="right-bottom">
            <div class="abrt-right">
              {% if section.settings.description != blank %}
                <div class="abrt-text ab-reveal-block">
                  <p>{{ section.settings.description }}</p>
                </div>
              {% endif %}

              <div class="abrt-img ab-reveal-block">
                {% if section.settings.bottom_right_img != blank %}
                  <img src="{{ section.settings.bottom_right_img | image_url }}" alt="" class="img">
                {% endif %}
              </div>

            </div>
          </div>

        </div>

      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    function init() {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        setTimeout(init, 100);
        return;
      }

      gsap.registerPlugin(ScrollTrigger);

      const section = document.getElementById('about-banner-{{ section.id }}');
      if (!section) return;

      const hero = section.querySelector('.about-banner-img');
      const logo = section.querySelector('.about-banner-logo');
      const heroImage = section.querySelector('.about-banner-hero-image');
      const strip = section.querySelector('.about-banner-strip');
      const mobileCopy = section.querySelector('.about-banner-mobile-copy');
      const split = section.querySelector('.about-banner-split');
      const splitPanels = section.querySelectorAll('.about-banner-split-panel');
      const splitFromImages = section.querySelectorAll('.about-banner-split-from');
      const splitToImages = section.querySelectorAll('.about-banner-split-to');
      const grid = section.querySelector('.about-banner-in');
      const leftCol = section.querySelector('.about-banner-in .left');
      const blocks = section.querySelectorAll('.ab-reveal-block');
      const leftBlocks = section.querySelectorAll('.about-banner-in .left .ab-reveal-block');
      const rightBlocks = section.querySelectorAll('.about-banner-in .right .ab-reveal-block');
      const splitGap = 40;

      const mm = gsap.matchMedia();

      mm.add('(min-width: 992px)', () => {
        gsap.set(hero, {
          width: '100%',
          height: '800px',
          yPercent: -50,
          autoAlpha: 1,
          clipPath: 'inset(0% 0% 0% 0%)',
        });
        if (logo) gsap.set(logo, { autoAlpha: 0, scale: 0.92 });
        gsap.set(strip, { autoAlpha: 1, scaleX: 0, transformOrigin: 'left center' });
        gsap.set(split, { autoAlpha: 0, width: '100%', height: '800px', gap: splitGap, yPercent: -50 });
        gsap.set(splitPanels, { clipPath: 'inset(0% 0% 0% 0%)' });
        gsap.set(splitFromImages, { autoAlpha: 1, scale: 1 });
        gsap.set(splitToImages, { autoAlpha: 0, scale: 1.04 });
        gsap.set(grid, { autoAlpha: 1 });
        gsap.set(blocks, { autoAlpha: 0, y: 70, clipPath: 'inset(18% 0% 18% 0%)' });
        gsap.set(leftBlocks, { y: 0, clipPath: 'inset(0% 0% 0% 0%)' });

        const getLeftColumnSize = () => {
          const bounds = leftCol.getBoundingClientRect();
          return {
            width: bounds.width,
            height: bounds.height,
          };
        };

        const getLeftColumnGap = () => parseFloat(getComputedStyle(leftCol).rowGap) || splitGap;

        const tl = gsap.timeline({
          paused: true,
          defaults: { ease: 'power2.inOut' },
        });

        if (logo) tl.to(logo, { autoAlpha: 1, scale: 1, ease: 'power2.out', duration: 0.45 }, 0.15);
        tl.to(strip, { scaleX: 1, ease: 'power3.inOut', duration: 0.95 }, 0.72);
        if (logo) tl.to(logo, { autoAlpha: 0, scale: 0.98, ease: 'power2.inOut', duration: 0.5 }, 1.12);
        tl.to(split, { autoAlpha: 1, ease: 'power2.out', duration: 0.5 }, 1.6);
        tl.to(hero, { autoAlpha: 0, ease: 'power2.inOut', duration: 0.65 }, 1.68);
        tl.to(split, {
          width: () => getLeftColumnSize().width,
          height: () => getLeftColumnSize().height,
          gap: () => getLeftColumnGap(),
          yPercent: -50,
          ease: 'expo.inOut',
          duration: 2.05,
        }, 1.92);
        tl.to(splitFromImages, {
          autoAlpha: 0,
          scale: 1.01,
          ease: 'sine.inOut',
          duration: 1.9,
        }, 2.08);
        tl.to(splitToImages, {
          autoAlpha: 1,
          scale: 1,
          ease: 'sine.inOut',
          duration: 1.9,
        }, 2.08);
        tl.to(rightBlocks, {
          autoAlpha: 1,
          y: 0,
          clipPath: 'inset(0% 0% 0% 0%)',
          ease: 'power3.out',
          duration: 1.25,
          stagger: 0.18,
        }, 3.82);
        tl.set(leftBlocks, { autoAlpha: 1 }, 4.35);
        tl.to(split, { autoAlpha: 0, ease: 'power2.inOut', duration: 0.8 }, 4.45);

        const trigger = ScrollTrigger.create({
          trigger: section,
          start: 'top 65%',
          once: true,
          onEnter: () => tl.play(),
        });

        return () => {
          trigger.kill();
          tl.kill();
        };
      });

      mm.add('(max-width: 991px)', () => {
        const mobileGap = 16;

        gsap.set(hero, {
          width: '100%',
          height: 'min(70svh, 720px)',
          yPercent: -50,
          autoAlpha: 1,
          clipPath: 'inset(0% 0% 0% 0%)',
        });
        if (logo) gsap.set(logo, { autoAlpha: 0, scale: 0.86 });
        gsap.set(strip, { autoAlpha: 1, height: mobileGap, scaleX: 0, transformOrigin: 'left center' });
        gsap.set(mobileCopy, { autoAlpha: 0, y: 16 });
        gsap.set(split, {
          autoAlpha: 0,
          width: '100%',
          height: 'min(70svh, 720px)',
          gap: mobileGap,
          yPercent: -50,
        });
        gsap.set(splitPanels, { clipPath: 'inset(0% 0% 0% 0%)' });
        gsap.set(splitFromImages, { autoAlpha: 1, scale: 1 });
        gsap.set(splitToImages, { autoAlpha: 0, scale: 1 });
        gsap.set(grid, { autoAlpha: 1 });
        gsap.set(leftBlocks, { autoAlpha: 0 });
        gsap.set(rightBlocks, { autoAlpha: 0 });

        const tl = gsap.timeline({
          paused: true,
          defaults: { ease: 'power2.inOut' },
        });

        if (logo) tl.to(logo, { autoAlpha: 1, scale: 1, ease: 'power2.out', duration: 0.55 }, 0.25);
        tl.to(strip, { scaleX: 1, ease: 'power3.inOut', duration: 0.9 }, 1.05);
        if (logo) tl.to(logo, { scale: 1.03, ease: 'power2.inOut', duration: 0.55 }, 1.18);
        tl.to(split, { autoAlpha: 1, ease: 'power2.out', duration: 0.45 }, 1.82);
        if (heroImage) tl.to(heroImage, { autoAlpha: 0, ease: 'power2.inOut', duration: 0.55 }, 1.9);
        tl.to(split, {
          height: 'min(90svh, 900px)',
          ease: 'expo.inOut',
          duration: 1.25,
        }, 2.2);
        tl.to(strip, {
          height: 'clamp(150px, 28svh, 220px)',
          ease: 'expo.inOut',
          duration: 1.25,
        }, 2.2);
        if (logo) tl.to(logo, { autoAlpha: 0, scale: 0.98, ease: 'power2.inOut', duration: 0.45 }, 2.45);
        tl.to(mobileCopy, { autoAlpha: 1, y: 0, ease: 'power3.out', duration: 0.75 }, 2.75);
        tl.to(splitToImages, { autoAlpha: 1, ease: 'power2.inOut', duration: 0.6 }, 2.75);
        tl.to(splitFromImages, { autoAlpha: 0, ease: 'power2.inOut', duration: 0.6 }, 2.75);

        const trigger = ScrollTrigger.create({
          trigger: section,
          start: 'top 72%',
          once: true,
          onEnter: () => tl.play(),
        });

        return () => {
          trigger.kill();
          tl.kill();
        };
      });
    }

    init();
  })();
</script>

{% schema %}
{
  "name": "About Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_logo",
      "label": "Hero logo"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "left_img_1",
      "label": "Left Image 1"
    },
    {
      "type": "image_picker",
      "id": "left_img_2",
      "label": "Left Image 2"
    },
    {
      "type": "image_picker",
      "id": "top_right_img",
      "label": "Top Right Image"
    },
    {
      "type": "image_picker",
      "id": "bottom_right_img",
      "label": "Bottom Right Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    }

  ],
  "presets": [
    {
      "name": "About Banner"
    }
  ]
}
{% endschema %}
