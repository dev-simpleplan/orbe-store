<section class="behind-every-choice">
  <div class="bec-bg-logo">
    {% render 'orbe-logo-o' %}
  </div>

  <div class="container">
    <div class="behind-every-choice-in">
      <div class="left">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <p>{{ section.settings.text }}</p>
        {% endif %}
      </div>

      <div class="right">
        <div class="bec-slider">
          {% for block in section.blocks %}
            <div class="bec-slide{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
              <div class="bec-stars">
                {% for i in (1..5) %}
                  {% if i <= block.settings.rating %}
                    {% render 'rating-star' %}
                  {% endif %}
                {% endfor %}
              </div>
              <h3>{{ block.settings.quote }}</h3>
              <div class="bec-author">
                <span class="bec-avatar">
                  {% if block.settings.author_image != blank %}
                    <img src="{{ block.settings.author_image | image_url: width: 80 }}" alt="{{ block.settings.author | escape }}" width="40" height="40" loading="lazy">
                  {% endif %}
                </span>
                <p>{{ block.settings.author }}</p>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="bec-controls">
          <button class="bec-prev" type="button" aria-label="Previous testimonial">
            <svg width="43" height="43" viewBox="0 0 43 43" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="21.3472" cy="21.3472" r="21.3472" transform="matrix(-1 0 0 1 42.6943 0)" fill="currentColor"/>
              <path d="M30.0313 20.8421L17.665 20.8421L22.9648 15.5423L22.2985 14.7852L15.7368 21.3469L22.2985 27.9086L22.9648 27.1515L17.665 21.8516L30.0313 21.8516L30.0313 20.8421Z" fill="white"/>
            </svg>
          </button>
          <button class="bec-next" type="button" aria-label="Next testimonial">
            <svg width="43" height="43" viewBox="0 0 43 43" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="21.3472" cy="21.3472" r="21.3472" fill="currentColor"/>
              <path d="M12.663 20.8421L25.0294 20.8421L19.7295 15.5423L20.3958 14.7852L26.9575 21.3469L20.3958 27.9086L19.7295 27.1515L25.0294 21.8516L12.663 21.8516L12.663 20.8421Z" fill="white"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="bec-ticker" aria-hidden="true">
    <div class="bec-ticker-track">
      {% for i in (1..4) %}
        {% assign img_id = 'ticker_image_' | append: i %}
        {% assign img = section.settings[img_id] %}
        {% if img != blank %}
          <span><img src="{{ img | image_url: width: 200 }}" alt="" width="100" height="40" loading="lazy"></span>
        {% endif %}
      {% endfor %}
      {% for i in (1..4) %}
        {% assign img_id = 'ticker_image_' | append: i %}
        {% assign img = section.settings[img_id] %}
        {% if img != blank %}
          <span><img src="{{ img | image_url: width: 200 }}" alt="" width="100" height="40" loading="lazy"></span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
  (function () {
    function init() {
      const script = document.currentScript;
      const section = script ? script.previousElementSibling : document.querySelector('.behind-every-choice');
      if (!section) return;

      const slides = section.querySelectorAll('.bec-slide');
      const prev = section.querySelector('.bec-prev');
      const next = section.querySelector('.bec-next');
      if (!slides.length || !prev || !next) return;

      let activeIndex = 0;

      function showSlide(index) {
        activeIndex = (index + slides.length) % slides.length;

        slides.forEach(function (slide, slideIndex) {
          slide.classList.toggle('active', slideIndex === activeIndex);
        });
      }

      prev.addEventListener('click', function () {
        showSlide(activeIndex - 1);
      });

      next.addEventListener('click', function () {
        showSlide(activeIndex + 1);
      });
    }

    init();
  })();
</script>

{% schema %}
{
