{% comment %}
  Product page — sticky image gallery + purchase panel.
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign has_selling_plans = false -%}
{%- if product.selling_plan_groups.size > 0 -%}
  {%- assign has_selling_plans = true -%}
{%- endif -%}

<section class="pdp" id="pdp-{{ section.id }}" data-pdp>
  <div class="container">
    <div class="pdp-grid">

      <!-- ============ GALLERY ============ -->
      <div class="pdp-gallery">
        {% for image in product.images %}
          <div class="pdp-gallery-item">
            {%- assign img_alt = image.alt | default: product.title | escape -%}
            {{ image | image_url: width: 1200 | image_tag: alt: img_alt, class: 'pdp-gallery-img', loading: 'lazy' }}
          </div>
        {% else %}
          <div class="pdp-gallery-item pdp-gallery-item--placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'pdp-gallery-img' }}
          </div>
        {% endfor %}
      </div>

      <!-- ============ INFO ============ -->
      <div class="pdp-info">
        <div class="pdp-info-inner">

          {% if section.settings.show_rating %}
            <div class="pdp-rating">
              <span class="pdp-stars" aria-label="{{ section.settings.rating_value }} out of 5 stars">
                {% assign filled = section.settings.rating_value %}
                {% for i in (1..5) %}
                  <svg viewBox="0 0 24 24" width="16" height="16" class="pdp-star {% if i <= filled %}is-filled{% endif %}" aria-hidden="true">
                    <path d="M12 2l2.9 6.26 6.1.53-4.6 4.02 1.36 6.19L12 15.9l-5.76 3.1 1.36-6.19-4.6-4.02 6.1-.53z"/>
                  </svg>
                {% endfor %}
              </span>
              {% if section.settings.reviews_text != blank %}
                <span class="pdp-reviews">{{ section.settings.reviews_text }}</span>
              {% endif %}
            </div>
          {% endif %}

          <h1 class="pdp-title">{{ product.title }}</h1>

          {% if product.description != blank %}
            <div class="pdp-desc">{{ product.description }}</div>
          {% endif %}

          <div class="pdp-price">
            <span class="pdp-price-current" data-price>{{ current_variant.price | money }}</span>
          </div>

          {% if section.settings.supply_text != blank %}
            <p class="pdp-supply">{{ section.settings.supply_text }}</p>
          {% endif %}

          {% form 'product', product, id: 'pdp-form', class: 'pdp-form', novalidate: 'novalidate' %}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

            <!-- Purchase options -->
            <div class="pdp-options" data-options>
              <label class="pdp-option is-active" data-option>
                <input type="radio" name="selling_plan" value="" checked data-plan-price="{{ current_variant.price }}">
                <span class="pdp-option-radio" aria-hidden="true"></span>
                <span class="pdp-option-label">{{ section.settings.onetime_label }}</span>
                <span class="pdp-option-price">{{ current_variant.price | money }}</span>
              </label>

              {% if has_selling_plans %}
                {% for group in product.selling_plan_groups %}
                  {% for plan in group.selling_plans %}
                    {%- assign allocation = false -%}
                    {%- for a in current_variant.selling_plan_allocations -%}
                      {%- if a.selling_plan.id == plan.id -%}
                        {%- assign allocation = a -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- if allocation -%}
                      <label class="pdp-option" data-option>
                        <input type="radio" name="selling_plan" value="{{ plan.id }}" data-plan-price="{{ allocation.price }}">
                        <span class="pdp-option-radio" aria-hidden="true"></span>
                        <span class="pdp-option-label">{{ group.name | default: plan.name }}</span>
                        {%- assign saving = current_variant.price | minus: allocation.price -%}
                        {%- if saving > 0 -%}
                          {%- assign pct = saving | times: 100.0 | divided_by: current_variant.price | round -%}
                          <span class="pdp-option-save">Save {{ pct }}%</span>
                        {%- endif -%}
                        <span class="pdp-option-price">{{ allocation.price | money }}</span>
                        {% if group.name != blank %}
                          <span class="pdp-option-sub">{{ section.settings.subscription_sub }}</span>
                        {% endif %}
                      </label>
                    {%- endif -%}
                  {% endfor %}
                {% endfor %}
              {% endif %}
            </div>

            <!-- Targets (from product tags) -->
            {%- assign prefix = section.settings.target_prefix -%}
            {%- assign target_tags = '' -%}
            {%- for tag in product.tags -%}
              {%- if prefix != blank -%}
                {%- if tag contains prefix -%}
                  {%- assign clean = tag | remove_first: prefix | strip -%}
                  {%- assign target_tags = target_tags | append: clean | append: '|' -%}
                {%- endif -%}
              {%- else -%}
                {%- assign target_tags = target_tags | append: tag | append: '|' -%}
              {%- endif -%}
            {%- endfor -%}
            {%- assign target_list = target_tags | split: '|' -%}
            {% if target_list.size > 0 %}
              <div class="pdp-targets">
                <p class="pdp-targets-label">{{ section.settings.targets_label }}</p>
                <div class="pdp-targets-list">
                  {% for tag in target_list %}
                    <span class="pdp-target">{{ tag }}</span>
                  {% endfor %}
                </div>
              </div>
            {% endif %}

            <!-- Quantity + Add to cart -->
            <div class="pdp-buy">
              <div class="pdp-qty" data-qty>
                <button type="button" class="pdp-qty-btn" data-qty-minus aria-label="Decrease quantity">&minus;</button>
                <input type="text" inputmode="numeric" name="quantity" value="1" class="pdp-qty-input" data-qty-input aria-label="Quantity">
                <button type="button" class="pdp-qty-btn" data-qty-plus aria-label="Increase quantity">+</button>
              </div>
              <button type="submit" class="pdp-add-btn primary-btn" {% unless current_variant.available %}disabled{% endunless %}>
                {% if current_variant.available %}{{ section.settings.add_button_text }}{% else %}{{ section.settings.sold_out_text }}{% endif %}
              </button>
            </div>
          {% endform %}

          <!-- Trust: safe checkout -->
          {% if section.settings.show_checkout_badges %}
            <div class="pdp-checkout">
              <p class="pdp-checkout-label">{{ section.settings.checkout_label }}</p>
              <div class="pdp-checkout-icons">
                {% for type in shop.enabled_payment_types %}
                  {{ type | payment_type_svg_tag: class: 'pdp-pay-icon' }}
                {% endfor %}
              </div>
            </div>
          {% endif %}

          <!-- Perks -->
          {% if section.settings.perks != blank %}
            <ul class="pdp-perks">
              {% assign perks = section.settings.perks | newline_to_br | split: '<br />' %}
              {% for perk in perks %}
                {% assign p = perk | strip %}
                {% if p != blank %}<li>{{ p }}</li>{% endif %}
              {% endfor %}
            </ul>
          {% endif %}

          <!-- Accordions -->
          {% assign acc_blocks = section.blocks | where: 'type', 'collapsible' %}
          {% if acc_blocks.size > 0 %}
            <div class="pdp-accordion" data-accordion>
              {% for block in acc_blocks %}
                {%- assign mf_value = blank -%}
                {%- assign mf_key = block.settings.metafield_key | strip -%}
                {%- if mf_key contains '.' -%}
                  {%- assign mf_parts = mf_key | split: '.' -%}
                  {%- assign mf_value = product.metafields[mf_parts[0]][mf_parts[1]] -%}
                {%- endif -%}
                <div class="pdp-acc-item" {{ block.shopify_attributes }}>
                  <button type="button" class="pdp-acc-head" aria-expanded="false">
                    <span>{{ block.settings.title }}</span>
                    <span class="pdp-acc-icon" aria-hidden="true"></span>
                  </button>
                  <div class="pdp-acc-body">
                    <div class="pdp-acc-content">
                      {%- if mf_value != blank -%}{{ mf_value | metafield_tag }}{%- else -%}{{ block.settings.content }}{%- endif -%}
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}

        </div>
      </div>

    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('pdp-{{ section.id }}');
    if (!root) return;

    // Quantity stepper
    var qtyInput = root.querySelector('[data-qty-input]');
    root.querySelectorAll('[data-qty-minus]').forEach(function (b) {
      b.addEventListener('click', function () {
        var v = Math.max(1, (parseInt(qtyInput.value, 10) || 1) - 1);
        qtyInput.value = v;
      });
    });
    root.querySelectorAll('[data-qty-plus]').forEach(function (b) {
      b.addEventListener('click', function () {
        var v = Math.max(1, (parseInt(qtyInput.value, 10) || 1) + 1);
        qtyInput.value = v;
      });
    });
    qtyInput && qtyInput.addEventListener('input', function () {
      this.value = this.value.replace(/[^0-9]/g, '');
    });

    // Purchase option selection + price swap
    var priceEl = root.querySelector('[data-price]');
    var options = root.querySelectorAll('[data-option]');
    options.forEach(function (opt) {
      var input = opt.querySelector('input[type="radio"]');
      input && input.addEventListener('change', function () {
        options.forEach(function (o) { o.classList.remove('is-active'); });
        opt.classList.add('is-active');
        var priceStr = opt.querySelector('.pdp-option-price');
        if (priceEl && priceStr) priceEl.textContent = priceStr.textContent;
      });
    });

    // Accordion
    var accItems = root.querySelectorAll('.pdp-acc-item');
    accItems.forEach(function (item) {
      var head = item.querySelector('.pdp-acc-head');
      var body = item.querySelector('.pdp-acc-body');
      head.addEventListener('click', function () {
        var isOpen = item.classList.contains('is-open');
        if (isOpen) {
          item.classList.remove('is-open');
          head.setAttribute('aria-expanded', 'false');
          body.style.maxHeight = null;
        } else {
          item.classList.add('is-open');
          head.setAttribute('aria-expanded', 'true');
          body.style.maxHeight = body.scrollHeight + 'px';
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating",
      "default": true
    },
    {
      "type": "range",
      "id": "rating_value",
      "label": "Stars filled",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "reviews_text",
      "label": "Reviews text",
      "default": "200+ Reviews"
    },
    {
      "type": "header",
      "content": "Purchase options"
    },
    {
      "type": "text",
      "id": "supply_text",
      "label": "Supply line",
      "default": "30 Days: 60 N Capsules"
    },
    {
      "type": "text",
      "id": "onetime_label",
      "label": "One-time label",
      "default": "One Time Purchase"
    },
    {
      "type": "text",
      "id": "subscription_sub",
      "label": "Subscription subtitle",
      "default": "Subscribe for a simpler routine delivered effortlessly every month."
    },
    {
      "type": "header",
      "content": "Targets"
    },
    {
      "type": "text",
      "id": "targets_label",
      "label": "Targets label",
      "default": "Targets:"
    },
    {
      "type": "text",
      "id": "target_prefix",
      "label": "Tag prefix (optional)",
      "info": "Leave blank to show all product tags. Set e.g. 'target:' to only show tags like 'target:Sleep' (prefix is hidden on the page)."
    },
    {
      "type": "header",
      "content": "Add to cart"
    },
    {
      "type": "text",
      "id": "add_button_text",
      "label": "Button text",
      "default": "Add to cart"
    },
    {
      "type": "text",
      "id": "sold_out_text",
      "label": "Sold out text",
      "default": "Sold out"
    },
    {
      "type": "header",
      "content": "Trust"
    },
    {
      "type": "checkbox",
      "id": "show_checkout_badges",
      "label": "Show safe checkout badges",
      "default": true
    },
    {
      "type": "text",
      "id": "checkout_label",
      "label": "Checkout label",
      "default": "Guaranteed Safe Checkout With"
    },
    {
      "type": "textarea",
      "id": "perks",
      "label": "Perks (one per line)",
      "default": "Free shipping on all orders\nSecure checkout\nExclusive D2C savings"
    }
  ],
  "blocks": [
    {
      "type": "collapsible",
      "name": "Accordion row",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Why Orbe"
        },
        {
          "type": "text",
          "id": "metafield_key",
          "label": "Metafield key",
          "info": "e.g. custom.why_orbe — pulls this row's content from the product metafield so it can differ per product. Falls back to the content below if empty or unset."
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Fallback content",
          "default": "<p>Add your content here.</p>"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "Product",
      "blocks": [
        { "type": "collapsible", "settings": { "title": "Why Orbe" } },
        { "type": "collapsible", "settings": { "title": "Ingredients" } },
        { "type": "collapsible", "settings": { "title": "Nutrition Profile" } },
        { "type": "collapsible", "settings": { "title": "How To Use" } }
      ]
    }
  ]
}
{% endschema %}
