<section class="heart-behind">
  <div class="container">
    <div class="heart-behind-in">

      <div class="left">

        <div class="hb-top">
          <div>
            {% if section.settings.top_image_1 != blank %}
              <img src="{{ section.settings.top_image_1 | image_url }}" alt="Image" class="img">
            {% endif %}
          </div>
          <div>
            {% if section.settings.top_image_2 != blank %}
              <img src="{{ section.settings.top_image_2 | image_url }}" alt="Image" class="img">
            {% endif %}
          </div>
        </div>

        <div class="hb-bottom">
          <h2>{{ section.settings.heading }}</h2>

          {% if section.settings.text_1 != blank %}
            <p>{{ section.settings.text_1 }}</p>
          {% endif %}

          {% if section.settings.text_2 != blank %}
            <p>{{ section.settings.text_2 }}</p>
          {% endif %}

          {% if section.settings.text_3 != blank %}
            <p>{{ section.settings.text_3 }}</p>
          {% endif %}
        </div>

      </div>

      <div class="right">
        {% if section.settings.right_image != blank %}
          <img src="{{ section.settings.right_image | image_url }}" alt="Image" class="img">
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Heart Behind Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "top_image_1",
      "label": "Top Image 1"
    },
    {
      "type": "image_picker",
      "id": "top_image_2",
      "label": "Top Image 2"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Heart Behind Orbé"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Paragraph 1",
      "default": "Orbe began with a simple but powerful frustration: why does taking care of ourselves feel so complicated?"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Paragraph 2",
      "default": "Women feel overwhelmed by noise, conflicting advice, and wellness trends that offer more confusion than clarity. So we set out to create something different; a brand built on intention, rooted in evidence, and guided by simplicity."
    },
    {
      "type": "textarea",
      "id": "text_3",
      "label": "Paragraph 3",
      "default": "Orbe is the answer to a question women have been asking for years: What if feeling well could feel simple?"
    }
  ],
  "presets": [
    {
      "name": "Heart Behind Section"
    }
  ]
}
{% endschema %}