<section class="standard-that-speaks">
    <div class="container">
        <div class="heading">
            <h2>{{ section.settings.heading }}</h2>
            <p>{{ section.settings.description }}</p>
        </div>
        <div class="standard-that-speaks-in">
            <div class="center-ring">
                {% if section.blocks.size > 0 %}
                    {% for block in section.blocks limit: 6 %}
                        {% case forloop.index %}
                            {% when 1 %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/a456ca26b0e9b0f7bd557e46fac0239b4fb25bfd_1.png?v=1777901848' %}
                            {% when 2 %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/37ac90a8325a2eb5fb7dcc774ce97dcf06f2caae.png?v=1777901848' %}
                            {% when 3 %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/9c14938d24fac2e401e48d5fd699111e852d73d0.png?v=1777901848' %}
                            {% when 4 %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/9535738d3cadb555d7a157419abec5eaee44b597_1.png?v=1777901552' %}
                            {% when 5 %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/cb528a057874ed1960709ef4ccbdb9d1d937fafd_1.png?v=1777901552' %}
                            {% else %}
                                {% assign default_image = 'https://cdn.shopify.com/s/files/1/0739/8014/9916/files/c1a59def97b3f3bff6c226dadac007d718ed7033_1.png?v=1777901552' %}
                        {% endcase %}
                        <div class="standard-ring-item standard-ring-item-{{ forloop.index }}" {{ block.shopify_attributes }}>
                            <div class="standard-ring-item-inner">
                                {% if block.settings.image != blank %}
                                    <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.title | escape }}" class="img">
                                {% elsif block.settings.fallback_image != blank %}
                                    <img src="{{ block.settings.fallback_image }}" alt="{{ block.settings.title | escape }}" class="img">
                                {% else %}
                                    <img src="{{ default_image }}" alt="{{ block.settings.title | escape }}" class="img">
                                {% endif %}
                                <span>{{ block.settings.title }}</span>
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="standard-ring-item standard-ring-item-1">
                        <div class="standard-ring-item-inner">
                            <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/a456ca26b0e9b0f7bd557e46fac0239b4fb25bfd_1.png?v=1777901848" alt="Clean-label commitments" class="img">
                            <span>Clean-label<br>commitments</span>
                        </div>
                    </div>
                    <div class="standard-ring-item standard-ring-item-2">
                        <div class="standard-ring-item-inner">
                            <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/37ac90a8325a2eb5fb7dcc774ce97dcf06f2caae.png?v=1777901848" alt="Third-party testing" class="img">
                            <span>Third-party<br>testing</span>
                        </div>
                    </div>
                    <div class="standard-ring-item standard-ring-item-3">
                        <div class="standard-ring-item-inner">
                            <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/9c14938d24fac2e401e48d5fd699111e852d73d0.png?v=1777901848" alt="Vegan-certified capsules" class="img">
                            <span>Vegan-certified<br>capsules</span>
                        </div>
                    </div>
                    <div class="standard-ring-item standard-ring-item-4">
                        <div class="standard-ring-item-inner">
                            <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/9535738d3cadb555d7a157419abec5eaee44b597_1.png?v=1777901552" alt="Ingredient traceability" class="img">
                            <span>Ingredient<br>traceability</span>
                        </div>
                    </div>
                    <div class="standard-ring-item standard-ring-item-5">
                        <div class="standard-ring-item-inner">
                            <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/cb528a057874ed1960709ef4ccbdb9d1d937fafd_1.png?v=1777901552" alt="Batch-level transparency" class="img">
                            <span>Batch-Level<br>Transparency</span>
                        </div>
                    </div>
                    <div class="standard-ring-item standard-ring-item-6">
                        <div class="standard-ring-item-inner">
                            <img src="https://cdn.shopify.com/s/files/1/0739/8014/9916/files/c1a59def97b3f3bff6c226dadac007d718ed7033_1.png?v=1777901552" alt="GMP-certified facilities" class="img">
                            <span>GMP-certified<br>facilities</span>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Standards That Speaks",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Standards that speaks for themselves"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Because informed choices are powerful ones and you deserve both clarity and calm."
    }
  ],
  "blocks": [
    {
      "type": "standard",
      "name": "Standard",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Text",
          "default": "Clean-label commitments"
        },
        {
          "type": "url",
          "id": "fallback_image",
          "label": "Fallback image URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Standards That Speaks"
    }
  ]
}
{% endschema %}
