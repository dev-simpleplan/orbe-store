<section class="certified-by">
    <div class="certified-by-in">
        {% if section.settings.heading != blank %}
            <div class="container">
                <p class="slider-heading">{{ section.settings.heading }}</p>
            </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
            <div class="certified-by-slider">
                {% for block in section.blocks %}
                    {% liquid
                        assign block_image = block.settings.image
                        assign block_alt = block.settings.alt | default: section.settings.heading | escape
                    %}

                    {% if block_image != blank %}
                        <div class="cbs-item" {{ block.shopify_attributes }}>
                            <img
                                src="{{ block_image | image_url: width: 340 }}"
                                alt="{{ block_alt }}"
                                width="170"
                                height="200"
                                loading="lazy"
                            >
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

<script>
    (function () {
        function readyCertifiedBySlider(root, attempts) {
            attempts = attempts || 30;

            if (!window.jQuery || !jQuery.fn.bxSlider) {
                if (attempts > 0) setTimeout(function () { readyCertifiedBySlider(root, attempts - 1); }, 100);
                return;
            }

            jQuery(root).find('.certified-by-slider').addBack('.certified-by-slider').each(function () {
                var $slider = jQuery(this);
                if ($slider.data('certifiedByReady')) return;

                $slider.data('certifiedByReady', true).bxSlider({
                    minSlides: 4,
                    maxSlides: 4,
                    slideWidth: 180,
                    slideMargin: 80,
                    ticker: true,
                    speed: 22000
                });
            });
        }

        readyCertifiedBySlider(document);
        window.addEventListener('load', function () { readyCertifiedBySlider(document); });
        document.addEventListener('shopify:section:load', function (event) { readyCertifiedBySlider(event.target); });
    })();
</script>

{% schema %}
{
  "name": "Certified by",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Certified by"
    }
  ],
  "blocks": [
    {
      "type": "certificate",
      "name": "Certificate",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text",
          "default": "Certification logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Certified by",
      "blocks": [
        { "type": "certificate" },
        { "type": "certificate" },
        { "type": "certificate" },
        { "type": "certificate" }
      ]
    }
  ]
}
{% endschema %}
