<section class="blogs-feature">
    <div class="container">
        {% if section.settings.heading != blank %}
            <div class="heading text-animation">
                <h2>{{ section.settings.heading }}</h2>
            </div>
        {% endif %}
        <div class="blogs-feature-in">
            <div class="left">
                {% if section.settings.show_navigation %}
                <div class="blogs-feature-nav">
                    <div class="prev-btn">
                        <svg width="43" height="43" viewBox="0 0 43 43" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="21.3472" cy="21.3472" r="21.3472" transform="matrix(-1 0 0 1 42.6943 0)"
                                fill="#1A1A1A" />
                            <path
                                d="M30.0313 20.8421L17.665 20.8421L22.9648 15.5423L22.2985 14.7852L15.7368 21.3469L22.2985 27.9086L22.9648 27.1515L17.665 21.8516L30.0313 21.8516L30.0313 20.8421Z"
                                fill="white" />
                        </svg>
                    </div>
                    <div class="next-btn">
                        <svg width="43" height="43" viewBox="0 0 43 43" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="21.3472" cy="21.3472" r="21.3472" fill="#1A1A1A" />
                            <path
                                d="M12.663 20.8421L25.0294 20.8421L19.7295 15.5423L20.3958 14.7852L26.9575 21.3469L20.3958 27.9086L19.7295 27.1515L25.0294 21.8516L12.663 21.8516L12.663 20.8421Z"
                                fill="white" />
                        </svg>

                    </div>
                </div>
                {% endif %}
            </div>
            <div class="right">
                <div class="blogs-feature-card-wrap">
                    {% assign selected_blog = section.settings.blog %}
                    {% if selected_blog != blank and selected_blog.articles_count > 0 %}
                        {% for article in selected_blog.articles limit: section.settings.articles_to_show %}
                            <div class="item">
                                {% render 'blogs-feature-card',
                                    article: article,
                                    blog_title: selected_blog.title,
                                    show_category: section.settings.show_category
                                %}
                            </div>
                        {% endfor %}
                    {% elsif section.blocks.size > 0 %}
                        {% for block in section.blocks %}
                            {% if block.settings.article != blank %}
                                <div class="item" {{ block.shopify_attributes }}>
                                    {% render 'blogs-feature-card',
                                        article: block.settings.article,
                                        show_category: section.settings.show_category
                                    %}
                                </div>
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Blogs Feature",
  "tag": "section",
  "class": "blogs-feature-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Thoughts Worth Returning To"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "min": 1,
      "max": 12,
      "step": 1,
      "label": "Articles to show",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_category",
      "label": "Show category",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Article"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blogs Feature"
    }
  ]
}
{% endschema %}
