<section class="new-faq-section" data-new-faq-section-{{ section.id }}>
  <div class="new-faq-left">
    {% if section.settings.image != blank %}
      <div class="new-faq-sec-img">
        {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.image.alt, class: 'img' }}
      </div>
    {% endif %}
  </div>

  <div class="new-faq-right">
    <div class="new-faq-heading">
      <h2>{{ section.settings.heading | default: 'FAQs' }}</h2>
    </div>

    <div class="new-faq-accordion">
      {% for block in section.blocks %}
        <div class="new-faq-item{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
          <button
            type="button"
            class="new-faq-question"
            aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
            <span>{{ block.settings.question }}</span>
            <span class="new-faq-icon" aria-hidden="true"></span>
          </button>

          <div class="new-faq-answer">
            <div class="new-faq-answer-inner">
              {% if block.settings.answer != blank %}
                <p>{{ block.settings.answer }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
      <div class="new-faq-cta">
        <a href="{{ section.settings.cta_link }}">{{ section.settings.cta_text }}</a>
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    var section = document.querySelector('[data-new-faq-section-{{ section.id }}]');
    if (!section || section.dataset.faqReady === 'true') return;

    var items = Array.prototype.slice.call(section.querySelectorAll('.new-faq-item'));
    section.dataset.faqReady = 'true';

    function setAnswerHeight(item, isOpen) {
      var answer = item.querySelector('.new-faq-answer');
      if (!answer) return;

      answer.style.maxHeight = isOpen ? answer.scrollHeight + 8 + 'px' : '0px';
    }

    function setItemState(item, isOpen) {
      item.classList.toggle('active', isOpen);
      setAnswerHeight(item, isOpen);

      var button = item.querySelector('.new-faq-question');
      if (button) button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    }

    items.forEach(function (item) {
      setAnswerHeight(item, item.classList.contains('active'));
    });

    items.forEach(function (item) {
      var button = item.querySelector('.new-faq-question');
      if (!button) return;

      button.addEventListener('click', function () {
        var isActive = item.classList.contains('active');

        items.forEach(function (faqItem) {
          setItemState(faqItem, false);
        });

        if (!isActive) {
          setItemState(item, true);
        }
      });
    });

    window.addEventListener('resize', function () {
      items.forEach(function (item) {
        if (item.classList.contains('active')) setAnswerHeight(item, true);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "New FAQ Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQs"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "View All FAQs"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Why Isn’t Food Alone Always Enough?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Because informed choices are powerful ones and you deserve both clarity and calm."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New FAQ Section",
      "blocks": [
        {
          "type": "faq_item"
        },
        {
          "type": "faq_item"
        },
        {
          "type": "faq_item"
        },
        {
          "type": "faq_item"
        }
      ]
    }
  ]
}
{% endschema %}
