    "new-faq-section": {
      "type": "new-faq-section",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "Do I need a prescription to take supplements?",
            "answer": "No. Supplements are designed to support wellbeing, not replace medical treatment. But speaking with a healthcare professional is helpful if you have specific conditions or concerns."
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "Will supplements affect my hormones?",
            "answer": "Not negatively, in fact, the right nutrients gently support hormonal balance. Magnesium, zinc, B-vitamins and iron all play a role in regulating cycles and mood."
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "Are supplements safe to take long-term?",
            "answer": "Yes, when they’re clean, thoughtfully formulated, and used in recommended amounts. Consistency is where benefits unfold."
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Why do some supplements not “work”?",
            "answer": "Because not all forms of nutrients are easily absorbed. The body responds best to active, bioavailable forms, the ones it recognises and uses deeply."
          }
        },
        "faq_item_xPBdTP": {
          "type": "faq_item",
          "settings": {
            "question": "Why does simplicity matter in supplements?",
            "answer": "Because when something feels clear and uncomplicated, you’re more likely to stay consistent, and consistency is where results happen."
          }
        },
        "faq_item_zNPzxt": {
          "type": "faq_item",
          "settings": {
            "question": "What results should I realistically expect?",
            "answer": "Subtle shifts that build: better energy, steadier mood, smoother cycles, deeper rest, stronger foundation. Small changes compounding over time."
          }
        },
        "faq_item_xbya6q": {
          "type": "faq_item",
          "settings": {
            "question": "What makes Orbe different from other supplement brands?",
            "answer": "Intention. Clarity. Purpose in design. Clean ingredients, active nutrient forms, and thoughtful delivery — all crafted to simplify your daily wellbeing."
          }
        }
      },
